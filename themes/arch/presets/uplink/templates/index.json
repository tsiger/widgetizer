    "home_services": {
      "type": "numbered-service-list",
      "settings": {
        "eyebrow": "What we do",
        "eyebrow_uppercase": true,
        "title": "Five pillars, one retainer.",
        "description": "Everything a growing team needs from IT — delivered by one team, billed under one contract.",
        "heading_alignment": "start",
        "show_numbers": true,
        "show_dividers": true,
        "color_scheme": "standard-primary"
      },
      "blocks": {
        "svc-helpdesk": {
          "type": "service",
          "settings": {
            "title": "Helpdesk",
            "description": "<p>People-first support. Pick up the phone and get a real engineer — no tier-1 robots, no ticket hot-potato. Full coverage Monday through Friday, after-hours on-call for managed clients.</p>",
            "link": {
              "text": "How we run helpdesk",
              "href": "services.html",
              "target": "_self"
            }
          }
        },
        "svc-networking": {
          "type": "service",
          "settings": {
            "title": "Managed networking",
            "description": "<p>Routers, switches, Wi‑Fi, VPN, and firewalls — designed, deployed, monitored, and documented. Vendor-neutral procurement so you're not locked in.</p>",
            "link": {
              "text": "Our networking approach",
              "href": "services.html",
              "target": "_self"
            }
          }
        },
        "svc-security": {
          "type": "service",
          "settings": {
            "title": "Cybersecurity",
            "description": "<p>Endpoint detection, MFA on every identity, email filtering, phishing simulations, and a quarterly security review. A written baseline with real teeth — not a slide deck.</p>",
            "link": {
              "text": "Security baseline",
              "href": "services.html",
              "target": "_self"
            }
          }
        },
        "svc-cloud": {
          "type": "service",
          "settings": {
            "title": "Cloud",
            "description": "<p>Microsoft 365, Google Workspace, Azure. Licensing, identity, tenant hardening, and migrations from on‑prem or cross‑cloud — scoped and priced up front.</p>",
            "link": {
              "text": "Cloud services",
              "href": "services.html",
              "target": "_self"
            }
          }
        },
        "svc-backup": {
          "type": "service",
          "settings": {
            "title": "Backup & disaster recovery",
            "description": "<p>Off‑site encrypted backups with documented RTO per system, quarterly restore drills, and written recovery runbooks. You never find out your backup is broken at the wrong moment.</p>",
            "link": {
              "text": "Backup program",
              "href": "services.html",
              "target": "_self"
            }
          }
        }
      },

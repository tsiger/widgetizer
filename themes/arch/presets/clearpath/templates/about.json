        "intro-heading": {
          "type": "heading",
          "settings": {
            "text": "An independent advisor, by design.",
            "size": "3xl",
            "position": "right"
          }
        },
        "intro-body": {
          "type": "text",
          "settings": {
            "text": "<p>I spent twelve years inside the kind of companies I now advise — two as a founder, six leading operations at a growth-stage SaaS business, and four as a partner at a boutique consulting firm I left because it had gotten too big to pay attention.</p><p>Clearpath is the shape of the practice I wanted to find when I needed one, and couldn't.</p>",
            "size": "base",
            "muted": false,
            "position": "right"
          }
        }
      },
      "blocksOrder": ["portrait", "intro-eyebrow", "intro-heading", "intro-body"]

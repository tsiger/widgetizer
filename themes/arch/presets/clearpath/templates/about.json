    "beliefs": {
      "type": "rich-text",
      "settings": {
        "text_alignment": "start",
        "content_width": "medium",
        "color_scheme": "standard-secondary"
      },
      "blocks": {
        "beliefs-heading": {
          "type": "heading",
          "settings": {
            "text": "What I believe about this work.",
            "size": "3xl"
          }
        },
        "beliefs-body-1": {
          "type": "text",
          "settings": {
            "text": "<p>Good consulting is mostly careful listening and accurate writing. The frameworks can be learned in an afternoon; the willingness to sit with a problem for a week until you actually understand it takes longer.</p>",
            "size": "base",
            "uppercase": false,
            "muted": false
          }
        },
        "beliefs-body-2": {
          "type": "text",
          "settings": {
            "text": "<p>Most operating friction is social, not analytical. The math is usually fine. What breaks is the part where a group of intelligent people agree on what to do next — and that part is solved through clarity of language, not volume of data.</p>",
            "size": "base",
            "uppercase": false,
            "muted": false
          }
        },
        "beliefs-body-3": {
          "type": "text",
          "settings": {
            "text": "<p>I'd rather be useful to a small number of people than visible to a large number. The practice is deliberately small and deliberately slow.</p>",
            "size": "base",
            "uppercase": false,
            "muted": false
          }
        }
      },
      "blocksOrder": ["beliefs-heading", "beliefs-body-1", "beliefs-body-2", "beliefs-body-3"]
    },
    "journey": {
      "type": "timeline",
      "settings": {
        "eyebrow": "",
        "title": "How I got here",
        "description": "",
        "heading_alignment": "start",
        "layout": "vertical",
        "color_scheme": "standard-primary"
      },
      "blocks": {
        "stop-1": {
          "type": "item",
          "settings": {
            "date": "2011 — 2013",
            "title": "Founded and sold a small SaaS",
            "description": "<p>Two years of learning that most startup problems are about communication, not product.</p>"
          }
        },
        "stop-2": {
          "type": "item",
          "settings": {
            "date": "2013 — 2019",
            "title": "VP Operations, growth-stage SaaS",
            "description": "<p>Six years scaling a business from thirty people to four hundred. Learned the failure modes of every operating ritual at least twice.</p>"
          }
        },
        "stop-3": {
          "type": "item",
          "settings": {
            "date": "2019 — 2023",
            "title": "Partner, boutique consulting firm",
            "description": "<p>Four years of client work. Left when the firm grew past the point where I could remember every client's name.</p>"
          }
        },
        "stop-4": {
          "type": "item",
          "settings": {
            "date": "2023 — now",
            "title": "Clearpath",
            "description": "<p>Independent practice. One engagement at a time, by design.</p>"
          }
        }
      },
      "blocksOrder": ["stop-1", "stop-2", "stop-3", "stop-4"]
    },
    "peer_quote": {
      "type": "testimonial-hero",

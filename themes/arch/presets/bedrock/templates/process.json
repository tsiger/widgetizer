    "the_steps": {
      "type": "steps",
      "settings": {
        "eyebrow": "The process",
        "eyebrow_uppercase": true,
        "title": "Five steps, start to finish.",
        "description": "",
        "heading_alignment": "start",
        "color_scheme": "standard-primary",
        "top_spacing": "auto",
        "bottom_spacing": "auto"
      },
      "blocks": {
        "step-visit": {
          "type": "step",
          "settings": {
            "image": "/uploads/images/bedrock-process-consult.webp",
            "title": "Site visit & consultation",
            "description": "<p>We walk the space with you, measure, and talk through what you're after. You'll get straight answers about what's realistic — including when the honest answer is that a project isn't worth doing.</p>",
            "button_link": {
              "href": "contact.html",
              "text": "Book a site visit",
              "target": "_self"
            }
          }
        },
        "step-quote": {
          "type": "step",
          "settings": {
            "image": "/uploads/images/bedrock-process-quote.webp",
            "title": "Design & fixed quote",
            "description": "<p>Within five days you get a written, fixed price — itemized, with allowances spelled out. It's valid for sixty days and it only changes if you change the scope.</p>"
          }
        },
        "step-permits": {
          "type": "step",
          "settings": {
            "image": "/uploads/images/bedrock-process-permits.webp",
            "title": "Permits & preparation",
            "description": "<p>We file the permits, order the long-lead materials, and prep the site — floor protection down, dust barriers up — before the first cut is made.</p>"
          }
        },
        "step-build": {
          "type": "step",
          "settings": {
            "image": "/uploads/images/bedrock-process-build.webp",
            "title": "The build",
            "description": "<p>Your project manager sends a written update every Friday: what happened, what's next, and anything that needs a decision from you. The site gets swept every day it's worked.</p>"
          }
        },
        "step-walkthrough": {
          "type": "step",
          "settings": {
            "image": "/uploads/images/bedrock-process-walkthrough.webp",
            "title": "Walkthrough & warranty",
            "description": "<p>We walk every room together and write down anything that isn't right. The final payment isn't due until that list is cleared. Then the two-year warranty clock starts.</p>"
          }
        }
      },
      "blocksOrder": ["step-visit", "step-quote", "step-permits", "step-build", "step-walkthrough"]

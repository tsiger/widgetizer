        "faq-1": {
          "type": "item",
          "settings": {
            "question": "How do I book a cleaning?",
            "answer": "<p>Call us at (555) 718-2200 or email hello@sparkhaus.co. Let us know the size of your space, the type of cleaning you need, and your preferred date. We'll send you a quote within the hour.</p>"
          }
        },
        "faq-2": {
          "type": "item",
          "settings": {
            "question": "What's your cancellation policy?",
            "answer": "<p>You can reschedule or cancel with 24 hours' notice at no charge. Cancellations with less than 24 hours' notice may incur a 50% fee. Same-day cancellations are charged in full.</p>"
          }
        },
        "faq-3": {
          "type": "item",
          "settings": {
            "question": "What forms of payment do you accept?",
            "answer": "<p>We accept credit and debit cards, e-transfer, and invoiced billing for commercial accounts. Payment is collected after the cleaning is complete and you're satisfied with the result.</p>"
          }
        },
        "faq-4": {
          "type": "item",
          "settings": {
            "question": "How quickly can you start?",
            "answer": "<p>We often have same-day or next-day availability for standard residential cleanings. Commercial contracts and deep cleans typically start within 2-3 business days of booking. Call for current availability.</p>"
          }
        },

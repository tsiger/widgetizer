      "blocks": {
        "detail-transit": {
          "type": "item",
          "settings": {
            "question": "Public transit",
            "answer": "<p>The G train at Classon Avenue is the closest stop. From the A/C at Clinton–Washington, it's a ten-minute walk east. The B48 bus stops at the corner of Elm and Franklin.</p>"
          }
        },
        "detail-parking": {
          "type": "item",
          "settings": {
            "question": "Parking",
            "answer": "<p>We don't have a dedicated lot. Street parking is metered until 7 pm and free after. A paid garage is available two blocks north on Washington Avenue.</p>"
          }
        },
        "detail-accessibility": {
          "type": "item",
          "settings": {
            "question": "Accessibility",
            "answer": "<p>The entrance and dining room are step-free. An accessible bathroom is on the main floor. If you have specific needs, please let us know when booking so we can seat you appropriately.</p>"
          }
        },
        "detail-drinks": {
          "type": "item",
          "settings": {
            "question": "A drink before dinner",
            "answer": "<p>The bar at The Long Goodbye, two doors down, is our favorite spot for an aperitif. They know to send you over at your reservation time.</p>"
          }
        },
        "detail-bikes": {
          "type": "item",
          "settings": {
            "question": "What to do with bikes",
            "answer": "<p>There are five bike racks directly outside. We do not store bikes inside the dining room — but the block is well-lit and the racks are covered by our camera.</p>"
          }
        }
      },

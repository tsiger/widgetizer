        "policy-cancellation": {
          "type": "item",
          "settings": {
            "question": "Cancellation policy",
            "answer": "<p>We ask for 24 hours' notice for cancellations. Same-day cancellations and no-shows are charged $25 per guest. Plans change — if you need to adjust your reservation, please call us and we'll do our best to help.</p>"
          }
        },
        "policy-dress": {
          "type": "item",
          "settings": {
            "question": "Dress code",
            "answer": "<p>Smart casual. The room is warm and softly lit, not formal. Wear what you'd wear to a friend's dinner party.</p>"
          }
        },
        "policy-late": {
          "type": "item",
          "settings": {
            "question": "Arriving late",
            "answer": "<p>We hold tables for fifteen minutes past your reservation. If you're running later than that, please call so we can reseat you if a table is available.</p>"
          }
        },
        "policy-dietary": {
          "type": "item",
          "settings": {
            "question": "Dietary restrictions and allergies",
            "answer": "<p>The kitchen accommodates most allergies and dietary preferences with a day's notice. Please note restrictions when booking so we can plan the menu around them.</p>"
          }
        },
        "policy-children": {
          "type": "item",
          "settings": {
            "question": "Children",
            "answer": "<p>Well-behaved children are welcome. We have two high chairs, and the kitchen will happily prepare a simpler plate for younger guests.</p>"
          }
        },
        "policy-large-parties": {
          "type": "item",
          "settings": {
            "question": "Large parties",
            "answer": "<p>The main room seats up to six per table. For parties of seven or more, please email hello@saffron-brooklyn.com to arrange a semi-private booking.</p>"
          }
        },
        "policy-private": {
          "type": "item",
          "settings": {
            "question": "Private dining",
            "answer": "<p>A semi-private table of ten is available Tuesday through Thursday. A set menu is required. Email us to discuss dates and budget.</p>"
          }
        }
      },

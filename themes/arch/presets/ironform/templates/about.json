        "story-heading": {
          "type": "heading",
          "settings": {
            "text": "Marcus Cole",
            "size": "2xl"
          }
        },
        "story-text-1": {
          "type": "text",
          "settings": {
            "text": "<p>Marcus is a NASM-certified personal trainer and competitive powerlifter with 12 years of experience coaching clients of every level — from first-time gym-goers to national-level athletes. He started Ironform because he was tired of the fitness industry selling shortcuts.</p>",
            "size": "base"
          }
        },
        "story-text-2": {
          "type": "text",
          "settings": {
            "text": "<p>His approach is simple: smart programming, honest nutrition, consistent effort. No gimmicks, no fads, no magic supplements. Just structured training that produces real, lasting results. Over 500 clients trained. The work speaks for itself.</p>",
            "size": "base"
          }
        }
      },

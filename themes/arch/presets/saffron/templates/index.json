      "blocks": {
        "quote-1": {
          "type": "quote",
          "settings": {
            "quote": "The braised lamb shank might be the best thing I've eaten this year. The atmosphere is warm without being stuffy, and the staff made us feel like regulars from the moment we walked in.",

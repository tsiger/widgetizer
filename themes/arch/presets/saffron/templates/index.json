        "exp-text": {
          "type": "text",
          "settings": {
            "text": "<p>Step into a space where exposed brick meets soft candlelight, where the hum of conversation blends with the rhythm of our open kitchen. Saffron was designed for lingering — for long dinners that turn into late nights.</p>",
            "size": "base",
            "uppercase": false,
            "muted": false

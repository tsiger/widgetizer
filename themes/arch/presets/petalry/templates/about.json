        "story-text-1": {
          "type": "text",
          "settings": {
            "text": "<p>Petalry started in a small studio with a market stall, a bucket of seasonal blooms, and a belief that every arrangement should feel intentional. Not just pretty — but specific to the person who receives it.</p>",

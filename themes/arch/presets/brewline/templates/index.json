    "drinks": {
      "type": "image-tabs",
      "settings": {
        "eyebrow": "What We Brew",
        "title": "Find Your Cup",
        "description": "Whether you're a black coffee purist or a lavender latte adventurer, we've got something for you.",
        "heading_alignment": "center",
        "image_position": "start",
        "color_scheme": "standard-secondary"
      },
      "blocks": {
        "tab-1": {
          "type": "tab",
          "settings": {
            "title": "Espresso",
            "description": "<p>Bold, concentrated, and perfectly extracted. The foundation of everything we do — from a straight double shot to a velvety flat white. Our house blend balances chocolate and citrus notes, pulled fresh to order.</p>"
          }
        },
        "tab-2": {
          "type": "tab",
          "settings": {
            "title": "Pour Over",
            "description": "<p>Single-origin, hand-poured. The purest way to taste what makes each bean unique. We rotate origins weekly and dial in every morning. Ask your barista what's on — they'll talk your ear off about it.</p>"
          }
        },
        "tab-3": {
          "type": "tab",
          "settings": {
            "title": "Cold Brew",
            "description": "<p>Steeped for 20 hours. Smooth, bold, and naturally sweet — no bitterness in sight. Served over ice, on tap. Our most popular order when the temperature climbs above 70°F.</p>"
          }
        }
      },
      "blocksOrder": ["tab-1", "tab-2", "tab-3"]
    },

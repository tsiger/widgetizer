        },
        "intro-text": {
          "type": "text",
          "settings": {
            "text": "<p>We source our beans directly from small farms in Ethiopia, Colombia, and Guatemala. Every batch is roasted in our shop, dialed in each morning, and brewed to bring out the best each origin has to offer.</p>",
            "size": "base"
          }
        },
        "intro-features": {

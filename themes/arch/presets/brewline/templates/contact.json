          "type": "item",
          "settings": {
            "question": "Do you have wifi?",
            "answer": "<p>Yes — free wifi for all customers. We do have a laptop-free zone at the bar for those who want to unplug. The communal table and window seats are fair game for working.</p>"
          }
        },
        "faq-2": {
          "type": "item",
          "settings": {
            "question": "What dairy alternatives do you offer?",
            "answer": "<p>We stock oat milk, almond milk, and coconut milk. Oat is our default — it steams beautifully and pairs best with espresso. All alternatives are available at no extra charge.</p>"
          }
        },
        "faq-3": {
          "type": "item",
          "settings": {
            "question": "Is the patio dog-friendly?",
            "answer": "<p>Absolutely. Dogs are welcome on the back patio. We keep a water bowl by the door and have been known to hand out the occasional treat.</p>"
          }
        },
        "faq-4": {
          "type": "item",
          "settings": {
            "question": "Can I buy beans to take home?",
            "answer": "<p>Yes — we sell all of our house-roasted beans by the bag (250g or 1kg). Whole bean or ground to your preferred method. We also offer a monthly subscription if you want fresh beans delivered to your door.</p>"
          }
        }
      },
      "blocksOrder": ["faq-1", "faq-2", "faq-3", "faq-4"]

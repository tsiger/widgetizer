    "origin": {
      "type": "image-text",
      "settings": {
        "image_position": "start",
        "color_scheme": "standard-primary",
        "image": "/uploads/images/about-founder.webp"
      },
      "blocks": {
        "origin-eyebrow": {
          "type": "text",
          "settings": {
            "text": "<p>How It Started</p>",
            "size": "sm",
            "uppercase": true,
            "muted": true
          }
        },
        "origin-heading": {
          "type": "heading",
          "settings": {
            "text": "From a Garage Roaster to Your Morning Ritual",
            "size": "3xl"
          }
        },
        "origin-text": {
          "type": "text",
          "settings": {
            "text": "<p>Brewline started in 2017 when Sam Chen traded a career in tech for a second-hand drum roaster in his parents' garage. Armed with a notebook full of flavor profiles and a stubborn belief that specialty coffee shouldn't feel pretentious, he started selling bags at the local farmers market.</p><p>Two years later, the first Brewline shop opened — a 500-square-foot space with exactly six seats and the same roaster that started it all. Today, we've grown, but the ethos hasn't changed: great coffee, good people, no attitude.</p>",
            "size": "base"
          }
        }
      },
      "blocksOrder": [
        "origin-eyebrow",
        "origin-heading",
        "origin-text"
      ]
    },
    "process": {
      "type": "steps",
      "settings": {
        "eyebrow": "Bean to Cup",
        "title": "How We Brew",
        "description": "Every cup of Brewline coffee follows the same journey — from farm to your hands.",
        "heading_alignment": "center",
        "color_scheme": "standard-secondary"
      },
      "blocks": {
        "step-1": {
          "type": "step",
          "settings": {
            "title": "Source",
            "description": "<p>We build direct relationships with small-lot farmers in Ethiopia, Colombia, and Guatemala. We visit the farms, cup the harvests, and choose only what excites us.</p>",
            "image": "/uploads/images/step-source.webp"
          }
        },
        "step-2": {
          "type": "step",
          "settings": {
            "title": "Roast",
            "description": "<p>Every batch is roasted in-house on our Probat roaster. Light to medium profiles that honor the origin — never over-roasted, never bitter.</p>",
            "image": "/uploads/images/step-roast.webp"
          }
        },
        "step-3": {
          "type": "step",
          "settings": {
            "title": "Dial In",
            "description": "<p>Each morning, we dial in every grinder and every method. Water temp, grind size, dose — it all matters, and we adjust until it's right.</p>",
            "image": "/uploads/images/step-dialin.webp"
          }
        },
        "step-4": {
          "type": "step",
          "settings": {
            "title": "Serve",
            "description": "<p>Your coffee is brewed to order by baristas who care about the craft. We'll happily talk you through the menu — no question is too basic.</p>",
            "image": "/uploads/images/step-serve.webp"
          }
        }
      },
      "blocksOrder": [
        "step-1",
        "step-2",
        "step-3",
        "step-4"
      ]
    },

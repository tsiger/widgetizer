      "blocks": {
        "hero-heading": {
          "type": "heading",
          "settings": {
            "text": "Our Story",
            "size": "5xl"
          }
        },
        "hero-text": {
          "type": "text",
          "settings": {
            "text": "A tiny roastery that grew into a neighborhood staple — one cup at a time.",
            "size": "lg",
            "uppercase": false,
            "muted": false
          }
        }
      },
      "blocksOrder": ["hero-heading", "hero-text"]

      "blocks": {
        "r-1": {
          "type": "quote",
          "settings": {
            "quote": "Called at 10pm on a Sunday with a leaking supply line flooding the laundry. Dani was at our door in 40 minutes with the parts and had it fixed by midnight. Quoted me before he started. Paid exactly what he quoted.",
            "name": "Melissa R.",
            "title": "Sellwood · Emergency repair, 2025",
            "rating": "5"
          }
        },
        "r-2": {
          "type": "quote",
          "settings": {
            "quote": "Got three quotes on replacing our 19-year-old water heater. Pipeworks wasn't the cheapest, but they were the only ones who walked me through tank vs. tankless honestly — including why tankless wasn't right for our setup. Installed the next morning.",
            "name": "Tom K.",
            "title": "Eastmoreland · Water heater replace, 2024",
            "rating": "5"
          }
        },
        "r-3": {
          "type": "quote",
          "settings": {
            "quote": "Kitchen drain had been slow for months. Two other plumbers snaked it and charged us, and it came back both times. Pipeworks ran a camera, found a root, and hydro-jetted the line. Hasn't backed up since.",
            "name": "Priya S.",
            "title": "Hawthorne · Drain & sewer, 2025",
            "rating": "5"
          }
        },
        "r-4": {
          "type": "quote",
          "settings": {
            "quote": "We own a small restaurant on Division. When a supply line under the sink burst during service, they had someone there in under an hour and we were back open for dinner. Fair price for an emergency call-out.",
            "name": "Javier L.",
            "title": "Richmond · Light commercial, 2024",
            "rating": "5"
          }
        },
        "r-5": {
          "type": "quote",
          "settings": {
            "quote": "Repiped a 1920s bungalow. Marcus walked through the whole house on day one, marked every wall he'd need to open, and gave us a fixed price. Finished in three days, cleaned up perfectly, patched the drywall like it never happened.",
            "name": "Anne B.",
            "title": "Laurelhurst · Whole-house repipe, 2024",
            "rating": "5"
          }
        },
        "r-6": {
          "type": "quote",
          "settings": {
            "quote": "Fourth time using Pipeworks in six years. Different houses, different jobs, same experience every time. Shows up when they said, prices what they quoted, cleans up after. That's all I'm asking for.",
            "name": "David G.",
            "title": "Woodstock · Repeat client since 2020",
            "rating": "5"
          }
        }
      },
      "blocksOrder": ["r-1", "r-2", "r-3", "r-4", "r-5", "r-6"]

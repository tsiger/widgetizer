    "area_faqs": {
      "type": "accordion",
      "settings": {
        "eyebrow": "Area questions",
        "eyebrow_uppercase": true,
        "title": "Before you call.",
        "description": "",
        "heading_alignment": "start",
        "style": "separated",
        "allow_multiple": false,
        "sidebar_position": "end",
        "color_scheme": "standard-primary",
        "top_spacing": "auto",
        "bottom_spacing": "auto"
      },
      "blocks": {
        "a-1": {
          "type": "item",
          "settings": {
            "question": "My neighborhood isn't listed — do you still serve it?",
            "answer": "<p>Probably. The list above is our most common service areas, but we regularly take calls from neighborhoods just outside it. Give us a call with your cross-street and we'll tell you honestly whether we're a good fit or whether a closer plumber would get to you faster.</p>"
          }
        },
        "a-2": {
          "type": "item",
          "settings": {
            "question": "Do extended-response areas cost more?",
            "answer": "<p>No. Our flat-rate prices are the same everywhere in our service area. Extended zones just take a bit longer to reach, so we tell you that upfront when you book so you're not waiting for a truck without knowing when it'll arrive.</p>"
          }
        },
        "a-3": {
          "type": "item",
          "settings": {
            "question": "How does 24/7 emergency response work outside the Portland core?",
            "answer": "<p>Same dispatcher, same number, any hour. Response windows stretch at night and on holidays — a typical after-hours emergency call takes 60–90 minutes in our core zone and up to two hours in extended areas. We stay on the phone with you until a tech is on the way.</p>"
          }
        },
        "a-4": {
          "type": "item",
          "settings": {
            "question": "Do you handle apartments and multi-unit buildings?",
            "answer": "<p>Yes — duplexes, fourplexes, small condo buildings, and light commercial. We coordinate with building managers, work around tenant schedules, and we're familiar with the shared-stack issues that come up in older Portland apartments.</p>"
          }
        },
        "a-5": {
          "type": "item",
          "settings": {
            "question": "Do you charge a travel fee?",
            "answer": "<p>No travel fee inside our service area — the map above covers it. For calls well outside the map we'll give you a heads-up if there's a travel component before you book, and most of the time we'll refer you to a closer plumber instead.</p>"
          }
        },
        "a-sidebar": {
          "type": "info",
          "settings": {
            "title": "Check coverage",
            "text": "<p>(555) 203-9844</p><p>Tell the dispatcher your cross-street and we'll confirm a response window before you book.</p>"
          }
        }
      },
      "blocksOrder": ["a-1", "a-2", "a-3", "a-4", "a-5", "a-sidebar"]
    },

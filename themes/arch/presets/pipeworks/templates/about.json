      "blocks": {
        "faq-1": {
          "type": "item",
          "settings": {
            "question": "Are you licensed and insured?",
            "answer": "<p>Yes. Pipeworks holds active plumbing and electrical contractor licenses in Oregon and Washington. We carry full general liability and workers' compensation insurance. License numbers are available on request.</p>"
          }
        },
        "faq-2": {
          "type": "item",
          "settings": {
            "question": "Do you offer warranties?",
            "answer": "<p>All labor carries a one-year workmanship warranty. Parts are covered by the manufacturer's warranty, which we help you register and file if needed. If something we installed fails, we come back and fix it at no charge.</p>"
          }
        },
        "faq-3": {
          "type": "item",
          "settings": {
            "question": "What are your hours?",
            "answer": "<p>Regular hours are Monday through Friday, 7 AM to 6 PM, and Saturday 8 AM to 2 PM. Emergency service is available 24 hours a day, 7 days a week, 365 days a year — no overtime charges.</p>"
          }
        },
        "faq-4": {
          "type": "item",
          "settings": {
            "question": "Do you charge for estimates?",
            "answer": "<p>No. All estimates are free and come with no obligation. We diagnose the problem, explain your options, and give you an upfront price before any work begins.</p>"
          }
        },
        "faq-5": {
          "type": "item",
          "settings": {
            "question": "How quickly can you respond to an emergency?",
            "answer": "<p>Our average emergency response time is 60 minutes within the Portland metro area. We dispatch the nearest available technician the moment you call.</p>"
          }
        }
      },
      "blocksOrder": ["faq-1", "faq-2", "faq-3", "faq-4", "faq-5"]

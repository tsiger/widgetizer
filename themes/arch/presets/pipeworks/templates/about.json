        "story-heading": {
          "type": "heading",
          "settings": {
            "text": "Family-Owned, Community-Trusted",
            "size": "3xl"
          }
        },
        "story-text-1": {
          "type": "text",
          "settings": {
            "text": "<p>Mike Torres started Pipeworks in 2008 with a used van, a toolbox, and a simple belief: if you do honest work at a fair price, the business will come. He was right.</p>",
            "size": "base"
          }
        },
        "story-text-2": {
          "type": "text",
          "settings": {
            "text": "<p>Seventeen years later, Pipeworks is a team of licensed plumbers and electricians serving thousands of homes across Greater Portland. We've grown, but the values haven't changed — show up on time, do it right, clean up after yourself, and charge what's fair.</p>",
            "size": "base"
          }
        }
      },
      "blocksOrder": ["story-eyebrow", "story-heading", "story-text-1", "story-text-2"]
    },

      "blocks": {
        "review-1": {
          "type": "quote",
          "settings": {
            "quote": "The kind of place where you arrive planning to explore the valley and end up spending the whole afternoon on the porch with a book. We have already booked our return.",
            "author": "Sarah M.",
            "role": "Weekend stay, October",
            "rating": 5
          }
        },
        "review-2": {
          "type": "quote",
          "settings": {
            "quote": "Breakfast alone is worth the trip. But then you see your room, and the garden, and the way the light comes through the windows in the morning. Absolutely perfect.",
            "author": "David & Lena K.",
            "role": "Anniversary trip",
            "rating": 5
          }
        },
        "review-3": {
          "type": "quote",
          "settings": {
            "quote": "Clara and James make you feel like a guest in their home, not a customer in a hotel. The Tower Room is extraordinary. We will be back every autumn.",

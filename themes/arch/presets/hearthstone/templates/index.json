    "reviews": {
      "type": "testimonials",
      "settings": {
        "eyebrow": "From guests",
        "eyebrow_uppercase": true,
        "title": "What people say.",
        "heading_alignment": "center",
        "layout": "carousel",
        "columns_desktop": 3,
        "card_layout": "flat",
        "color_scheme": "standard-primary",
        "top_spacing": "auto",
        "bottom_spacing": "auto"
      },
      "blocks": {
        "r-1": {
          "type": "quote",
          "settings": {
            "quote": "We went for four days in June for our honeymoon and stayed five. Eleni made us breakfast on the terrace every morning, Yannis walked us to the beach the first day so we wouldn't get lost, and the Olive room had the best light I've ever slept in. We'll be back.",
            "name": "Clara & Tomás",
            "title": "Four days · June honeymoon",
            "rating": "5"
          }
        },
        "r-2": {
          "type": "quote",
          "settings": {
            "quote": "Exactly what you hope a small Greek-island hotel will be. No televisions, no buffet, no staff in uniforms. Just a family who's been doing this for a decade and a house that's been in the family since 1870. We left with a bottle of their olive oil and a recipe for something we'd had at breakfast.",
            "name": "Hannes & Mira",
            "title": "A week in September · Berlin",
            "rating": "5"
          }
        },
        "r-3": {
          "type": "quote",
          "settings": {
            "quote": "I went alone to work on a book for a week. Eleni let me take breakfast up to my room most mornings, Yannis pointed me to a walk along the Byzantine road that changed how I write about the sea. The Jasmine room has a small desk by a window where I wrote more than I have anywhere else.",
            "name": "Alice R.",
            "title": "Writing week · May",
            "rating": "5"
          }
        },
        "r-4": {
          "type": "quote",
          "settings": {
            "quote": "We've stayed three times now, once with friends and twice on our own, and it just keeps getting quieter and better. They've added the pool since we first visited and we still haven't used it once — we're always on the terrace or in the garden.",
            "name": "Sophie & Jean-Luc",
            "title": "Three visits · Paris",
            "rating": "5"
          }
        },
        "r-5": {
          "type": "quote",
          "settings": {
            "quote": "Booked direct after finding the site on a friend's recommendation. Saved about 15% versus Booking.com, which in itself paid for a really good dinner. But the real value is that when we had a question at 11pm the night before arrival, Yannis answered in five minutes. That's the whole pitch.",
            "name": "Andrew K.",
            "title": "Anniversary trip · October",
            "rating": "5"
          }
        }
      },
      "blocksOrder": [
        "r-1",
        "r-2",
        "r-3",
        "r-4",
        "r-5"
      ]
    },

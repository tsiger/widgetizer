      "blocks": {
        "intro-body": {
          "type": "text",
          "settings": {
            "text": "<p>Six rooms, a walled garden, a stone terrace with a sea view, and breakfast from what's ripe in the orchard that week. We look after everything ourselves because that's the only way it stays the way we want it.</p>",

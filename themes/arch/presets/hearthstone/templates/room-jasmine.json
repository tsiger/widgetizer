    "room_faqs": {
      "type": "accordion",
      "settings": {
        "eyebrow": "Questions about this room",
        "eyebrow_uppercase": true,
        "title": "Before you book Jasmine.",
        "description": "",
        "heading_alignment": "center",
        "style": "separated",
        "allow_multiple": false,
        "sidebar_position": "end",
        "color_scheme": "standard-primary",
        "top_spacing": "auto",
        "bottom_spacing": "auto"
      },
      "blocks": {
        "rq-1": {
          "type": "item",
          "settings": {
            "question": "Is there a single-occupancy rate?",
            "answer": "<p>Same rate regardless of occupancy — €215 in low season, roughly €280 in peak July and August. The room sleeps two; we don't charge a supplement for a single guest.</p>"
          }
        },
        "rq-2": {
          "type": "item",
          "settings": {
            "question": "Can we connect Jasmine with another room for a family?",
            "answer": "<p>Jasmine and Olive share the east terrace but are separate rooms with their own entrances. If you need two rooms together for a family of four, ask us — we'll check availability and propose the quietest configuration.</p>"
          }
        },
        "rq-3": {
          "type": "item",
          "settings": {
            "question": "What's the bathroom setup?",
            "answer": "<p>En-suite with a walk-in shower, hand-thrown tiles matching the room, and a proper counter. No tub — we kept the space for the shower. Soap, shampoo, and conditioner are from a small producer on Paros.</p>"
          }
        },
        "rq-4": {
          "type": "item",
          "settings": {
            "question": "Is the terrace fully private?",
            "answer": "<p>Private to Jasmine — not shared. The jasmine and bougainvillea create a natural screen on one side; a low stone wall encloses the other. You'll hear neighbors in Olive occasionally but you won't see them.</p>"
          }
        },
        "rq-5": {
          "type": "item",
          "settings": {
            "question": "Can we bring a dog?",
            "answer": "<p>Jasmine isn't the best room for dogs — the terrace is on the first floor and the staircase is steep. If you're traveling with a dog, Thyme or Lemon on the ground floor are a much easier fit. Same rate, both open to the garden directly.</p>"
          }
        },
        "rq-sidebar": {
          "type": "info",
          "settings": {
            "title": "Ready to book?",
            "text": "<p>hello@example.com</p><p>We reply within a day, usually faster</p>"
          }
        }
      },

    "booking_faqs": {
      "type": "accordion",
      "settings": {
        "eyebrow": "Booking questions",
        "eyebrow_uppercase": true,
        "title": "Before you write.",
        "description": "",
        "heading_alignment": "start",
        "style": "separated",
        "allow_multiple": false,
        "sidebar_position": "end",
        "color_scheme": "standard-primary",
        "top_spacing": "auto",
        "bottom_spacing": "auto"
      },
      "blocks": {
        "bf-1": {
          "type": "item",
          "settings": {
            "question": "Do you work with booking platforms?",
            "answer": "<p>We're listed on Booking.com and Airbnb, but we'd rather book direct. Booking through us is usually 10–15% cheaper than through a platform, and you get a real conversation instead of a template confirmation.</p>"
          }
        },
        "bf-2": {
          "type": "item",
          "settings": {
            "question": "How does the deposit work?",
            "answer": "<p>30% deposit on booking — paid by bank transfer or card. Balance due on arrival, same payment options. No platform fees, no hidden charges.</p>"
          }
        },
        "bf-3": {
          "type": "item",
          "settings": {
            "question": "What happens if we need to cancel?",
            "answer": "<p>Full refund up to 30 days before arrival. Half refund between 30 and 14 days. No refund inside 14 days, but we'll usually move the booking to another week in the same season if there's availability and ask us in time.</p>"
          }
        },
        "bf-4": {
          "type": "item",
          "settings": {
            "question": "Do you host weddings or small events?",
            "answer": "<p>Occasionally — the courtyard can seat twenty for dinner, and we can book out all six rooms for a small wedding weekend. Ask us early; we only take one or two events a year and the dates fill up in October.</p>"
          }
        },
        "bf-5": {
          "type": "item",
          "settings": {
            "question": "Is the villa accessible?",
            "answer": "<p>Partially. The ground-floor Thyme and Lemon rooms and the main common areas are step-free. The upstairs rooms (Olive, Fig, Jasmine, Sage) require a flight of stone stairs. The garden and pool are both accessible. Tell us what you need and we'll be honest about whether we can host you well.</p>"
          }
        },
        "bf-6": {
          "type": "item",
          "settings": {
            "question": "What airport and how long a drive?",
            "answer": "<p>Paros airport (PAS), twenty-minute drive. Direct seasonal flights from Athens, and direct from several European capitals in high season. If you're arriving by ferry instead, Parikia port is a fifteen-minute drive and we can pick you up.</p>"
          }
        },
        "bf-sidebar": {
          "type": "info",
          "settings": {
            "title": "Still unsure?",
            "text": "<p>hello@example.com</p><p>Write anything. We reply within a day.</p>"
          }
        }
      },

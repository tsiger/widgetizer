        "q1": {
          "type": "item",
          "settings": {
            "question": "How large is the team?",
            "answer": "<p>Formline is a studio of eight \u2014 three licensed architects, two designers, a project coordinator, and two support staff. We stay small by design so that principals are involved in every project.</p>"
          }
        },
        "q2": {
          "type": "item",
          "settings": {
            "question": "What is your design philosophy?",
            "answer": "<p>We believe buildings should be specific to their place and their people. We don\u2019t have a house style. Each project responds to its site, its program, and its materials.</p>"
          }
        },
        "q3": {
          "type": "item",
          "settings": {
            "question": "Do you work outside Chicago?",
            "answer": "<p>Most of our work is in Chicagoland, but we\u2019ve completed projects in Michigan, Wisconsin, and Indiana. We\u2019re open to travel for the right project.</p>"
          }
        },
        "q4": {
          "type": "item",
          "settings": {
            "question": "What sustainability certifications do you pursue?",
            "answer": "<p>We\u2019ve completed LEED-certified projects and work with Passive House consultants when appropriate. But we believe good sustainable design doesn\u2019t always need a certification \u2014 it starts with siting, orientation, and material choices.</p>"
          }
        }
      },

    "reviews": {
      "type": "testimonials",
      "settings": {
        "eyebrow": "Reviews",
        "eyebrow_uppercase": true,
        "title": "What drivers say.",
        "heading_alignment": "center",
        "layout": "carousel",
        "columns_desktop": 3,

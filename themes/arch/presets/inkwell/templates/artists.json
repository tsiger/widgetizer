            "size": "4xl",
            "position": "right"
          }
        },
        "k-bio": {
          "type": "text",
          "settings": {
            "text": "<p>Bold line, flat colour, tight composition. Kiko apprenticed in Los Angeles and her work draws cleanly from American traditional — animals, florals, figurative pieces, nautical flash. Colour palette is measured, never muddy.</p><p>Books three to four months out.</p>",
            "size": "base",
            "muted": false,
            "position": "right"

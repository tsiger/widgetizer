        "cv-1": {
          "type": "quote",
          "settings": {
            "quote": "Saoirse redrew the design three times over six weeks until the proportions were exactly right. The tattoo is a year old and the lines are still as fine as the day they healed.",
            "name": "Mira L.",
            "title": "Sternum botanical with Saoirse, 2024",
            "rating": "5"
          }
        },
        "cv-2": {
          "type": "quote",
          "settings": {
            "quote": "Rafael's consultation was the most thoughtful conversation I've ever had about a tattoo. Twelve months of drawing before the first session — worth every minute.",
            "name": "David H.",
            "title": "Japanese back piece with Rafael, 2023",
            "rating": "5"
          }
        },
        "cv-3": {
          "type": "quote",
          "settings": {
            "quote": "Elena's ability to capture a face in black and grey is genuinely uncanny. The portrait of my grandfather looks more like him than most photographs.",
            "name": "Aliyah K.",
            "title": "Portrait with Elena, 2024",
            "rating": "5"
          }
        },
        "cv-4": {
          "type": "quote",
          "settings": {
            "quote": "I wanted ornament, not a picture. Jules drew something that genuinely belongs on a body — it feels designed rather than illustrated.",
            "name": "Theo R.",
            "title": "Chest ornament with Jules, 2024",
            "rating": "5"
          }
        }
      },

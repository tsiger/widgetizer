        "r-label": {
          "type": "text",
          "settings": {
            "text": "<p>Japanese · irezumi · 12 years</p>",
            "size": "sm",
            "uppercase": true,
            "muted": true,
            "position": "left"
          }
        },
        "r-name": {
          "type": "heading",
          "settings": {
            "text": "Rafael Mendes",
            "size": "4xl",
            "position": "left"
          }
        },
        "r-bio": {
          "type": "text",
          "settings": {
            "text": "<p>Traditional Japanese work — dragons, koi, hannya, peonies, wind and waves. Rafael trained under Horikiku in Tokyo and works predominantly on sleeves, back pieces, and bodysuit projects.</p><p>Books six to twelve months out. Does not accept small one-off pieces.</p>",
            "size": "base",
            "muted": false,
            "position": "left"
          }
        },
        "r-button": {
          "type": "button",
          "settings": {
            "link": {

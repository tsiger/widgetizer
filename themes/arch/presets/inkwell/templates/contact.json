        "q1": {
          "type": "item",
          "settings": {
            "question": "How do I book an appointment?",
            "answer": "<p>Call us, email, or DM us on Instagram with your tattoo idea, preferred placement, and approximate size. We'll schedule a free consultation to discuss your project in detail.</p>"
          }
        },
        "q2": {
          "type": "item",
          "settings": {
            "question": "How much does a tattoo cost?",
            "answer": "<p>Pricing depends on size, complexity, placement, and style. Small pieces start around $150. Larger custom work is quoted on an hourly basis during your consultation.</p>"
          }
        },
        "q3": {
          "type": "item",
          "settings": {
            "question": "What's your cancellation policy?",
            "answer": "<p>We require 48 hours notice for cancellations or rescheduling. Late cancellations or no-shows forfeit the deposit. We understand life happens\u2014just communicate with us.</p>"
          }
        },
        "q4": {
          "type": "item",
          "settings": {
            "question": "Do you tattoo over scars or old tattoos?",
            "answer": "<p>Yes, we do cover-ups and scar coverage. These projects require an in-person consultation so we can assess the area and discuss realistic expectations.</p>"
          }
        },
        "q5": {
          "type": "item",
          "settings": {
            "question": "Can I bring someone with me?",
            "answer": "<p>You're welcome to bring one guest for moral support. Our studio space is limited, so we ask that children and large groups stay home.</p>"
          }
        }

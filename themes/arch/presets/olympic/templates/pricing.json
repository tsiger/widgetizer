      "blocks": {
        "faq-1": {
          "type": "item",
          "settings": {
            "question": "How does the free trial work?",
            "answer": "<p>Your first session is completely free with no commitment. Just show up, train with us, and see if Olympic is the right fit. No credit card required.</p>"
          }
        },
        "faq-2": {
          "type": "item",
          "settings": {
            "question": "Can I cancel my membership anytime?",
            "answer": "<p>Monthly memberships can be cancelled with 30 days notice. No cancellation fees, no hassle. Annual memberships are billed upfront and are non-refundable after the first 30 days.</p>"
          }
        },
        "faq-3": {
          "type": "item",
          "settings": {
            "question": "Do I need to book classes in advance?",
            "answer": "<p>We recommend booking through the member app to guarantee your spot, especially for popular evening classes. Walk-ins are welcome if space is available.</p>"
          }
        },
        "faq-4": {
          "type": "item",
          "settings": {
            "question": "Is personal training included?",
            "answer": "<p>Monthly members receive one personal training session per month. Annual members get two sessions per month. Additional sessions can be purchased separately.</p>"
          }
        },
        "faq-5": {
          "type": "item",
          "settings": {
            "question": "Do you offer student or family discounts?",
            "answer": "<p>Yes. We offer a 15% student discount with valid ID and family plans for households of two or more. Contact us for details.</p>"
          }
        },
        "faq-sidebar": {
          "type": "info",
          "settings": {
            "title": "Still have questions?",
            "text": "<p>Call us at (555) 738-0200 or drop by the gym. We are happy to show you around and answer anything in person.</p>"
          }
        }

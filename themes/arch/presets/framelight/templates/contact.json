        },
        "cfaq-02": {
          "type": "item",
          "settings": {
            "question": "What are your rates?",
            "answer": "<p>Session rates begin at a half-day rate and scale with scope. Every project is quoted in a written brief — there are no listed packages because every shoot is a little different.</p>"
          }
        },
        "cfaq-03": {
          "type": "item",
          "settings": {
            "question": "What's your turnaround?",
            "answer": "<p>Three weeks for a final curated set. Rush delivery is possible on editorial assignments; say so in the inquiry.</p>"
          }
        },
        "cfaq-04": {
          "type": "item",
          "settings": {
            "question": "How do licensing and usage rights work?",
            "answer": "<p>Every commercial project ships with a written license that names the usage, territory, and term. Private-client work includes personal-use rights by default.</p>"
          }
        },

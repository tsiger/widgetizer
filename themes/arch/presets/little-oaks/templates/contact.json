        "fullwidth": true,
        "content_width": "medium",
        "alignment": "center",
        "color_scheme": "highlight-primary"
      },
      "blocks": {
        "contact-heading": {
          "type": "heading",
          "settings": {
            "text": "Visit Little Oaks",
            "size": "6xl"

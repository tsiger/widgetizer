        "show_address": true,
        "sidebar_position": "end",
        "color_scheme": "standard-primary"
      },
      "blocks": {
        "map-hours": {
          "type": "info",
          "settings": {
            "title": "Hours",
            "text": "<p>Monday\u2013Friday: 7 AM \u2013 6 PM</p><p>Saturday\u2013Sunday: Closed</p>"
          }
        },
        "map-visit": {
          "type": "info",
          "settings": {
            "title": "Visiting",
            "text": "<p>Tours are available Monday through Friday by appointment.</p><p>Free parking is available in the lot behind the building.</p>"
          }
        }
      },
      "blocksOrder": ["map-hours", "map-visit"]
    },
    "contact_faq": {
      "type": "accordion",
      "settings": {
        "eyebrow": "First Visit",
        "eyebrow_uppercase": true,
        "title": "Before You Come In",
        "heading_alignment": "start",
        "style": "separated",
        "allow_multiple": false,
        "color_scheme": "standard-secondary"
      },
      "blocks": {
        "faq-1": {
          "type": "item",
          "settings": {
            "question": "What happens during a tour?",
            "answer": "<p>We walk you through each classroom, introduce you to the teachers, and explain our curriculum and daily routine. Tours usually last about 30 minutes. Your child is welcome to come along.</p>"
          }
        },
        "faq-2": {
          "type": "item",
          "settings": {
            "question": "How far in advance should I inquire?",
            "answer": "<p>We recommend reaching out at least 2 to 3 months before your preferred start date, especially for infant spots. Some age groups fill quickly and maintain waitlists.</p>"
          }
        },
        "faq-3": {
          "type": "item",
          "settings": {
            "question": "Can I observe a class before enrolling?",
            "answer": "<p>Yes. After your initial tour, you are welcome to schedule a classroom observation during regular hours to see how a typical day unfolds.</p>"
          }
        },
        "faq-4": {
          "type": "item",
          "settings": {
            "question": "What do I need to bring on my child's first day?",
            "answer": "<p>We provide a welcome checklist after enrollment. Generally, you will need a change of clothes, a comfort item if your child uses one, and any necessary medications with written instructions.</p>"
          }
        }
      },
      "blocksOrder": ["faq-1", "faq-2", "faq-3", "faq-4"]
    },
    "contact_cta": {
      "type": "action-bar",
      "settings": {
        "color_scheme": "highlight-primary"
      },
      "blocks": {
        "cta-heading": {
          "type": "heading",
          "settings": {

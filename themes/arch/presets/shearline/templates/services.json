    "services_pricing_faq": {
      "type": "accordion",
      "settings": {
        "eyebrow": "About pricing",
        "eyebrow_uppercase": true,
        "title": "Why ranges, and what shifts the price.",
        "heading_alignment": "start",
        "style": "separated",
        "allow_multiple": false,
        "sidebar_position": "start",
        "color_scheme": "standard-primary"
      },
      "blocks": {
        "faq-sidebar": {
          "type": "info",
          "settings": {
            "title": "Not sure what to book?",
            "text": "<p>Tell us your hair length, last appointment, and what you're thinking. We'll help you pick the right service before you book.</p>"
          }
        },
        "faq-single-price": {
          "type": "item",
          "settings": {
            "question": "Why isn't there a single price for my cut?",
            "answer": "<p>Length, density, and condition all affect how long a cut takes. The range reflects that range honestly — you'll know the final number before we start.</p>"
          }
        },
        "faq-from": {
          "type": "item",
          "settings": {
            "question": "What does \"from\" mean on a price?",
            "answer": "<p>It means that's the starting price for the shortest or simplest version of the service. Longer, thicker, or more-damaged hair takes longer to work with, and we price honestly for that.</p>"
          }
        },
        "faq-color-consult": {
          "type": "item",
          "settings": {
            "question": "Why is a consultation required for color?",
            "answer": "<p>Because color done right starts with seeing your hair in person, understanding its history, and agreeing on an outcome. Same-day bookings for balayage or color correction almost always end badly.</p>"
          }
        },
        "faq-long-hair": {
          "type": "item",
          "settings": {
            "question": "Do you charge more for long hair?",
            "answer": "<p>Yes — long hair takes more time to wash, cut, and finish, and more product to treat. The range on every service accounts for length.</p>"
          }
        },
        "faq-gender-pricing": {
          "type": "item",
          "settings": {
            "question": "Same price for men's and women's cuts?",
            "answer": "<p>We price by time and technique, not gender. A short precision bob and a men's scissor cut cost roughly the same. A long layered cut costs more than either, regardless of who's in the chair.</p>"
          }
        }
      },
      "blocksOrder": ["faq-sidebar", "faq-single-price", "faq-from", "faq-color-consult", "faq-long-hair", "faq-gender-pricing"]
    },

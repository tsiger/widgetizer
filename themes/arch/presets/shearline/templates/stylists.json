      "blocks": {
        "stylist-rowan": {
          "type": "profile",
          "settings": {
            "name": "Rowan Ellis",
            "role": "Lead Stylist & Founder",
            "specialty": "Precision bobs, fringe, short cuts",
            "bio": "Twelve years at the chair. Trained at a Vidal Sassoon academy in London, then spent four years in a studio on the Lower East Side before opening Shearline in 2019. Rowan built the salon around one idea: a cut that still looks good three weeks later. If you're growing out layers, cutting a blunt bob, or trying to land on a fringe that works with your cowlick, this is the chair.",
            "instagram": "https://instagram.com/",
            "email": "hello@example.com"
          }
        },
        "stylist-sloane": {
          "type": "profile",
          "settings": {
            "name": "Sloane Park",
            "role": "Senior Colorist",
            "specialty": "Balayage, blonding, color correction",
            "bio": "Nine years specializing in color, certified in Redken and Goldwell. Sloane is the person to book for balayage that grows out beautifully — no hard lines, no brassy shift at week six. She also handles the rescues when someone else got it wrong, and she will tell you honestly whether a color transformation is one appointment or three. All color services require a consultation first.",
            "instagram": "https://instagram.com/",
            "email": "hello@example.com"
          }
        },
        "stylist-mara": {
          "type": "profile",
          "settings": {
            "name": "Mara Okafor",
            "role": "Stylist",
            "specialty": "Textured & curly hair, long layers",
            "bio": "Seven years focused on curly and coily hair, from defined 3A waves to 4C coils. Mara trained with a curl specialist in Atlanta and carries that approach here — dry cutting, curl-by-curl shape work, and finishes that respect the texture instead of fighting it. If another stylist has ever told you your hair is hard to cut, this is the chair to book.",
            "instagram": "https://instagram.com/",
            "email": "hello@example.com"
          }
        },
        "stylist-theo": {
          "type": "profile",
          "settings": {
            "name": "Theo Vance",
            "role": "Stylist",
            "specialty": "Men's cuts, fades, beard work",
            "bio": "Eight years in men's grooming. Theo works the whole range — a quiet executive side part, a sharp skin fade, a textured crop, and the beards that come with them. He's especially good if you're growing your hair out from a shorter cut and want the in-between months to actually look intentional. Walk-ins welcome for beard trims when the chair is free.",
            "instagram": "https://instagram.com/",
            "email": "hello@example.com"
          }
        }
      },
      "blocksOrder": ["stylist-rowan", "stylist-sloane", "stylist-mara", "stylist-theo"]
    },

        "tab-short-cuts": {
          "type": "tab",
          "settings": {
            "title": "Short cuts",
            "description": "<p>Precision bobs, pixies, and undercuts. The shortest shapes are the least forgiving — which is exactly why they need the most considered cut. We dry-check every line before you leave.</p>"

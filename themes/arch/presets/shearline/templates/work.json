        },
        "tab-long-lengths": {
          "type": "tab",
          "settings": {
            "title": "Long & Lengths",
            "description": "<p>Layered long cuts, lived-in shapes, movement without weight loss. We cut with the hair's natural fall in mind so the shape still reads on day twenty-one.</p>"
          }
        },
        "tab-color-balayage": {
          "type": "tab",
          "settings": {
            "title": "Color & Balayage",
            "description": "<p>Hand-painted balayage, foil work, dimensional blonding, and the gentler single-process services. Consultation first, always — color done well is a conversation.</p>"
          }
        },
        "tab-mens": {
          "type": "tab",
          "settings": {
            "title": "Men's",
            "description": "<p>Classic cuts, skin fades, textured crops, and beard shaping. Same attention to shape and finish as every other service in the salon.</p>"
          }
        },
        "tab-editorial-events": {
          "type": "tab",
          "settings": {
            "title": "Editorial & Events",
            "description": "<p>Bridal, event styling, and photoshoot work. Hair that holds up through a long day and still looks considered in photographs.</p>"

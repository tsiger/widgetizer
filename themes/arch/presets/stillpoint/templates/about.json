        "founder-heading": {
          "type": "heading",
          "settings": {
            "text": "Meet Ava Lindqvist",
            "size": "4xl"
          }
        },
        "founder-text": {
          "type": "text",
          "settings": {
            "text": "<p>Ava discovered yoga at 22, burned out from a career in finance. What started as stress relief became a calling — she sold her apartment, spent a year training in Mysore, and came home with a 500-hour certification and a clear vision.</p><p>She opened Stillpoint in 2018 with a single room and six students. Today the studio has two practice rooms, a team of eight instructors, and a community that feels more like family than a mailing list.</p>",
            "size": "base",
            "uppercase": false,
            "muted": false
          }
        }
      },
      "blocksOrder": ["founder-eyebrow", "founder-heading", "founder-text"]
    },
    "philosophy": {
      "type": "numbered-cards",
      "settings": {
        "eyebrow": "Our Values",
        "title": "What Guides Us",
        "columns_desktop": 3,
        "card_layout": "flat",
        "color_scheme": "standard-accent"
      },
      "blocks": {
        "value-1": {
          "type": "step",
          "settings": {
            "title": "Accessibility First",
            "description": "<p>Every class offers modifications. Every body is welcome. We never use language that makes anyone feel like they don't belong on the mat.</p>"
          }
        },
        "value-2": {
          "type": "step",
          "settings": {
            "title": "Depth Over Trends",
            "description": "<p>We teach from lineage and study, not Instagram. Our instructors are trained in anatomy, philosophy, and trauma-informed practices.</p>"
          }
        },
        "value-3": {
          "type": "step",
          "settings": {
            "title": "Community Over Competition",
            "description": "<p>There are no levels here — only practice. We celebrate showing up, not showing off. The studio is a space free from comparison.</p>"
          }
        }
      },
      "blocksOrder": ["value-1", "value-2", "value-3"]
    },

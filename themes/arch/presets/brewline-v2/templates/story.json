      "blocks": {
        "step-source": {
          "type": "step",
          "settings": {
            "image": "story-step-source.jpg",
            "title": "Source with range in mind",
            "description": "<p>We look for coffees that can carry the espresso bar, stand up in milk, and still offer enough nuance for slower brewing methods.</p>"
          }
        },
        "step-roast": {
          "type": "step",
          "settings": {
            "image": "story-step-roast.jpg",
            "title": "Roast in short, fresh runs",
            "description": "<p>Small batches keep the shelf current and let us adjust quickly when a coffee wants a lighter or deeper hand.</p>"

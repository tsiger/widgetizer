            "style": "primary",
            "size": "medium"
          }
        }
      },
      "blocksOrder": [
        "story-eyebrow",
        "story-heading",
        "story-text",
        "story-button"
      ]
    },
    "roast_note": {
      "type": "image-text",
      "settings": {
        "image": "story-roaster.jpg",
        "image_position": "end",
        "text_position": "center",
        "color_scheme": "standard-secondary",
        "content_color_scheme": "standard-primary"
      },
      "blocks": {
        "roast-eyebrow": {
          "type": "text",
          "settings": {
            "text": "<p>Roast Philosophy</p>",
            "size": "sm",
            "uppercase": true,
            "muted": true
          }
        },
        "roast-heading": {
          "type": "heading",
          "settings": {
            "text": "We chase clarity before complexity.",
            "size": "3xl"
          }
        },
        "roast-text": {
          "type": "text",
          "settings": {
            "text": "<p>That means coffees that taste distinct without turning every cup into a tasting exam. We buy for balance, roast for everyday drinkability, and keep enough range on hand to make the bar feel alive.</p>",
            "size": "base"
          }
        },
        "roast-features": {
          "type": "features",
          "settings": {
            "features": "+ Short rotating roast list\n+ Brewing choices that stay approachable\n+ Seasonal coffees without menu chaos"
          }
        }
      },
      "blocksOrder": [
        "roast-eyebrow",
        "roast-heading",
        "roast-text",
        "roast-features"
      ]
    },
    "craft_steps": {
      "type": "steps",
      "settings": {
        "eyebrow": "From Roast Day to Your Cup",
        "title": "A small process, repeated carefully.",
        "description": "Enough detail to explain the work, not enough to turn coffee into homework.",
        "heading_alignment": "center",

        },
        "story-text": {
          "type": "text",
          "settings": {
            "text": "<p>Brewline was built around a simple idea: a neighborhood coffee bar should feel daily and dependable, but the coffee itself should still show care. We roast in small runs, keep the menu tight, and let the room do as much talking as the copy.</p>",
            "size": "lg"
          }
        },
        "story-button": {
          "type": "button",
          "settings": {
            "link": {
              "href": "visit.html",
              "text": "Visit the Cafe",
              "target": "_self"

    "gallery_styles": {
      "type": "image-tabs",
      "settings": {
        "eyebrow": "Browse by cut",
        "eyebrow_uppercase": true,
        "title": "Five ways we cut a dog.",
        "description": "Different breeds, different goals — pick a tab to see how we think about each.",
        "heading_alignment": "center",
        "image_position": "start",
        "aspect_ratio": "3 / 2",
        "color_scheme": "standard-primary"
      },
      "blocks": {
        "tab-doodle": {
          "type": "tab",
          "settings": {
            "title": "Doodle teddy",
            "description": "<p>Even body length, neat round face, clean feet. Mara's most-grooming-table cut. The trick is keeping the face soft without leaving fur in the eyes, and matching legs to body without column-trimming them.</p>"
          }
        },
        "tab-schnauzer": {
          "type": "tab",
          "settings": {
            "title": "Hand-strip",
            "description": "<p>Pulling the dead outer coat by hand instead of clipping. Restores the harsh, weather-resistant texture and rich color the breed is supposed to have. Slower work — usually 2–3 hours — but the coat stays right between visits.</p>"
          }
        },
        "tab-double-coat": {
          "type": "tab",
          "settings": {
            "title": "Double-coat de-shed",
            "description": "<p>Huskies, malamutes, shepherds, retrievers — never shaved. Bath, blow out the dead undercoat with a high-velocity dryer, finish with an undercoat rake. Most double coats need this every 8–12 weeks.</p>"
          }
        },
        "tab-sanitary": {
          "type": "tab",
          "settings": {
            "title": "Sanitary trim",
            "description": "<p>Hygiene-only — undercarriage, paw pads, around the eyes. No body cut, no full bath. Great for puppies between full grooms, senior dogs who don't tolerate long appointments, and dogs whose owners are keeping the coat long.</p>"
          }
        },
        "tab-demat": {
          "type": "tab",
          "settings": {
            "title": "De-mat & shave-down",
            "description": "<p>When a coat has matted past safe brushing, the kind decision is often a fresh start. We assess, walk you through options, and — if a shave-down is right — go short enough to stop the discomfort but not so short the dog is uncomfortable in the cold.</p>"
          }
        }
      },
      "blocksOrder": ["tab-doodle", "tab-schnauzer", "tab-double-coat", "tab-sanitary", "tab-demat"]
    },

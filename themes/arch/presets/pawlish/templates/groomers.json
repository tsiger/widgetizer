          }
        },
        "groomer-dani": {
          "type": "profile",
          "settings": {
            "name": "Dani Iyer",
            "role": "Senior groomer",
            "specialty": "Double coats · de-shed · large breeds",
            "bio": "Nine years grooming, four with Pawlish. Handles huskies, malamutes, shepherds, and large retrievers — the double coats nobody else wants. IPG certified. Strong, calm, patient with the big dogs.",
            "instagram": "danigroomsdogs"
          }
        },
        "groomer-rae": {
          "type": "profile",
          "settings": {
            "name": "Rae Kowalski",
            "role": "Groomer",
            "specialty": "Small breeds · puppies · sanitary trims",
            "bio": "Vet tech background, three years grooming. The right person for puppies, small breeds, and any dog whose first grooming experience needs to land well. Working toward NDGAA Master Groomer.",
            "instagram": ""
          }
        },
        "groomer-jules": {
          "type": "profile",
          "settings": {
            "name": "Jules Okafor",
            "role": "Groomer & bath tech",
            "specialty": "Bath services · walk-in nails · seniors",
            "bio": "Five years at Pawlish, runs the bath station and walk-in nail service. Pet First Aid & CPR certified. The gentle hand most senior dogs settle into immediately.",

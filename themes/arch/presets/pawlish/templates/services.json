    "services_faq": {
      "type": "accordion",
      "settings": {
        "eyebrow": "About pricing",
        "eyebrow_uppercase": true,
        "title": "Common pricing questions.",
        "heading_alignment": "start",
        "style": "separated",
        "allow_multiple": false,
        "sidebar_position": "start",
        "color_scheme": "standard-secondary"
      },
      "blocks": {
        "faq-info": {
          "type": "info",
          "settings": {
            "title": "Not sure what to book?",
            "text": "<p>Call us with your dog's breed and last groom date — we'll tell you which service fits.</p><p>(555) 020-0184</p>"
          }
        },
        "faq-over-listed": {
          "type": "item",
          "settings": {
            "question": "Why does my dog cost more than the listed price?",
            "answer": "<p>Listed prices assume a clean, well-maintained coat in that size bracket. If we hit heavy matting, an unusually thick coat, or a much longer cut than typical, we add a small condition fee. We always tell you before we start, never at pickup.</p>"
          }
        },
        "faq-condition-fee": {
          "type": "item",
          "settings": {
            "question": "What's a coat condition fee?",
            "answer": "<p>An honest add-on for coats that take longer to work — usually heavy mats, double-coat de-shed beyond the standard treatment, or a coat that's grown out four-plus months. We quote it during intake.</p>"
          }
        },
        "faq-walk-in": {
          "type": "item",
          "settings": {
            "question": "Do you charge for nail walk-ins?",
            "answer": "<p>Yes — flat $18 small / $20 medium / $25 large. Walk in during open hours, no appointment needed. Five to ten minutes most of the time.</p>"
          }
        },
        "faq-split": {
          "type": "item",
          "settings": {
            "question": "Can I split the cost across services?",
            "answer": "<p>You can book a bath & tidy between full grooms to spread the cost. Many regulars do six-week bath & tidy plus twelve-week full groom — keeps a coat right for less per visit.</p>"
          }
        },
        "faq-shave": {
          "type": "item",
          "settings": {
            "question": "What if my dog needs a shave-down instead of a cut?",
            "answer": "<p>If the coat is matted past safe brushing, we'll recommend a shave-down — it's faster, cheaper, kinder. We'll talk through what to expect and help you plan how to grow it back.</p>"
          }
        }
      },
      "blocksOrder": ["faq-info", "faq-over-listed", "faq-condition-fee", "faq-walk-in", "faq-split", "faq-shave"]
    },

      "blocks": {
        "p-1": {
          "type": "profile",
          "settings": {
            "name": "Clara Marche",
            "role": "Founder & Lead Planner",
            "specialty": "Full-service",
            "bio": "Clara founded Everafter in 2016 and leads the studio's full-service engagements. Trained in hospitality, trained further by nine years of weddings, she is the planner most couples meet on their discovery call."
          }
        },
        "p-2": {
          "type": "profile",
          "settings": {
            "name": "Sena Okafor",
            "role": "Senior Planner",
            "specialty": "Partial & destination",
            "bio": "Sena leads partial-planning engagements and runs the studio's destination practice. Based between Hudson and Lisbon, she speaks four languages and has coordinated weddings on three continents."
          }
        },
        "p-3": {
          "type": "profile",
          "settings": {
            "name": "Theo Arden",
            "role": "Design & Floral Lead",
            "specialty": "Design direction",
            "bio": "Theo leads creative direction for every engagement — moodboards, moodshifts, florals, tablescapes, installation. Trained at a London flower school; grew up in a family of set designers."
          }
        },
        "p-4": {
          "type": "profile",
          "settings": {
            "name": "Maren Vallee",
            "role": "Logistics & Day-of Lead",
            "specialty": "Day-of coordination",
            "bio": "Maren runs the day-of team and every day-of-coordination engagement. The person vendors call first. The person timelines answer to. The calm you feel when everything is handled."
          }
        }
      },

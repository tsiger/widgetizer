    "history": {
      "type": "timeline",
      "settings": {
        "eyebrow": "History",
        "eyebrow_uppercase": true,
        "title": "How the studio grew.",
        "description": "",
        "heading_alignment": "start",
        "layout": "vertical",
        "color_scheme": "standard-primary",
        "top_spacing": "auto",
        "bottom_spacing": "auto"
      },
      "blocks": {
        "h-1": {
          "type": "item",
          "settings": {
            "date": "2016",
            "title": "Studio founded",
            "description": "<p>Clara Marche plans a friend's wedding in Rhinebeck and finds she doesn't want to stop. Everafter opens its first small office above a bookstore in Hudson.</p>"
          }
        },
        "h-2": {
          "type": "item",
          "settings": {
            "date": "2018",
            "title": "First editorial feature",
            "description": "<p>Magnolia Rouge publishes a feature of a Catskill farm wedding. Inquiries quadruple. The studio turns down more weddings than it accepts for the first time.</p>"
          }
        },
        "h-3": {
          "type": "item",
          "settings": {
            "date": "2020",
            "title": "The team grows",
            "description": "<p>Sena Okafor joins as Senior Planner. The studio restructures around named leads: every wedding has one partner or senior planner running it, with dedicated associate support.</p>"
          }
        },
        "h-4": {
          "type": "item",
          "settings": {
            "date": "2022",
            "title": "First destination wedding",
            "description": "<p>A multi-day wedding in Tuscany opens the studio's destination practice. Since then, Everafter has planned in six countries across three continents.</p>"
          }
        },
        "h-5": {
          "type": "item",
          "settings": {
            "date": "2024",
            "title": "Design-only tier launched",
            "description": "<p>After years of couples asking for design direction without planning logistics, the studio launches a creative-direction engagement for couples who've hired their own planner.</p>"
          }
        }
      },
      "blocksOrder": ["h-1", "h-2", "h-3", "h-4", "h-5"]
    },

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="format-detection" content="telephone=no">

    {% seo %}
    {% fonts %}
    
    {% render 'site-icons', site_icons: site_icons %}

    {% theme_settings %}

    {% asset src: "base.css" %}
    {% unless theme.general.enable_reveal_animations %}
      <style>.reveal { opacity: 1 !important; transform: none !important; }</style>
    {% endunless %}
    {% custom_css %}
    {% custom_head_scripts %}
    {% assign shopify_domain = theme.shopify.store_domain | default: '' | remove: 'https://' | remove: 'http://' | strip %}
    {% if shopify_domain != blank %}
      <script type="module" src="https://cdn.shopify.com/storefront/web-components.js"></script>
      {% asset src: "commerce.css" %}
    {% endif %}
    {% header_assets %}
  </head>
  <body class="{{ body_class }} corner-{{ theme.style.corner_style | default: 'sharp' }} spacing-{{ theme.style.spacing_density | default: 'default' }} buttons-{{ theme.style.button_shape | default: 'auto' }}">
    <a href="#main-content" class="visually-hidden skip-link">Skip to main content</a>
    {% if shopify_domain != blank %}<shopify-store store-domain="https://{{ shopify_domain }}" country="{{ theme.shopify.country | default: 'US' }}" language="{{ theme.shopify.language | default: 'en' }}"{% if theme.shopify.storefront_access_token != blank %} public-access-token="{{ theme.shopify.storefront_access_token }}"{% endif %}>{% endif %}
    {{ header | raw }}
    <main id="main-content" class="main-content">
      {{ main_content | raw }}
    </main>
    {{ footer | raw }}
    {% if shopify_domain != blank %}
      <shopify-cart id="widgetizer-cart"></shopify-cart>
      {% render 'product-modal' %}
      </shopify-store>
      {% asset src: "shopify-cart.js", defer: true %}
    {% endif %}

    {% asset src: "scripts.js", defer: true %}
    {% if theme.general.enable_reveal_animations %}
      {% asset src: "reveal.js", defer: true %}
    {% endif %}
    {% footer_assets %}
    {% custom_footer_scripts %}
  </body>
</html>


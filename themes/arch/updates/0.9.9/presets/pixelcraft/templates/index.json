    "pace_split": {
      "type": "split-content",
      "settings": {
        "balance": "equal",
        "sticky_column": "left",
        "color_scheme": "standard-primary",
        "top_spacing": "auto",
        "bottom_spacing": "auto"
      },
      "blocks": {
        "pace-heading": {
          "type": "heading",
          "settings": {
            "text": "We work slowly, on purpose.",
            "size": "7xl",
            "position": "left"
          }
        },
        "pace-body-1": {
          "type": "text",
          "settings": {
            "text": "<p>Good identity work doesn't come out of a five-day sprint. We spend the first week looking and the second week listening. By week three we're making, and by the time we show you anything we've already thrown most of it out.</p>",
            "size": "base",
            "uppercase": false,
            "muted": false,
            "position": "right"
          }
        },
        "pace-body-2": {
          "type": "text",
          "settings": {
            "text": "<p>What that means in practice: fewer clients per year, longer projects, and a final mark you can actually use for a decade.</p>",
            "size": "base",
            "uppercase": false,
            "muted": true,
            "position": "right"
          }
        }
      },
      "blocksOrder": [
        "pace-heading",
        "pace-body-2",
        "pace-body-1"
      ]
    },
    "reviews": {
      "type": "testimonials",
      "settings": {
        "eyebrow": "Notes from clients",
        "eyebrow_uppercase": true,
        "title": "What people say.",
        "heading_alignment": "start",
        "layout": "grid",
        "columns_desktop": 2,
        "card_layout": "flat",
        "color_scheme": "standard-primary",
        "top_spacing": "auto",
        "bottom_spacing": "auto"
      },
      "blocks": {
        "r-1": {
          "type": "quote",
          "settings": {
            "quote": "Pixelcraft spent a full week just looking at our shop before they drew a single thing. By the time we saw sketches, they already understood the brand better than I did. The identity they made is the one we'd hoped we could articulate ourselves.",
            "name": "Nina Vance",
            "title": "Co-founder · Vance & Oak",
            "rating": "5",
            "avatar": "/uploads/images/testimonial-nina.webp"
          }
        },
        "r-2": {
          "type": "quote",
          "settings": {
            "quote": "We went through three agencies before landing here. Pixelcraft is the only studio that pushed back on our brief — and the final magazine redesign is the one that's actually winning us subscribers, not just awards.",
            "name": "Marcus Kay",
            "title": "Editor-in-Chief · Orion Quarterly",
            "rating": "5",
            "avatar": "/uploads/images/testimonial-marcus.webp"
          }
        },
        "r-3": {
          "type": "quote",
          "settings": {
            "quote": "Small studio, big taste. They take the time to do the work right and they tell you honestly when you're asking for the wrong thing. That's rarer than it should be.",
            "name": "Isla Okafor",
            "title": "Founder · Hearth Coffee",
            "rating": "5",
            "avatar": "/uploads/images/testimonial-isla.webp"
          }
        },
        "r-4": {
          "type": "quote",
          "settings": {
            "quote": "The type family they drew for us is going to carry our imprint for the next decade. I've commissioned type from four studios before and none felt this considered.",
            "name": "Theo Reyes",
            "title": "Publisher · Cordage Press",
            "rating": "5",
            "avatar": "/uploads/images/testimonial-theo.webp"
          }
        }
      },
      "blocksOrder": [
        "r-4",
        "r-2",
        "r-3",
        "r-1"
      ]
    },

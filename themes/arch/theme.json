            "stack": "\"Fraunces\", serif",
            "weight": 600
          }
        },
        {
          "type": "font_picker",
          "id": "body_font",
          "label": "tTheme:global.typography.settings.body_font.label",
          "default": {
            "stack": "\"Inter\", sans-serif",
            "weight": 400
          }
        },
        {
          "type": "range",
          "id": "heading_scale",
          "label": "tTheme:global.typography.settings.heading_scale.label",
          "description": "tTheme:global.typography.settings.heading_scale.description",
          "default": 100,
          "min": 80,
          "max": 120,
          "step": 5,
          "outputAsCssVar": true
        },
        {
          "type": "range",
          "id": "body_scale",
          "label": "tTheme:global.typography.settings.body_scale.label",

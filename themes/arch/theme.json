{
  "name": "Arch",
  "version": "0.9.6",
  "description": "The default Widgetizer theme",
  "author": "Widgetizer",
  "settings": {
    "global": {
      "general": [
        {
          "type": "header",
          "id": "branding_header",
          "label": "tTheme:global.general.settings.branding_header.label"

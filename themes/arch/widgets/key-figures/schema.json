{
  "type": "key-figures",
  "displayName": "tTheme:key_figures.name",
  "aliases": [
    "stats",
    "metrics",
    "data points",
    "numbers"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:key_figures.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:key_figures.settings.title.label",
      "default": "By The Numbers"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:key_figures.settings.description.label"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:key_figures.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "tTheme:key_figures.settings.layout.label",
      "default": "cards",
      "options": [
        {
          "value": "cards",
          "label": "tTheme:key_figures.settings.layout.options.cards"
        },
        {
          "value": "carousel",
          "label": "tTheme:key_figures.settings.layout.options.carousel"
        },
        {
          "value": "bar",
          "label": "tTheme:key_figures.settings.layout.options.bar"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "tTheme:key_figures.settings.columns_desktop.label",
      "default": 4,
      "min": 2,
      "max": 5,
      "step": 1
    },
    {
      "type": "checkbox",
      "id": "animate",
      "label": "tTheme:key_figures.settings.animate.label",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:key_figures.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:key_figures.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:key_figures.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "figure",
      "displayName": "tTheme:key_figures.blocks.figure.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:key_figures.blocks.figure.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "number",
          "label": "tTheme:key_figures.blocks.figure.settings.number.label",
          "default": "500"
        },
        {
          "type": "text",
          "id": "suffix",
          "label": "tTheme:key_figures.blocks.figure.settings.suffix.label",
          "default": "+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "tTheme:key_figures.blocks.figure.settings.label.label",
          "default": "Projects"
        },
        {
          "type": "text",
          "id": "description",
          "label": "tTheme:key_figures.blocks.figure.settings.description.label"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "figure",
      "settings": {
        "number": "500",
        "suffix": "+",
        "label": "Happy Clients",
        "description": "And growing every day"
      }
    },
    {
      "type": "figure",
      "settings": {
        "number": "98",
        "suffix": "%",
        "label": "Success Rate",
        "description": "Project completion"
      }
    },
    {
      "type": "figure",
      "settings": {
        "number": "24",
        "suffix": "/7",
        "label": "Support",
        "description": "Always here to help"
      }
    },
    {
      "type": "figure",
      "settings": {
        "number": "10",
        "suffix": "+",
        "label": "Years",
        "description": "Industry experience"
      }
    }
  ]
}

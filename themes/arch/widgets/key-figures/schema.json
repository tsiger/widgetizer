{
  "type": "key-figures",
  "displayName": "tTheme:key_figures.name",
  "aliases": [
    "stats",
    "metrics",
    "data points",
    "numbers"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "By The Numbers"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "tTheme:global.widgets.settings.options.left"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "tTheme:key_figures.settings.layout.label",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "tTheme:key_figures.settings.layout.options.grid"
        },
        {
          "value": "carousel",
          "label": "tTheme:key_figures.settings.layout.options.carousel"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "tTheme:global.widgets.settings.columns_desktop.label",
      "default": 4,
      "min": 2,
      "max": 5,
      "step": 1
    },
    {
      "type": "header",
      "id": "cards_header",
      "label": "Cards"
    },
    {
      "type": "select",
      "id": "card_layout",
      "label": "tTheme:global.widgets.settings.card_layout.label",
      "default": "box",
      "options": [
        {
          "value": "box",
          "label": "tTheme:global.widgets.settings.card_layout.options.box"
        },
        {
          "value": "flat",
          "label": "tTheme:global.widgets.settings.card_layout.options.flat"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "animate",
      "label": "tTheme:key_figures.settings.animate.label",
      "default": true
    },
    {
      "type": "header",
      "id": "widget_header",
      "label": "Widget"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard"
        },
        {
          "value": "standard-accent",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_accent"
        },
        {
          "value": "highlight",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight"
        },
        {
          "value": "highlight-accent",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_accent"
        }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.top_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.top_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.top_spacing.options.none"
        }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.none"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "figure",
      "displayName": "tTheme:key_figures.blocks.figure.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "number",
          "label": "tTheme:key_figures.blocks.figure.settings.number.label",
          "default": "500"
        },
        {
          "type": "text",
          "id": "suffix",
          "label": "tTheme:key_figures.blocks.figure.settings.suffix.label",
          "default": "+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "tTheme:key_figures.blocks.figure.settings.label.label",
          "default": "Projects"
        },
        {
          "type": "text",
          "id": "description",
          "label": "tTheme:key_figures.blocks.figure.settings.description.label"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "figure",
      "settings": {
        "number": "500",
        "suffix": "+",
        "label": "Happy Clients",
        "description": "And growing every day"
      }
    },
    {
      "type": "figure",
      "settings": {
        "number": "98",
        "suffix": "%",
        "label": "Success Rate",
        "description": "Project completion"
      }
    },
    {
      "type": "figure",
      "settings": {
        "number": "24",
        "suffix": "/7",
        "label": "Support",
        "description": "Always here to help"
      }
    },
    {
      "type": "figure",
      "settings": {
        "number": "10",
        "suffix": "+",
        "label": "Years",
        "description": "Industry experience"
      }
    }
  ]
}

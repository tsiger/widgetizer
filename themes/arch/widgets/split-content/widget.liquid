<section
  id="{{ widget.id }}"
  class="widget widget-split-content widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}{% if widget.settings.top_spacing == 'none' %} spacing-top-none{% endif %}{% if widget.settings.bottom_spacing == 'none' %} spacing-bottom-none{% endif %}"
  {% unless widget.settings.color_scheme == 'standard' %}
    style="--widget-bg-color: var(--bg-primary);"
  {% endunless %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="split-content"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      & .split-content-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-2xl);
      }

      & .split-content-column {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);

        & > * {
          margin-block: 0;
        }
      }

      @media (min-width: 750px) {
        & .split-content-grid {
          {% if widget.settings.balance == 'left-heavy' %}
          grid-template-columns: 7fr 3fr;
          {% elsif widget.settings.balance == 'right-heavy' %}
          grid-template-columns: 3fr 7fr;
          {% else %}
          grid-template-columns: 1fr 1fr;
          {% endif %}
          gap: var(--space-3xl);
          align-items: start;
        }
      }

      @media (min-width: 990px) {
        & .split-content-grid {
          gap: var(--space-4xl);
        }

        {% if widget.settings.sticky_column == 'left' %}
        & .split-content-column:first-child {
          position: sticky;
          top: calc(var(--header-sticky-offset, 0px) + var(--space-xl));
          align-self: start;
        }
        {% elsif widget.settings.sticky_column == 'right' %}
        & .split-content-column:last-child {
          position: sticky;
          top: calc(var(--header-sticky-offset, 0px) + var(--space-xl));
          align-self: start;
        }
        {% endif %}
      }

      & .widget-actions-start {
        justify-content: flex-start;
      }
    }
  </style>

  <div class="widget-container {% unless widget.settings.color_scheme == 'standard' %}widget-container-padded{% endunless %}">
    <div class="split-content-grid">
      {% assign sides = "left,right" | split: "," %}
      {% for side in sides %}
        <div class="split-content-column">
          {% assign delay = 0 %}
          {% assign numbered_counter = 0 %}
          {% for blockId in widget.blocksOrder %}
            {% assign block = widget.blocks[blockId] %}
            {% assign pos = block.settings.position | default: 'left' %}
            {% if pos != side %}{% continue %}{% endif %}

            {% case block.type %}
              {% when 'rating' %}
                {% assign rating = block.settings.rating | plus: 0 %}
                <div class="widget-rating reveal reveal-up" style="--reveal-delay: {{ delay }}" data-block-id="{{ blockId }}">
                  <span class="stars" aria-hidden="true">
                    {% for i in (1..5) %}
                      {% if i <= rating %}
                        <span class="widget-rating-star">★</span>
                      {% else %}
                        <span class="widget-rating-star empty">★</span>
                      {% endif %}
                    {% endfor %}
                  </span>
                  <span class="visually-hidden">
                    Rated {{ rating }} out of 5
                  </span>
                </div>

              {% when 'image' %}
                <div class="widget-block-image reveal reveal-up" style="--reveal-delay: {{ delay }}; --block-image-width: {{ block.settings.width }}%;" data-block-id="{{ blockId }}">
                  {% if block.settings.image != blank %}
                    {% assign block_image_width_factor = 7.1 %}
                    {% if widget.settings.balance == 'left-heavy' %}
                      {% if pos == 'left' %}
                        {% assign block_image_width_factor = 9.94 %}
                      {% else %}
                        {% assign block_image_width_factor = 4.26 %}
                      {% endif %}
                    {% elsif widget.settings.balance == 'right-heavy' %}
                      {% if pos == 'right' %}
                        {% assign block_image_width_factor = 9.94 %}
                      {% else %}
                        {% assign block_image_width_factor = 4.26 %}
                      {% endif %}
                    {% endif %}
                    {% assign block_image_cap = block.settings.width | times: block_image_width_factor %}
                    {% capture block_image_sizes %}(max-width: 749px) {{ block.settings.width }}vw, {{ block_image_cap }}px{% endcapture %}
                    {% image src: block.settings.image, size: 'small', srcset: true, sizes: block_image_sizes %}
                  {% else %}
                    {% placeholder_image aspect: 'square' %}
                  {% endif %}
                </div>

              {% when 'icon' %}
                <div class="reveal reveal-up" style="--reveal-delay: {{ delay }}" data-block-id="{{ blockId }}">
                  {% if block.settings.icon != blank %}
                    {% render 'icon', icon: block.settings.icon, class: 'w-icon', style: block.settings.style, size: block.settings.size, shape: block.settings.shape %}
                  {% endif %}
                </div>

              {% when 'heading' %}
                {% assign size_class = 't-' | append: block.settings.size %}
                {% if widget.index == 1 %}
                  <h1 class="w-headline {{ size_class }} reveal reveal-up" style="--reveal-delay: {{ delay }}" data-block-id="{{ blockId }}" data-setting="text">
                    {{ block.settings.text }}
                  </h1>
                {% else %}
                  <h2 class="w-headline {{ size_class }} reveal reveal-up" style="--reveal-delay: {{ delay }}" data-block-id="{{ blockId }}" data-setting="text">
                    {{ block.settings.text }}
                  </h2>
                {% endif %}

              {% when 'text' %}
                {% assign size_class = 't-' | append: block.settings.size %}
                {% assign style_class = '' %}
                {% if block.settings.uppercase %}{% assign style_class = style_class | append: ' t-uppercase' %}{% endif %}
                {% if block.settings.muted %}{% assign style_class = style_class | append: ' t-muted' %}{% endif %}
                <div class="w-body w-rte {{ size_class }}{{ style_class }} reveal reveal-up" style="--reveal-delay: {{ delay }}" data-block-id="{{ blockId }}" data-setting="text">
                  {{ block.settings.text | raw }}
                </div>

              {% when 'features' %}
                {% if block.settings.features != blank %}
                  <ul class="features-list reveal reveal-up" style="--reveal-delay: {{ delay }}" data-block-id="{{ blockId }}">
                    {% assign normalized_features = block.settings.features | replace: '\r\n', '\n' %}
                    {% assign features_list = normalized_features | split: '\n' %}
                    {% for feature in features_list %}
                      {% assign trimmed_feature = feature | strip %}
                      {% if trimmed_feature != blank %}
                        {% assign feature_text = trimmed_feature %}
                        {% assign icon_name = '' %}
                        {% assign first_char = trimmed_feature | slice: 0, 1 %}
                        {% if first_char == '+' %}
                          {% assign icon_name = 'check' %}
                          {% assign feature_text = trimmed_feature | remove_first: '+' | strip %}
                        {% elsif first_char == '-' %}
                          {% assign icon_name = 'x' %}
                          {% assign feature_text = trimmed_feature | remove_first: '-' | strip %}
                        {% endif %}
                        <li class="feature-item w-body">
                          {% if icon_name != blank %}
                            <span class="feature-icon">
                              {% render 'icon', icon: icon_name, class: 'feature-icon-svg' %}
                            </span>
                          {% endif %}
                          <span>{{ feature_text }}</span>
                        </li>
                      {% endif %}
                    {% endfor %}
                  </ul>
                {% endif %}

              {% when 'numbered-item' %}
                {% assign numbered_counter = numbered_counter | plus: 1 %}
                <div class="numbered-item reveal reveal-up" style="--reveal-delay: {{ delay }}" data-block-id="{{ blockId }}">
                  <span class="numbered-item-circle numbered-item-circle-{{ block.settings.size }} numbered-item-shape-{{ block.settings.shape }}" aria-hidden="true">{{ numbered_counter }}</span>
                  <div class="numbered-item-content">
                    {% if block.settings.title != blank %}
                      <span class="w-title t-lg t-heading-font" data-setting="title">{{ block.settings.title }}</span>
                    {% endif %}
                    {% if block.settings.description != blank %}
                      <span class="w-body t-sm t-muted" data-setting="description">{{ block.settings.description }}</span>
                    {% endif %}
                  </div>
                </div>

              {% when 'button' %}
                {% if block.settings.link.text != blank or block.settings.link_2.text != blank %}
                  <div class="widget-actions reveal reveal-up{% if block.settings.alignment == 'start' %} widget-actions-start{% endif %}" style="--reveal-delay: {{ delay }}" data-block-id="{{ blockId }}">
                    {% if block.settings.link.text != blank %}
                      {% if block.settings.size != 'small' and block.settings.size != blank %}
                        {% assign btn_size_class = 'widget-button-' | append: block.settings.size %}
                      {% else %}
                        {% assign btn_size_class = '' %}
                      {% endif %}
                      <a
                        href="{{ block.settings.link.href }}"
                        class="widget-button {{ btn_size_class }} {% if block.settings.style == 'primary' %}widget-button-primary{% else %}widget-button-secondary{% endif %}"
                        data-setting="link"
                        {% if block.settings.link.target == '_blank' %}
                          target="_blank" rel="noopener"
                        {% endif %}
                      >
                        {{ block.settings.link.text }}
                      </a>
                    {% endif %}
                    {% if block.settings.link_2.text != blank %}
                      {% if block.settings.size != 'small' and block.settings.size != blank %}
                        {% assign btn_size_class = 'widget-button-' | append: block.settings.size %}
                      {% else %}
                        {% assign btn_size_class = '' %}
                      {% endif %}
                      <a
                        href="{{ block.settings.link_2.href }}"
                        class="widget-button {{ btn_size_class }} {% if block.settings.style_2 == 'primary' %}widget-button-primary{% else %}widget-button-secondary{% endif %}"
                        data-setting="link_2"
                        {% if block.settings.link_2.target == '_blank' %}
                          target="_blank" rel="noopener"
                        {% endif %}
                      >
                        {{ block.settings.link_2.text }}
                      </a>
                    {% endif %}
                  </div>
                {% endif %}
            {% endcase %}
            {% assign delay = delay | plus: 1 %}
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

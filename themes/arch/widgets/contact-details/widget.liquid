<section
  id="{{ widget.id }}"
  class="widget widget-contact-details widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}"
  data-widget-id="{{ widget.id }}"
  data-widget-type="contact-details"
  style="{% if widget.settings.color_scheme == 'highlight' %}--widget-bg-color: var(--bg-primary);{% endif %}"
>
  <style>
    .widget-{{ widget.id }} {
      & .contact-details-column {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);

        &:first-child {
          grid-column: span 2;
        }
      }

      & .contact-details-menu {
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
        list-style: none;
        padding: 0;
        margin: 0;
      }

      & .contact-details-menu-link {
        color: var(--text-content);
        text-decoration: none;
        font-size: calc(var(--font-size-sm) * var(--body-scale));
        font-weight: var(--typography-body_font-weight, 400);
        transition: color var(--transition-speed-fast);

        &:hover {
          color: var(--accent);
        }
      }

      & .contact-details-social {
        justify-content: flex-start;
      }
    }
  </style>

  <div class="{% if widget.settings.color_scheme == 'highlight' %}widget-container-padded{% else %}widget-container{% endif %}">
    {% if widget.settings.eyebrow != blank or widget.settings.title != blank or widget.settings.description != blank %}
      <div class="widget-header{% if widget.settings.heading_alignment == 'left' %} widget-header--align-start{% endif %}">
        {% if widget.settings.eyebrow != blank %}
          <p class="w-eyebrow" data-setting="eyebrow">{{ widget.settings.eyebrow }}</p>
        {% endif %}
        {% if widget.settings.title != blank %}
          <h2 class="w-headline" data-setting="title">{{ widget.settings.title }}</h2>
        {% endif %}
        {% if widget.settings.description != blank %}
          <p class="w-description" data-setting="description">{{ widget.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="widget-grid" style="--grid-cols-desktop: 5; --grid-gap: var(--space-3xl);">
      {% for blockId in widget.blocksOrder %}
        {% assign block = widget.blocks[blockId] %}

        <div class="contact-details-column" data-block-id="{{ blockId }}">
          {% case block.type %}
          {% when 'info' %}
            {% if block.settings.title != blank %}
              <span class="w-title t-xl t-heading-font" data-setting="title">{{ block.settings.title }}</span>
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="w-body w-rte t-sm" data-setting="text">{{ block.settings.text | raw }}</div>
            {% endif %}

          {% when 'text_block' %}
            {% if block.settings.title != blank %}
              <h3 class="w-title t-lg" data-setting="title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="w-body w-rte t-sm" data-setting="text">{{ block.settings.text | raw }}</div>
            {% endif %}

          {% when 'menu_block' %}
            {% if block.settings.title != blank %}
              <h3 class="w-title t-lg" data-setting="title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.menu %}
              {% render 'menu',
                menu: block.settings.menu,
                aria_label: block.settings.title,
                class_nav: 'contact-details-nav',
                class_list: 'contact-details-menu',
                class_item: 'contact-details-menu-item',
                class_link: 'contact-details-menu-link',
                class_submenu: 'hidden',
                class_has_submenu: 'hidden'
              %}
            {% endif %}

          {% when 'social_block' %}
            {% if block.settings.title != blank %}
              <h3 class="w-title t-lg" data-setting="title">{{ block.settings.title }}</h3>
            {% endif %}
            <div class="social-links contact-details-social">
              {% render 'social-icons', social: theme.social %}
            </div>
          {% endcase %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

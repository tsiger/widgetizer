{
  "type": "schedule-table",
  "displayName": "tTheme:schedule_table.name",
  "aliases": [
    "agenda",
    "time table",
    "timetable",
    "events schedule"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:schedule_table.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:schedule_table.settings.title.label",
      "default": "Opening Hours"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:schedule_table.settings.description.label"
    },
    {
      "type": "header",
      "id": "content_header",
      "label": "tTheme:schedule_table.settings.content_header.label"
    },
    {
      "type": "text",
      "id": "note",
      "label": "tTheme:schedule_table.settings.note.label",
      "default": "We are closed on public holidays"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:schedule_table.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "sidebar_position",
      "label": "tTheme:schedule_table.settings.sidebar_position.label",
      "default": "right",
      "options": [
        {
          "value": "left",
          "label": "tTheme:schedule_table.settings.sidebar_position.options.left"
        },
        {
          "value": "right",
          "label": "tTheme:schedule_table.settings.sidebar_position.options.right"
        }
      ]
    },
    {
      "type": "select",
      "id": "week_start_day",
      "label": "tTheme:schedule_table.settings.week_start_day.label",
      "options": [
        {
          "value": "0",
          "label": "tTheme:schedule_table.settings.week_start_day.options.0"
        },
        {
          "value": "1",
          "label": "tTheme:schedule_table.settings.week_start_day.options.1"
        }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:schedule_table.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:schedule_table.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:schedule_table.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "day",
      "displayName": "tTheme:schedule_table.blocks.day.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:schedule_table.blocks.day.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "day",
          "label": "tTheme:schedule_table.blocks.day.settings.day.label",
          "default": "Monday"
        },
        {
          "type": "text",
          "id": "hours",
          "label": "tTheme:schedule_table.blocks.day.settings.hours.label",
          "default": "9:00 AM - 5:00 PM"
        },
        {
          "type": "header",
          "id": "options_header",
          "label": "tTheme:schedule_table.blocks.day.settings.options_header.label"
        },
        {
          "type": "checkbox",
          "id": "closed",
          "label": "tTheme:schedule_table.blocks.day.settings.closed.label",
          "default": false
        }
      ]
    },
    {
      "type": "info",
      "displayName": "tTheme:schedule_table.blocks.info.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:schedule_table.blocks.info.settings.title.label",
          "default": "Contact Us"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "tTheme:schedule_table.blocks.info.settings.text.label",
          "default": "<p>hello@example.com</p>"
        }
      ]
    },
    {
      "type": "social",
      "displayName": "tTheme:schedule_table.blocks.social.name",
      "settings": []
    }
  ],
  "defaultBlocks": [
    {
      "type": "day",
      "settings": {
        "day": "Monday",
        "hours": "9:00 AM - 9:00 PM",
        "closed": false
      }
    },
    {
      "type": "day",
      "settings": {
        "day": "Tuesday",
        "hours": "9:00 AM - 9:00 PM",
        "closed": false
      }
    },
    {
      "type": "day",
      "settings": {
        "day": "Wednesday",
        "hours": "9:00 AM - 9:00 PM",
        "closed": false
      }
    },
    {
      "type": "day",
      "settings": {
        "day": "Thursday",
        "hours": "9:00 AM - 9:00 PM",
        "closed": false
      }
    },
    {
      "type": "day",
      "settings": {
        "day": "Friday",
        "hours": "9:00 AM - 10:00 PM",
        "closed": false
      }
    },
    {
      "type": "day",
      "settings": {
        "day": "Saturday",
        "hours": "10:00 AM - 10:00 PM",
        "closed": false
      }
    },
    {
      "type": "day",
      "settings": {
        "day": "Sunday",
        "hours": "Closed",
        "closed": true
      }
    },
    {
      "type": "info",
      "settings": {
        "title": "Contact Us",
        "text": "<p>hello@example.com</p>"
      }
    }
  ]
}

{
  "type": "icon-list",
  "displayName": "tTheme:icon_list.name",
  "aliases": [
    "amenities",
    "features",
    "icons",
    "services list",
    "facilities"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:icon_list.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:icon_list.settings.title.label"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:icon_list.settings.description.label"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:icon_list.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "tTheme:icon_list.settings.layout.label",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "tTheme:icon_list.settings.layout.options.grid"
        },
        {
          "value": "carousel",
          "label": "tTheme:icon_list.settings.layout.options.carousel"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "tTheme:icon_list.settings.columns_desktop.label",
      "default": 4,
      "min": 2,
      "max": 8,
      "step": 1
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:icon_list.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:icon_list.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:icon_list.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "displayName": "tTheme:icon_list.blocks.item.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:icon_list.blocks.item.settings.content_header.label"
        },
        {
          "type": "icon",
          "id": "icon",
          "label": "tTheme:icon_list.blocks.item.settings.icon.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:icon_list.blocks.item.settings.title.label",
          "default": "Feature"
        },
        {
          "type": "text",
          "id": "description",
          "label": "tTheme:icon_list.blocks.item.settings.description.label"
        }
      ]
    }
  ],

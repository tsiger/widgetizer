        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:icon_list.blocks.item.settings.title.label",
          "default": "Feature"
        },
        {
          "type": "text",
          "id": "description",
          "label": "tTheme:icon_list.blocks.item.settings.description.label"
        }
      ]
    }
  ],

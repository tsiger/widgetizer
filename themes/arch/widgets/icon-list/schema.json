      "options": [
        {
          "value": "plain",
          "label": "tTheme:global.widgets.settings.icon_style.options.plain"
        },
        {
          "value": "outline",
          "label": "tTheme:global.widgets.settings.icon_style.options.outline"
        },
        {
          "value": "filled",
          "label": "tTheme:global.widgets.settings.icon_style.options.filled"
        }
      ]
    },
    {
      "type": "select",
      "id": "icon_size",
      "label": "tTheme:global.widgets.settings.icon_size.label",
      "default": "xl",
      "options": [
        {
          "value": "sm",
          "label": "tTheme:global.widgets.settings.icon_size.options.sm"
        },
        {
          "value": "md",
          "label": "tTheme:global.widgets.settings.icon_size.options.md"
        },
        {
          "value": "lg",
          "label": "tTheme:global.widgets.settings.icon_size.options.lg"
        },
        {
          "value": "xl",
          "label": "tTheme:global.widgets.settings.icon_size.options.xl"
        }
      ]
    },
    {
      "type": "select",
      "id": "icon_shape",
      "label": "tTheme:global.widgets.settings.icon_shape.label",
      "default": "circle",
      "options": [
        {
          "value": "sharp",
          "label": "tTheme:global.widgets.settings.icon_shape.options.sharp"
        },
        {
          "value": "rounded",
          "label": "tTheme:global.widgets.settings.icon_shape.options.rounded"
        },
        {
          "value": "circle",
          "label": "tTheme:global.widgets.settings.icon_shape.options.circle"
        }
      ]
    },
    {
      "type": "select",
      "id": "layout",
      "label": "tTheme:global.widgets.settings.layout.label",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "tTheme:global.widgets.settings.layout.options.grid"
        },
        {
          "value": "carousel",
          "label": "tTheme:global.widgets.settings.layout.options.carousel"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "tTheme:global.widgets.settings.columns_desktop.label",
      "default": 4,
      "min": 2,
      "max": 8,
      "step": 1
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard"
        },
        {
          "value": "standard-accent",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_accent"
        },
        {
          "value": "highlight",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight"
        },
        {
          "value": "highlight-accent",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_accent"
        }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.top_spacing.options.auto"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.top_spacing.options.none"
        }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.none"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "displayName": "tTheme:icon_list.blocks.item.name",
      "settings": [
        {
          "type": "header",

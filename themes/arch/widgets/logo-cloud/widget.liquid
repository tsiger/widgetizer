{% if widget.settings.layout == 'carousel' %}
  {% enqueue_script src: "carousel.js", defer: true, location: "footer", priority: 40, theme: true %}
{% endif %}
<section
  id="{{ widget.id }}"
  class="widget widget-type-logo-cloud widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}{% if widget.settings.top_spacing != 'auto' %} spacing-top-{{ widget.settings.top_spacing }}{% endif %}{% if widget.settings.bottom_spacing != 'auto' %} spacing-bottom-{{ widget.settings.bottom_spacing }}{% endif %}"
  {% unless widget.settings.color_scheme == 'standard-primary' %}
    style="--widget-bg-color: var(--bg-primary);"
  {% endunless %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="logo-cloud"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      & .logo-grid {
        list-style: none;
        padding: 0;
        margin: 0;
        align-items: center;
        justify-items: center;
      }

      & .logo-item {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: var(--space-sm);
        background-color: var(--bg-primary);
        border: var(--border-width-thin) solid var(--border-color);
        border-radius: var(--radius-sm);
        min-height: 11rem;
        overflow: hidden;
      }

      & .logo-link,
      & .logo-frame {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;

        {% if widget.settings.aspect_ratio != 'auto' %}
        &.has-image {
          aspect-ratio: {{ widget.settings.aspect_ratio }};
        }
        {% endif %}
      }

      & .logo-image {
        width: 100%;
        height: 100%;
        max-width: 100%;
        object-fit: contain;
        object-position: center;
        filter: grayscale(100%);
        opacity: 0.6;
        transition: opacity 0.3s, filter 0.3s;
        display: block;

        &:hover {
          opacity: 1;
          filter: grayscale(0%);
        }
      }

      @media (min-width: 750px) {
        & .logo-item {
          min-height: 12rem;
        }
      }

      @media (min-width: 990px) {
        & .logo-item {
          min-height: 13rem;
        }
      }
    }
  </style>

  <div class="widget-container {% unless widget.settings.color_scheme == 'standard-primary' %}widget-container-padded{% endunless %}">
    {% if widget.settings.title != blank or widget.settings.description != blank or widget.settings.eyebrow != blank %}
      <div class="widget-header{% if widget.settings.heading_alignment == 'left' %} widget-header--align-start{% endif %}">
        {% assign header_delay = 0 %}
        {% if widget.settings.eyebrow != blank %}
          <span class="w-eyebrow reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.title != blank %}
          {% if widget.index == 1 %}
            <h1 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h1>
          {% else %}
            <h2 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h2>
          {% endif %}
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.description != blank %}
          <p class="w-description reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="description">{{ widget.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="widget-content">
      {% if widget.settings.layout == 'carousel' %}
        <div class="carousel-container reveal reveal-up">
          <button type="button" class="carousel-btn carousel-btn-prev" aria-label="Previous">
            <svg class="carousel-btn-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <button type="button" class="carousel-btn carousel-btn-next" aria-label="Next">
            <svg class="carousel-btn-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <ul class="logo-grid carousel-track" style="--carousel-cols: {{ widget.settings.columns_desktop }}">
            {% for blockId in widget.blocksOrder %}
              {% assign block = widget.blocks[blockId] %}
              <li class="logo-item carousel-item" data-block-id="{{ blockId }}">
                {% if block.settings.link.href != blank %}
                  <a
                    href="{{ block.settings.link.href }}"
                    class="logo-link{% if block.settings.image != blank %} has-image{% endif %}"
                    {% if block.settings.link.target == '_blank' %}
                      target="_blank" rel="noopener"
                    {% endif %}
                  >
                    {% if block.settings.image != blank %}
                      {% image src: block.settings.image, size: 'small', class: 'logo-image', alt: block.settings.name %}
                    {% else %}
                      {% placeholder_image aspect: 'landscape', class: 'logo-image' %}
                    {% endif %}
                  </a>
                {% else %}
                  <div class="logo-frame{% if block.settings.image != blank %} has-image{% endif %}">
                    {% if block.settings.image != blank %}
                      {% image src: block.settings.image, size: 'small', class: 'logo-image', alt: block.settings.name %}
                    {% else %}
                      {% placeholder_image aspect: 'landscape', class: 'logo-image' %}
                    {% endif %}
                  </div>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </div>

      {% else %}
        <ul
          class="logo-grid widget-grid"
          style="--grid-cols-desktop: {{ widget.settings.columns_desktop }};"
        >
          {% for blockId in widget.blocksOrder %}
            {% assign block = widget.blocks[blockId] %}
            <li class="logo-item reveal reveal-fade" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
              {% if block.settings.link.href != blank %}
                <a
                  href="{{ block.settings.link.href }}"
                  class="logo-link{% if block.settings.image != blank %} has-image{% endif %}"
                  {% if block.settings.link.target == '_blank' %}
                    target="_blank" rel="noopener"
                  {% endif %}
                >
                  {% if block.settings.image != blank %}
                    {% image src: block.settings.image, size: 'small', class: 'logo-image', alt: block.settings.name %}
                  {% else %}
                    {% placeholder_image aspect: 'landscape', class: 'logo-image' %}
                  {% endif %}
                </a>
              {% else %}
                <div class="logo-frame{% if block.settings.image != blank %} has-image{% endif %}">
                  {% if block.settings.image != blank %}
                    {% image src: block.settings.image, size: 'small', class: 'logo-image', alt: block.settings.name %}
                  {% else %}
                    {% placeholder_image aspect: 'landscape', class: 'logo-image' %}
                  {% endif %}
                </div>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </div>
</section>

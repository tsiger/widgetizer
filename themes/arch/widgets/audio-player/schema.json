{
  "type": "audio-player",
  "displayName": "tTheme:audio_player.name",
  "aliases": ["audio", "mp3 player", "music", "podcast", "player", "playlist", "sound", "track", "episode"],
  "settings": [
    {
      "type": "header",
      "id": "content_header",
      "label": "tTheme:global.widgets.settings.content_header.label"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label"
    },
    {
      "type": "checkbox",
      "id": "eyebrow_uppercase",
      "label": "tTheme:global.widgets.settings.eyebrow_uppercase.label",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "Listen"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label",
      "default": "Press play and enjoy the tracks below."
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        { "value": "start", "label": "tTheme:global.widgets.settings.alignment.options.start" },
        { "value": "center", "label": "tTheme:global.widgets.settings.alignment.options.center" }
      ]
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "checkbox",
      "id": "show_covers",
      "label": "tTheme:audio_player.settings.show_covers.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_volume",
      "label": "tTheme:audio_player.settings.show_volume.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_speed",
      "label": "tTheme:audio_player.settings.show_speed.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_download",
      "label": "tTheme:audio_player.settings.show_download.label",
      "default": true
    },
    {
      "type": "header",
      "id": "appearance_header",
      "label": "tTheme:global.widgets.settings.appearance_header.label"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard-primary",
      "options": [
        { "value": "standard-primary", "label": "tTheme:global.widgets.settings.color_scheme.options.standard_primary" },
        { "value": "standard-secondary", "label": "tTheme:global.widgets.settings.color_scheme.options.standard_secondary" },
        { "value": "highlight-primary", "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_primary" },
        { "value": "highlight-secondary", "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_secondary" }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "tTheme:global.widgets.settings.top_spacing.options.auto" },
        { "value": "small", "label": "tTheme:global.widgets.settings.top_spacing.options.small" },
        { "value": "none", "label": "tTheme:global.widgets.settings.top_spacing.options.none" }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto" },
        { "value": "small", "label": "tTheme:global.widgets.settings.bottom_spacing.options.small" },
        { "value": "none", "label": "tTheme:global.widgets.settings.bottom_spacing.options.none" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "track",
      "displayName": "tTheme:audio_player.blocks.track.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:audio_player.blocks.track.settings.title.label",
          "default": "Track title"
        },
        {
          "type": "text",
          "id": "artist",
          "label": "tTheme:audio_player.blocks.track.settings.artist.label",
          "default": "Artist name"
        },
        {
          "type": "file",
          "id": "audio",
          "label": "tTheme:audio_player.blocks.track.settings.audio.label",
          "description": "tTheme:audio_player.blocks.track.settings.audio.description"
        },
        {
          "type": "image",
          "id": "cover",
          "label": "tTheme:audio_player.blocks.track.settings.cover.label"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "track",
      "settings": { "title": "Opening Theme", "artist": "Your Band", "audio": "", "cover": "" }
    },
    {
      "type": "track",
      "settings": { "title": "Midnight Drive", "artist": "Your Band", "audio": "", "cover": "" }
    },
    {
      "type": "track",
      "settings": { "title": "Closing Credits", "artist": "Your Band", "audio": "", "cover": "" }
    }
  ]
}

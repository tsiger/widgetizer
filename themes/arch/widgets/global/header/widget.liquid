<header id="{{ widget.id }}" class="widget widget-site-header color-scheme-{{ widget.settings.color_scheme }}{% if widget.settings.sticky %} header-sticky{% endif %}" data-widget-id="{{ widget.id }}" data-widget-type="header"{% unless widget.settings.color_scheme == 'standard-primary' %}style="--widget-bg-color: var(--bg-primary);"{% endunless %}>

  <style>
    .widget-site-header .header-logo-image {
      max-width: {{ widget.settings.logoMaxWidth | default: 150 }}px;
      height: auto;
      display: block;
    }
    .widget-site-header .header-logo img[src$=".svg"],
    .widget-site-header .header-logo-image[src$=".svg"] {
      width: auto;
      height: auto;
      max-height: {{ widget.settings.logoMaxWidth | default: 150 }}px;
      min-height: 40px;
      object-fit: contain;
      vertical-align: middle;
    }
    .widget-site-header .header-logo {
      line-height: 0;
    }
    .widget-site-header .header-logo img {
      display: inline-block;
    }
    {% unless widget.settings.full_width %}
    .widget-site-header .header-inner {
      max-width: var(--container-max-width);
      margin-inline: auto;
    }
    {% endunless %}
  </style>

  <div class="header-inner{% if widget.settings.center_nav %} header-center-nav{% endif %}">
    <div class="header-branding">
      <a href="index.html" class="header-logo">
        {% if widget.settings.logoImage != blank %}
          {% image src: widget.settings.logoImage, size: 'medium', class: 'header-logo-image header-logo-default', lazy: false %}
          {% if widget.settings.transparent_logo != blank %}
            {% image src: widget.settings.transparent_logo, size: 'medium', class: 'header-logo-image header-logo-transparent', lazy: false %}
          {% else %}
            {% image src: widget.settings.logoImage, size: 'medium', class: 'header-logo-image header-logo-transparent', lazy: false %}
          {% endif %}
        {% else %}
          <span data-setting="logoText">{{ widget.settings.logoText | default: 'Widgetizer' }}</span>
        {% endif %}
      </a>

      {% if widget.settings.contact_position != 'menu' %}
        {% if widget.settings.contactDetailsLine1 != blank or widget.settings.contactDetailsLine2 != blank %}
          <div class="header-contact">
            {% if widget.settings.contactDetailsLine1 != blank %}
              <span class="header-contact-line t-sm t-body-bold t-heading" data-setting="contactDetailsLine1">
                {{ widget.settings.contactDetailsLine1 }}
              </span>
            {% endif %}
            {% if widget.settings.contactDetailsLine2 != blank %}
              <span class="header-contact-line t-xs t-muted" data-setting="contactDetailsLine2">
                {{ widget.settings.contactDetailsLine2 }}
              </span>
            {% endif %}
          </div>
        {% endif %}
      {% endif %}
    </div>

    <div class="header-actions">
      <nav class="header-nav" id="main-navigation" aria-label="Primary">
        <div class="nav-close">
          <span class="nav-close-title">Menu</span>
          <button type="button" class="nav-close-btn" aria-label="Close navigation menu">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M18 6l-12 12" />
              <path d="M6 6l12 12" />
            </svg>
          </button>
        </div>
        {% if widget.settings.headerNavigation %}
          {% render 'menu',
            menu: widget.settings.headerNavigation,
            skip_nav: true,
            class_list: 'nav-list',
            class_item: 'nav-item',
            class_link: '',
            class_submenu: 'nav-submenu',
            class_has_submenu: 'has-submenu'
          %}
        {% endif %}
        {% if widget.settings.ctaButtonLink.text != blank %}
          <a href="{{ widget.settings.ctaButtonLink.href | default: '#' }}" class="widget-button widget-button-full widget-button-large mobile-cta {% if widget.settings.ctaButtonStyle == 'primary' %}widget-button-primary{% else %}widget-button-secondary{% endif %}" {% if widget.settings.ctaButtonLink.target == '_blank' %}target="_blank" rel="noopener noreferrer"{% endif %}>
            {{ widget.settings.ctaButtonLink.text }}
          </a>
        {% endif %}
        {% if widget.settings.contactDetailsLine1 != blank or widget.settings.contactDetailsLine2 != blank %}
          <div class="header-contact header-contact-mobile">
            {% if widget.settings.contactDetailsLine1 != blank %}
              <span class="header-contact-line t-lg t-body-bold t-heading" data-setting="contactDetailsLine1">
                {{ widget.settings.contactDetailsLine1 }}
              </span>
            {% endif %}
            {% if widget.settings.contactDetailsLine2 != blank %}
              <span class="header-contact-line t-xs t-muted" data-setting="contactDetailsLine2">
                {{ widget.settings.contactDetailsLine2 }}
              </span>
            {% endif %}
          </div>
        {% endif %}
      </nav>

      <div class="header-end">
        {% if widget.settings.contact_position == 'menu' %}
          {% if widget.settings.contactDetailsLine1 != blank or widget.settings.contactDetailsLine2 != blank %}
            <div class="header-contact header-contact-right">
              {% if widget.settings.contactDetailsLine1 != blank %}
                <span class="header-contact-line t-sm t-body-bold t-heading" data-setting="contactDetailsLine1">
                  {{ widget.settings.contactDetailsLine1 }}
                </span>
              {% endif %}
              {% if widget.settings.contactDetailsLine2 != blank %}
                <span class="header-contact-line t-xs t-muted" data-setting="contactDetailsLine2">
                  {{ widget.settings.contactDetailsLine2 }}
                </span>
              {% endif %}
            </div>
          {% endif %}
        {% endif %}

        {% if widget.settings.ctaButtonLink.text != blank %}
        <a href="{{ widget.settings.ctaButtonLink.href | default: '#' }}" class="widget-button desktop-cta {% if widget.settings.ctaButtonStyle == 'primary' %}widget-button-primary{% else %}widget-button-secondary{% endif %}" {% if widget.settings.ctaButtonLink.target == '_blank' %}target="_blank" rel="noopener noreferrer"{% endif %}>
          {{ widget.settings.ctaButtonLink.text }}
        </a>
        {% endif %}

        {% assign header_shopify_domain = theme.shopify.store_domain | default: '' | strip %}
        {% if header_shopify_domain != blank %}
          {% comment %} Shopify cart trigger: opens the global cart (wired in
             assets/shopify-cart.js); the badge is a live cart context that
             Shopify refreshes on every cart change. Lives inside .header-end
             so it sits next to the CTA in both layouts (in center-nav mode
             .header-actions becomes display: contents and loose children get
             auto-placed by the grid); .header-end stays visible on mobile,
             its other children hide themselves there. {% endcomment %}
          <button type="button" class="header-cart" data-shopify-cart-open aria-label="Open cart">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M6 19m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" />
              <path d="M17 19m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" />
              <path d="M17 17h-11v-14h-2" />
              <path d="M6 5l14 1l-1 7h-13" />
            </svg>
            <shopify-context type="cart">
              {% comment %} assets/shopify-cart.js mirrors the rendered count into
                 data-count so CSS can hide the badge when the cart is empty. A
                 shopify-attr binding can't do this: attr expressions evaluate as
                 JS and throw (visibly) while no cart exists yet. {% endcomment %}
              <template><span class="header-cart-count"><shopify-data query="cart.totalQuantity"></shopify-data></span></template>
            </shopify-context>
          </button>
        {% endif %}
      </div>

      <button
        type="button"
        class="menu-toggle"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="main-navigation"
      >
        <svg
          class="icon-menu"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M4 6l16 0" />
          <path d="M4 12l16 0" />
          <path d="M4 18l16 0" />
        </svg>
        <svg
          class="icon-close"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
          <path d="M18 6l-12 12" />
          <path d="M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>
</header>

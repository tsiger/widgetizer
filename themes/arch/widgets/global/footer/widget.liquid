<footer
  id="{{ widget.id }}"
  class="widget widget-footer widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}"
  data-widget-id="{{ widget.id }}"
  data-widget-type="footer"
  style="{% unless widget.settings.color_scheme == 'standard-primary' %}--widget-bg-color: var(--bg-primary);{% endunless %}{% if widget.settings.copyright == blank %} padding-block: 8rem;{% endif %}"
>
  {% if widget.settings.layout != 'equal' %}
  <style>
    .widget-{{ widget.id }} .footer-column:{% if widget.settings.layout == 'last-featured' %}last-child{% else %}first-child{% endif %} {
      grid-column: span 2;
    }
  </style>
  {% endif %}
  <div class="widget-container footer-content">
    {% assign block_count = widget.blocksOrder.size %}
    {% if widget.settings.layout == 'equal' %}
      {% assign grid_cols = block_count %}
    {% else %}
      {% assign grid_cols = block_count | plus: 1 %}
    {% endif %}
    <div class="widget-grid" style="--grid-cols-desktop: {{ grid_cols }}; --grid-gap: var(--space-3xl);">
      {% for blockId in widget.blocksOrder %}
        {% assign block = widget.blocks[blockId] %}

        <div class="footer-column" data-block-id="{{ blockId }}">
          {% case block.type %}
          {% when 'logo_text' %}
            {% if block.settings.logo != blank %}
              <style>.widget-{{ widget.id }} [data-block-id="{{ blockId }}"] .footer-logo { max-width: {{ block.settings.logo_width | default: 100 }}px; height: auto; display: block; }</style>
              {% image src: block.settings.logo, size: 'small', class: 'footer-logo', alt: 'Logo' %}
            {% elsif block.settings.logo_text != blank %}
              <span class="footer-logo-text w-title t-xl t-heading-font" data-setting="logo_text">{{ block.settings.logo_text }}</span>
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="w-body w-rte t-sm" data-setting="text">{{ block.settings.text | raw }}</div>
            {% endif %}

          {% when 'text_block' %}
            {% if block.settings.title != blank %}
              <h3 class="w-title t-lg" data-setting="title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="w-body w-rte t-sm" data-setting="text">{{ block.settings.text | raw }}</div>
            {% endif %}

          {% when 'menu_block' %}
            {% if block.settings.title != blank %}
              <h3 class="w-title t-lg" data-setting="title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.menu %}
              {% render 'menu',
                menu: block.settings.menu,
                aria_label: block.settings.title,
                class_nav: 'footer-nav',
                class_list: 'footer-menu',
                class_item: 'footer-menu-item',
                class_link: 'footer-menu-link',
                class_submenu: 'hidden',
                class_has_submenu: 'hidden'
              %}
            {% endif %}

          {% when 'social_block' %}
            {% if block.settings.title != blank %}
              <h3 class="w-title t-lg" data-setting="title">{{ block.settings.title }}</h3>
            {% endif %}
            <div class="social-links footer-social">
              {% render 'social-icons', social: theme.social %}
            </div>

          {% when 'badges_block' %}
            {% if block.settings.title != blank %}
              <h3 class="w-title t-lg" data-setting="title">{{ block.settings.title }}</h3>
            {% endif %}
            <style>.widget-{{ widget.id }} [data-block-id="{{ blockId }}"] .footer-badge-image { max-height: {{ block.settings.max_height | default: 50 }}px; }</style>
            <ul class="footer-badges">
              {% for i in (1..4) %}
                {% assign image_key = 'badge_' | append: i | append: '_image' %}
                {% assign link_key = 'badge_' | append: i | append: '_link' %}
                {% assign badge_image = block.settings[image_key] %}
                {% assign badge_link = block.settings[link_key] %}
                {% if badge_image != blank %}
                  <li class="footer-badge" data-setting="{{ image_key }}">
                    {% if badge_link.href != blank %}
                      <a href="{{ badge_link.href }}"
                         {% if badge_link.target == '_blank' %}target="_blank" rel="noopener"{% endif %}
                         {% if badge_link.text != blank %}aria-label="{{ badge_link.text }}"{% endif %}>
                        {% image src: badge_image, size: 'small', class: 'footer-badge-image', alt: badge_link.text | default: '' %}
                      </a>
                    {% else %}
                      {% image src: badge_image, size: 'small', class: 'footer-badge-image', alt: '' %}
                    {% endif %}
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          {% endcase %}
        </div>
      {% endfor %}
    </div>

    {% if widget.settings.copyright != blank %}
      <p class="footer-copyright" data-setting="copyright">
        {{ widget.settings.copyright }}
      </p>
    {% endif %}
  </div>
</footer>

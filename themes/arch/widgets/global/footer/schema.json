{
  "type": "footer",
  "displayName": "tTheme:footer.name",
  "settings": [
    {
      "type": "header",
      "id": "content_header",
      "label": "tTheme:footer.settings.content_header.label"
    },
    {
      "type": "image",
      "id": "logo",
      "label": "tTheme:footer.settings.logo.label"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "tTheme:footer.settings.logo_width.label",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 100,
      "unit": "px"
    },
    {
      "type": "menu",
      "id": "footerNavigation",
      "label": "tTheme:footer.settings.footerNavigation.label",
      "description": "tTheme:footer.settings.footerNavigation.description",
      "default": "footer-menu"
    },
    {
      "type": "textarea",
      "id": "copyright",
      "label": "tTheme:footer.settings.copyright.label",
      "default": "© 2026 Widgetizer. All rights are yours to keep."
    },
    {
      "type": "header",
      "id": "social_header",
      "label": "tTheme:footer.settings.social_header.label"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "tTheme:footer.settings.show_social.label",
      "default": true,
      "description": "tTheme:footer.settings.show_social.description"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:footer.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:footer.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:footer.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:footer.settings.color_scheme.options.highlight"
        }
      ]
    }
  ]
}

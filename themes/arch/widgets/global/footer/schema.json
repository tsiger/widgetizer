{
  "type": "footer",
  "displayName": "Footer",
  "settings": [
    {
      "type": "header",
      "id": "content_header",
      "label": "Content"
    },
    {
      "type": "image",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 100,
      "unit": "px"
    },
    {
      "type": "menu",
      "id": "footerNavigation",
      "label": "Navigation Menu",
      "description": "Select the menu to display in the footer",
      "default": "footer-menu"
    },
    {
      "type": "textarea",
      "id": "copyright",
      "label": "Copyright text",
      "default": "© 2026 Widgetizer. All rights are yours to keep."
    },
    {
      "type": "header",
      "id": "social_header",
      "label": "Social Media"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true,
      "description": "Display social media icons from theme settings"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "Display"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "highlight",
          "label": "Highlight"
        }
      ]
    }
  ]
}

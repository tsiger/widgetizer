{
  "type": "content-switcher",
  "displayName": "tTheme:content_switcher.name",
  "aliases": [
    "tabs",
    "toggle content",
    "switch",
    "selector"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:content_switcher.settings.eyebrow.label",
      "default": "Pricing"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:content_switcher.settings.title.label",
      "default": "Choose Your Plan"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:content_switcher.settings.description.label",
      "default": "Select the billing cycle that works best for you. All plans include our core features."
    },
    {
      "type": "header",
      "id": "switcher_header",
      "label": "tTheme:content_switcher.settings.switcher_header.label"
    },
    {
      "type": "select",
      "id": "switcher_type",
      "label": "tTheme:content_switcher.settings.switcher_type.label",
      "default": "toggle",
      "options": [
        {
          "value": "toggle",
          "label": "tTheme:content_switcher.settings.switcher_type.options.toggle"
        },
        {
          "value": "tabs",
          "label": "tTheme:content_switcher.settings.switcher_type.options.tabs"
        }
      ]
    },
    {
      "type": "header",
      "id": "labels_header",
      "label": "tTheme:content_switcher.settings.labels_header.label"
    },
    {
      "type": "text",
      "id": "option_1_label",
      "label": "tTheme:content_switcher.settings.option_1_label.label",
      "default": "Monthly"
    },
    {
      "type": "text",
      "id": "option_2_label",
      "label": "tTheme:content_switcher.settings.option_2_label.label",
      "default": "Yearly"
    },
    {
      "type": "text",
      "id": "option_3_label",
      "label": "tTheme:content_switcher.settings.option_3_label.label",
      "default": "Lifetime"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:content_switcher.settings.display_header.label"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "tTheme:content_switcher.settings.columns.label",
      "default": 3,
      "min": 2,
      "max": 5,
      "step": 1
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:content_switcher.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:content_switcher.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:content_switcher.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "displayName": "tTheme:content_switcher.blocks.item.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:content_switcher.blocks.item.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:content_switcher.blocks.item.settings.title.label",
          "default": "Item Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "tTheme:content_switcher.blocks.item.settings.text.label",
          "default": "<p>Item description goes here.</p>"
        },
        {
          "type": "image",
          "id": "image",
          "label": "tTheme:content_switcher.blocks.item.settings.image.label"
        },
        {
          "type": "text",
          "id": "price",
          "label": "tTheme:content_switcher.blocks.item.settings.price.label"
        },
        {
          "type": "link",
          "id": "link",
          "label": "tTheme:content_switcher.blocks.item.settings.link.label"
        },
        {
          "type": "header",
          "id": "layout_header",
          "label": "tTheme:content_switcher.blocks.item.settings.layout_header.label"
        },
        {
          "type": "select",
          "id": "target_option",
          "label": "tTheme:content_switcher.blocks.item.settings.target_option.label",
          "default": "1",
          "options": [
            {
              "value": "1",
              "label": "tTheme:content_switcher.blocks.item.settings.target_option.options.1"
            },
            {
              "value": "2",
              "label": "tTheme:content_switcher.blocks.item.settings.target_option.options.2"
            },
            {
              "value": "3",
              "label": "tTheme:content_switcher.blocks.item.settings.target_option.options.3"
            }
          ]
        }
      ]
    }
  ],

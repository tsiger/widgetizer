{
  "type": "project-showcase",
  "displayName": "tTheme:project_showcase.name",
  "aliases": [
    "portfolio",
    "works",
    "case studies",
    "projects"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label",
      "default": "Featured Projects"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "Project Showcase"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label",
      "default": "Browse through our collection of successful projects and client collaborations."
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "tTheme:global.widgets.settings.options.left"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "tTheme:global.widgets.settings.layout.label",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "tTheme:global.widgets.settings.layout.options.grid"
        },
        {
          "value": "carousel",
          "label": "tTheme:global.widgets.settings.layout.options.carousel"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "tTheme:global.widgets.settings.columns_desktop.label",
      "default": 3,
      "min": 2,
      "max": 5,
      "step": 1
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "tTheme:global.widgets.settings.aspect_ratio.label",
      "default": "4 / 3",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.auto"
        },
        {
          "value": "contain",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.contain"
        },
        {
          "value": "1 / 1",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.1 / 1"
        },
        {
          "value": "4 / 3",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.4 / 3"
        },
        {
          "value": "3 / 2",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.3 / 2"
        },
        {
          "value": "3 / 4",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.3 / 4"
        },
        {
          "value": "16 / 9",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.16 / 9"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_display",
      "label": "tTheme:project_showcase.settings.text_display.label",
      "default": "hover",
      "options": [
        {
          "value": "hover",
          "label": "tTheme:project_showcase.settings.text_display.options.hover"
        },
        {
          "value": "always",
          "label": "tTheme:project_showcase.settings.text_display.options.always"
        }
      ]
    },
    {
      "type": "header",
      "id": "widget_header",
      "label": "Widget"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard-primary",
      "options": [
        {
          "value": "standard-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_primary"
        },
        {
          "value": "standard-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_secondary"
        },
        {
          "value": "highlight-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_primary"
        },
        {
          "value": "highlight-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_secondary"
        }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.top_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.top_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.top_spacing.options.none"
        }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.none"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "project",
      "displayName": "tTheme:project_showcase.blocks.project.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "image",
          "id": "image",
          "label": "tTheme:global.widgets.settings.image.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:project_showcase.blocks.project.settings.title.label",
          "default": "Project Name"
        },
        {
          "type": "text",
          "id": "description",
          "label": "tTheme:project_showcase.blocks.project.settings.description.label"
        },
        {
          "type": "link",
          "id": "link",
          "label": "tTheme:project_showcase.blocks.project.settings.link.label",
          "hide_text": true
        }
      ]
    }
  ],

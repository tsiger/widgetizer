{
  "type": "timeline",
  "displayName": "tTheme:timeline.name",
  "aliases": [
    "history",
    "roadmap",
    "milestones",
    "journey"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label"
    },
    {
      "type": "checkbox",
      "id": "eyebrow_uppercase",
      "label": "tTheme:global.widgets.settings.eyebrow_uppercase.label",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "Our Process"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "start",
          "label": "tTheme:global.widgets.settings.alignment.options.start"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.alignment.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "tTheme:timeline.settings.layout.label",
      "default": "vertical",
      "options": [
        {
          "value": "vertical",
          "label": "tTheme:timeline.settings.layout.options.vertical"
        },
        {
          "value": "horizontal",
          "label": "tTheme:timeline.settings.layout.options.horizontal"
        },
        {
          "value": "centered",
          "label": "tTheme:timeline.settings.layout.options.centered"
        }
      ]
    },
    {
      "type": "header",
      "id": "appearance_header",
      "label": "tTheme:global.widgets.settings.appearance_header.label"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard-primary",
      "options": [
        {
          "value": "standard-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_primary"
        },
        {
          "value": "standard-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_secondary"
        },
        {
          "value": "highlight-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_primary"
        },
        {
          "value": "highlight-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_secondary"
        }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.top_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.top_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.top_spacing.options.none"
        }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.none"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "displayName": "tTheme:timeline.blocks.item.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "date",
          "label": "tTheme:timeline.blocks.item.settings.date.label",
          "default": "Week  1"
        },
        {
          "type": "text",
          "id": "duration",
          "label": "tTheme:timeline.blocks.item.settings.duration.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:timeline.blocks.item.settings.title.label",
          "default": "Discovery"
        },
        {
          "type": "textarea",
          "id": "features",
          "label": "tTheme:timeline.blocks.item.settings.features.label",
          "description": "tTheme:timeline.blocks.item.settings.features.description"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "tTheme:timeline.blocks.item.settings.description.label"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "item",
      "settings": {
        "date": "Phase 1",
        "duration": "Week 1-2",
        "title": "Discovery & Planning",
        "description": "<p>We analyze your requirements and create a detailed project roadmap.</p>",
        "features": "Stakeholder interviews\nRequirements gathering\nProject timeline creation"
      }
    },
    {
      "type": "item",
      "settings": {
        "date": "Phase 2",
        "duration": "Week 3-5",
        "title": "Design & Prototyping",
        "description": "<p>Our designers create stunning mockups and interactive prototypes.</p>",
        "features": "UI/UX design\nInteractive prototypes\nDesign review sessions"
      }
    },
    {
      "type": "item",
      "settings": {
        "date": "Phase 3",
        "duration": "Week 6-10",
        "title": "Development",
        "description": "<p>Our developers bring the designs to life with clean, efficient code.</p>",
        "features": "Frontend development\nBackend integration\nQuality assurance"
      }
    },
    {
      "type": "item",
      "settings": {
        "date": "Phase 4",
        "duration": "Week 11-12",
        "title": "Launch & Support",
        "description": "<p>We deploy your project and provide ongoing support and maintenance.</p>",
        "features": "Production deployment\nPerformance optimization\nOngoing support"
      }
    }
  ]
}

            {
              "value": "9xl",
              "label": "tTheme:split_hero.blocks.heading.settings.size.options.9xl"
            }
          ]
        }
      ]
    },
    {
      "type": "text",
      "displayName": "tTheme:split_hero.blocks.text.name",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "tTheme:split_hero.blocks.text.settings.text.label",
          "default": "<p>A paragraph of descriptive text goes here.</p>"
        },
        {
          "type": "select",
          "id": "size",
          "label": "tTheme:split_hero.blocks.text.settings.size.label",
          "default": "base",
          "options": [
            {
              "value": "sm",
              "label": "tTheme:split_hero.blocks.text.settings.size.options.sm"
            },
            {
              "value": "base",
              "label": "tTheme:split_hero.blocks.text.settings.size.options.base"

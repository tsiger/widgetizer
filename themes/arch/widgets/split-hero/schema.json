{
  "type": "split-hero",
  "displayName": "tTheme:split_hero.name",
  "aliases": [
    "hero split",
    "background hero",
    "split banner",
    "full width hero"
  ],
  "settings": [
    {
      "type": "header",
      "id": "content_header",
      "label": "tTheme:split_hero.settings.content_header.label"
    },
    {
      "type": "image",
      "id": "image",
      "label": "tTheme:split_hero.settings.image.label"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "tTheme:split_hero.settings.overlay_color.label",
      "default": "",
      "allow_alpha": true,
      "description": "tTheme:split_hero.settings.overlay_color.description"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:split_hero.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "tTheme:split_hero.settings.image_position.label",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "tTheme:split_hero.settings.image_position.options.left"
        },
        {
          "value": "right",
          "label": "tTheme:split_hero.settings.image_position.options.right"
        }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:split_hero.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:split_hero.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:split_hero.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "displayName": "tTheme:split_hero.blocks.heading.name",

  "defaultBlocks": [
    {
      "type": "text",
      "settings": {
        "text": "Our Approach",
        "size": "sm",
        "uppercase": false,
        "muted": true
      }
    },
    {
      "type": "heading",
      "settings": {
        "text": "Built for Modern Teams",
        "size": "2xl"
      }
    },
    {
      "type": "text",
      "settings": {
        "text": "<p>We combine cutting-edge technology with proven methodologies to deliver exceptional results. Our platform is designed to help teams collaborate more effectively and achieve their goals faster.</p>",
        "size": "base",
        "uppercase": false,
        "muted": false
      }
    },
    {
      "type": "button",
      "settings": {
        "link": {
          "text": "Learn More",
          "href": "#",
          "target": "_self"
        },
        "style": "primary",
        "link_2": {
          "text": "Get Started",
          "href": "#",
          "target": "_self"
        },
        "style_2": "secondary"
      }

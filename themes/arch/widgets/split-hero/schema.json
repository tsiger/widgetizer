            "text": "Learn More",
            "href": "#",
            "target": "_self"
          }
        },
        {
          "type": "select",
          "id": "style",
          "label": "tTheme:split_hero.blocks.button.settings.style.label",
          "default": "secondary",
          "options": [
            {
              "value": "primary",
              "label": "tTheme:split_hero.blocks.button.settings.style.options.primary"
            },
            {
              "value": "secondary",
              "label": "tTheme:split_hero.blocks.button.settings.style.options.secondary"
            }
          ]
        },
        {
          "type": "link",
          "id": "link_2",
          "label": "tTheme:split_hero.blocks.button.settings.link_2.label"
        },
        {
          "type": "select",
          "id": "style_2",
          "label": "tTheme:split_hero.blocks.button.settings.style_2.label",
          "default": "secondary",
          "options": [
            {
              "value": "primary",
              "label": "tTheme:split_hero.blocks.button.settings.style_2.options.primary"
            },
            {
              "value": "secondary",
              "label": "tTheme:split_hero.blocks.button.settings.style_2.options.secondary"
            }
          ]
        },
        {
          "type": "select",
          "id": "size",
          "label": "tTheme:split_hero.blocks.button.settings.size.label",
          "default": "medium",
          "options": [
            {
              "value": "small",
              "label": "tTheme:split_hero.blocks.button.settings.size.options.small"
            },
            {
              "value": "medium",
              "label": "tTheme:split_hero.blocks.button.settings.size.options.medium"
            },
            {
              "value": "large",
              "label": "tTheme:split_hero.blocks.button.settings.size.options.large"
            },
            {
              "value": "xlarge",
              "label": "tTheme:split_hero.blocks.button.settings.size.options.xlarge"
            }
          ]
        }
      ]
    }

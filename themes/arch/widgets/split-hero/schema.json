            {
              "value": "4xl",
              "label": "tTheme:split_hero.blocks.heading.settings.size.options.4xl"
            },
            {
              "value": "5xl",
              "label": "tTheme:split_hero.blocks.heading.settings.size.options.5xl"
            },
            {
              "value": "6xl",
              "label": "tTheme:split_hero.blocks.heading.settings.size.options.6xl"
            },
            {
              "value": "7xl",
              "label": "tTheme:split_hero.blocks.heading.settings.size.options.7xl"

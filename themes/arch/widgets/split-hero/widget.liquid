{% assign has_countdown = false %}
{% for blockId in widget.blocksOrder %}
  {% assign block = widget.blocks[blockId] %}
  {% if block.type == 'countdown' %}
    {% assign has_countdown = true %}
    {% break %}
  {% endif %}
{% endfor %}
{% if has_countdown %}
  {% enqueue_script src: "countdown.js", defer: true, theme: true %}
{% endif %}
<section
  id="{{ widget.id }}"
  class="widget widget-split-hero widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}{% unless widget.settings.color_scheme == 'standard-primary' %} has-highlight-background{% endunless %}{% if widget.settings.image_position == 'end' %} layout-image-end{% endif %}{% if widget.settings.top_spacing != 'auto' %} spacing-top-{{ widget.settings.top_spacing }}{% endif %}{% if widget.settings.bottom_spacing != 'auto' %} spacing-bottom-{{ widget.settings.bottom_spacing }}{% endif %}"
  data-widget-id="{{ widget.id }}"
  data-widget-type="split-hero"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      /* Full viewport width - break out of container constraints */
      margin-block: 0;
      padding-inline: 0;
      position: relative;
      width: 100%;
      margin-inline: 0;
      max-width: none;

      &.has-highlight-background {
        --widget-bg-color: var(--bg-primary);
      }

      & .widget-container {
        max-width: none;
        margin-inline: 0;
      }

      & .split-hero-wrapper {
        display: flex;
        flex-direction: column;
        min-height: 50rem; /* Minimum height for hero section */
        width: 100%;
        margin: 0;
        padding: 0;
      }

      & .split-hero-image {
        width: 100%;
        min-height: 30rem;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        position: relative;
        margin: 0;
        padding: 0;
      }

      & .split-hero-overlay {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
      }

      & .split-hero-content {
        width: 100%;
        padding: var(--space-xl) var(--space-md);
      }

      @media (min-width: 990px) {
        & .split-hero-wrapper {
          flex-direction: row;
          min-height: 60rem;
        }

        & .split-hero-image {
          width: 50%;
          min-height: 60rem;
          flex-shrink: 0;
        }

        & .split-hero-content {
          width: 50%;
          padding: var(--space-4xl) var(--space-3xl);
          display: flex;
          align-items: center;
          flex-shrink: 0;
        }

        & .split-hero-content .widget-content {
          max-width: var(--content-width-md);
          width: 100%;
        }

        /* Image right variant */
        &.layout-image-end .split-hero-wrapper {
          flex-direction: row-reverse;
        }
      }
    }
  </style>

  <div class="widget-container">
    <div class="split-hero-wrapper">
    <!-- Background Image Section (50%) -->
    {% if widget.settings.image != blank %}
      <div class="split-hero-image reveal reveal-fade" style="background-image: url('{% image src: widget.settings.image, size: 'large', output: 'url' %}');">
        {% if widget.settings.overlay_color != blank %}
          <div class="split-hero-overlay" style="background-color: {{ widget.settings.overlay_color }};"></div>
        {% endif %}
      </div>
    {% else %}
      <div class="split-hero-image reveal reveal-fade" style="background-image: url({% placeholder_image aspect: 'landscape', output: 'url' %});">
        {% if widget.settings.overlay_color != blank %}
          <div class="split-hero-overlay" style="background-color: {{ widget.settings.overlay_color }};"></div>
        {% endif %}
      </div>
    {% endif %}

    <!-- Content Section (50%) -->
    <div class="split-hero-content">
      <div class="widget-content content-flow widget-content-align-start">
        {% for blockId in widget.blocksOrder %}
          {% assign block = widget.blocks[blockId] %}
          {% case block.type %}
            {% when 'rating' %}
              {% assign rating = block.settings.rating | times: 1 %}
                <div class="widget-rating reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
                  <span class="widget-rating-stars" aria-hidden="true">
                    {% for i in (1..5) %}
                      {% if i <= rating %}
                        <span class="widget-rating-star">★</span>
                      {% else %}
                        <span class="widget-rating-star empty">★</span>
                      {% endif %}
                    {% endfor %}
                  </span>
                  <span class="visually-hidden">
                    Rated {{ rating }} out of 5
                  </span>
                </div>
            {% when 'image' %}
              <div class="widget-block-image reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}; --block-image-width: {{ block.settings.width }}%;" data-block-id="{{ blockId }}">
                {% if block.settings.image != blank %}
                  {% assign block_image_cap = block.settings.width | times: 9 %}
                  {% capture block_image_sizes %}(max-width: 900px) {{ block.settings.width }}vw, {{ block_image_cap }}px{% endcapture %}
                  {% image src: block.settings.image, size: 'small', srcset: true, sizes: block_image_sizes %}
                {% else %}
                  {% placeholder_image aspect: 'square' %}
                {% endif %}
              </div>
            {% when 'heading' %}
              {% assign size_class = 't-' | append: block.settings.size %}
              {% if widget.index == 1 %}
                <h1 class="w-headline {{ size_class }} reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}" data-setting="text">
                  {{ block.settings.text }}
                </h1>
              {% else %}
                <h2 class="w-headline {{ size_class }} reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}" data-setting="text">
                  {{ block.settings.text }}
                </h2>
              {% endif %}
            {% when 'text' %}
              {% assign size_class = 't-' | append: block.settings.size %}
              {% assign style_class = '' %}
              {% if block.settings.uppercase %}{% assign style_class = style_class | append: ' t-uppercase' %}{% endif %}
              {% if block.settings.muted %}{% assign style_class = style_class | append: ' t-muted' %}{% endif %}
              <div class="w-body w-rte {{ size_class }}{{ style_class }} reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}" data-setting="text">
                {{ block.settings.text | raw }}
              </div>
            {% when 'features' %}
              {% if block.settings.features != blank %}
                <ul class="features-list reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
                  {% assign normalized_features = block.settings.features | replace: '\r\n', '\n' %}
                  {% assign features_list = normalized_features | split: '\n' %}
                  {% for feature in features_list %}
                    {% assign trimmed_feature = feature | strip %}
                    {% if trimmed_feature != blank %}
                        {% assign feature_text = trimmed_feature %}
                        {% assign icon_name = '' %}
                        {% assign first_char = trimmed_feature | slice: 0, 1 %}
                        {% if first_char == '+' %}
                          {% assign icon_name = 'check' %}
                          {% assign feature_text = trimmed_feature | remove_first: '+' | strip %}
                        {% elsif first_char == '-' %}
                          {% assign icon_name = 'x' %}
                          {% assign feature_text = trimmed_feature | remove_first: '-' | strip %}
                        {% endif %}
                      <li class="feature-item w-body">
                        {% if icon_name != blank %}
                          <span class="feature-icon">
                            {% render 'icon', icon: icon_name, class: 'feature-icon-svg' %}
                          </span>
                        {% endif %}
                        <span>{{ feature_text }}</span>
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              {% endif %}
            {% when 'icon' %}
              <div class="reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
                {% if block.settings.icon != blank %}
                  {% render 'icon', icon: block.settings.icon, class: 'w-icon', style: block.settings.style, size: block.settings.size, shape: block.settings.shape %}
                {% endif %}
              </div>
            {% when 'numbered-item' %}
              {% assign numbered_counter = numbered_counter | plus: 1 %}
              <div class="numbered-item reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
                <span class="numbered-item-circle numbered-item-circle-{{ block.settings.size }} numbered-item-shape-{{ block.settings.shape }}" aria-hidden="true">{{ numbered_counter }}</span>
                <div class="numbered-item-content">
                  {% if block.settings.title != blank %}
                    <span class="w-title t-lg t-heading-font" data-setting="title">{{ block.settings.title }}</span>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <span class="w-body t-sm t-muted" data-setting="description">{{ block.settings.description }}</span>
                  {% endif %}
                </div>
              </div>
            {% when 'countdown' %}
              <div class="countdown-timer reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}"
                data-target="{{ block.settings.target_date }}"
                data-expired-message="{{ block.settings.expired_message }}"
                data-show-seconds="{{ block.settings.show_seconds }}"
              >
                <div class="countdown-unit">
                  <span class="countdown-number" data-unit="days">00</span>
                  <span class="countdown-label w-meta t-sm">Days</span>
                </div>
                <span class="countdown-separator t-4xl t-muted">:</span>
                <div class="countdown-unit">
                  <span class="countdown-number" data-unit="hours">00</span>
                  <span class="countdown-label w-meta t-sm">Hours</span>
                </div>
                <span class="countdown-separator t-4xl t-muted">:</span>
                <div class="countdown-unit">
                  <span class="countdown-number" data-unit="minutes">00</span>
                  <span class="countdown-label w-meta t-sm">Minutes</span>
                </div>
                {% if block.settings.show_seconds %}
                  <span class="countdown-separator t-4xl t-muted">:</span>
                  <div class="countdown-unit">
                    <span class="countdown-number" data-unit="seconds">00</span>
                    <span class="countdown-label w-meta t-sm">Seconds</span>
                  </div>
                {% endif %}
              </div>
            {% when 'button' %}
              {% if block.settings.link.text != blank or block.settings.link_2.text != blank %}
                <div class="widget-actions reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
                  {% if block.settings.link.text != blank %}
                    {% if block.settings.size != 'small' and block.settings.size != blank %}
                      {% assign size_class = 'widget-button-' | append: block.settings.size %}
                    {% else %}
                      {% assign size_class = '' %}
                    {% endif %}
                    <a
                      href="{{ block.settings.link.href }}"
                      class="widget-button {{ size_class }} {% if block.settings.style == 'primary' %}widget-button-primary{% else %}widget-button-secondary{% endif %}"
                      data-setting="link"
                      {% if block.settings.link.target == '_blank' %}
                        target="_blank" rel="noopener"
                      {% endif %}
                    >
                      {{ block.settings.link.text }}
                    </a>
                  {% endif %}
                  {% if block.settings.link_2.text != blank %}
                    {% if block.settings.size != 'small' and block.settings.size != blank %}
                      {% assign size_class = 'widget-button-' | append: block.settings.size %}
                    {% else %}
                      {% assign size_class = '' %}
                    {% endif %}
                    <a
                      href="{{ block.settings.link_2.href }}"
                      class="widget-button {{ size_class }} {% if block.settings.style_2 == 'primary' %}widget-button-primary{% else %}widget-button-secondary{% endif %}"
                      data-setting="link_2"
                      {% if block.settings.link_2.target == '_blank' %}
                        target="_blank" rel="noopener"
                      {% endif %}
                    >
                      {{ block.settings.link_2.text }}
                    </a>
                  {% endif %}
                </div>
              {% endif %}
          {% endcase %}
        {% endfor %}
      </div>
    </div>
    </div>
  </div>
</section>

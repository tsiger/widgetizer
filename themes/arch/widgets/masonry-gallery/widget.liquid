{% enqueue_script src: "masonry.js", defer: true, location: "footer", priority: 40, theme: true %}
{% enqueue_script src: "lightbox.js", defer: true, location: "footer", priority: 41, theme: true %}
<section
  id="{{ widget.id }}"
  class="widget widget-type-masonry-gallery widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}{% if widget.settings.top_spacing != 'auto' %} spacing-top-{{ widget.settings.top_spacing }}{% endif %}{% if widget.settings.bottom_spacing != 'auto' %} spacing-bottom-{{ widget.settings.bottom_spacing }}{% endif %}"
  {% unless widget.settings.color_scheme == 'standard-primary' %}
    style="--widget-bg-color: var(--bg-primary);"
  {% endunless %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="masonry-gallery"
  data-masonry-cols="{{ widget.settings.columns_desktop | default: 3 }}"
  data-masonry-gap="{{ widget.settings.gap | default: 'medium' }}"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      & .masonry-grid {
        position: relative;
      }

      & .widget-card {
        position: absolute;
        padding: 0;
        overflow: hidden;
        box-sizing: border-box;
        visibility: hidden;
        cursor: pointer;

        &:hover .widget-card-image {
          opacity: 0.9;
        }
      }

      & .widget-card.is-positioned {
        visibility: visible;
      }

      & .widget-card-image {
        width: 100%;
        height: auto;
        aspect-ratio: auto;
        object-fit: unset;
        display: block;
        transition: opacity 0.3s;
        margin-block-end: 0;
        border-radius: 0;
      }

      & .widget-card-content {
        padding: var(--space-md);
      }

      & .widget-card-category {
        margin: 0;
      }

      &.color-scheme-standard-secondary,
      &.color-scheme-highlight-secondary {
        & .widget-card {
          background-color: var(--bg-secondary);
        }
      }

      &.color-scheme-standard-secondary,
      &.color-scheme-highlight-primary,
      &.color-scheme-highlight-secondary {
        & .widget-card {
          border: var(--border-width-thin) solid var(--border-color);
        }
      }
    }
  </style>

  <div class="widget-container {% unless widget.settings.color_scheme == 'standard-primary' %}widget-container-padded{% endunless %}">
    {% if widget.settings.title != blank or widget.settings.description != blank or widget.settings.eyebrow != blank %}
      <div class="widget-header{% if widget.settings.heading_alignment == 'start' %} widget-header--align-start{% endif %}">
        {% assign header_delay = 0 %}
        {% if widget.settings.eyebrow != blank %}
          <span class="w-eyebrow reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.title != blank %}
          {% if widget.index == 1 %}
            <h1 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h1>
          {% else %}
            <h2 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h2>
          {% endif %}
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.description != blank %}
          <p class="w-description reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="description">{{ widget.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="widget-content">
      <div class="masonry-grid">
        {% assign item_heading_level = 'h3' %}
        {% if widget.settings.title == blank %}
          {% assign item_heading_level = 'h2' %}
        {% endif %}

        {% for blockId in widget.blocksOrder %}
          {% assign block = widget.blocks[blockId] %}
          <div class="widget-card reveal reveal-fade" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}" data-caption="{{ block.settings.title }}">
            {% if block.settings.image != blank %}
              {% image src: block.settings.image, size: 'medium', srcset: true, sizes: '(max-width: 749px) 100vw, 400px', class: 'widget-card-image' %}
            {% else %}
              {% assign aspect_index = forloop.index | modulo: 3 %}
              {% if aspect_index == 1 %}
                {% placeholder_image aspect: 'portrait', class: 'widget-card-image' %}
              {% elsif aspect_index == 2 %}
                {% placeholder_image aspect: 'landscape', class: 'widget-card-image' %}
              {% else %}
                {% placeholder_image aspect: 'square', class: 'widget-card-image' %}
              {% endif %}
            {% endif %}
            {% if block.settings.title != blank or block.settings.category != blank %}
              <div class="widget-card-content">
                {% if block.settings.title != blank %}
                  <{{ item_heading_level }} class="w-title t-xl" data-setting="title">{{ block.settings.title }}</{{ item_heading_level }}>
                {% endif %}
                {% if block.settings.category != blank %}
                  <p class="widget-card-category w-meta t-sm" data-setting="category">{{ block.settings.category }}</p>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

</section>

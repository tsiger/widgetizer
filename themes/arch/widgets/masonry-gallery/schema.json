{
  "type": "masonry-gallery",
  "displayName": "tTheme:masonry_gallery.name",
  "aliases": [
    "pinterest style",
    "dynamic grid",
    "auto layout",
    "photo grid"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:masonry_gallery.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:masonry_gallery.settings.title.label",
      "default": "Our Work"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:masonry_gallery.settings.description.label",
      "default": "A collection of our recent projects and creative work."
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:masonry_gallery.settings.display_header.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "tTheme:masonry_gallery.settings.columns_desktop.label",
      "default": 3,
      "min": 2,
      "max": 5,
      "step": 1
    },
    {
      "type": "select",
      "id": "gap",
      "label": "tTheme:masonry_gallery.settings.gap.label",
      "default": "medium",
      "options": [
        {
          "value": "small",
          "label": "tTheme:masonry_gallery.settings.gap.options.small"
        },
        {
          "value": "medium",
          "label": "tTheme:masonry_gallery.settings.gap.options.medium"
        },
        {
          "value": "large",
          "label": "tTheme:masonry_gallery.settings.gap.options.large"
        }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:masonry_gallery.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:masonry_gallery.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:masonry_gallery.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "displayName": "tTheme:masonry_gallery.blocks.item.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:masonry_gallery.blocks.item.settings.content_header.label"
        },
        {
          "type": "image",
          "id": "image",
          "label": "tTheme:masonry_gallery.blocks.item.settings.image.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:masonry_gallery.blocks.item.settings.title.label"
        },
        {
          "type": "text",
          "id": "category",
          "label": "tTheme:masonry_gallery.blocks.item.settings.category.label"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "item",
      "settings": {
        "title": "Mountain Retreat",
        "category": "Architecture"
      }
    },
    {
      "type": "item",
      "settings": {
        "title": "Urban Renewal",
        "category": "Branding"
      }
    },
    {
      "type": "item",
      "settings": {
        "title": "Coastal Living",
        "category": "Interior Design"
      }
    },
    {
      "type": "item",
      "settings": {
        "title": "Tech Campus",
        "category": "Commercial"
      }
    },
    {
      "type": "item",
      "settings": {
        "title": "Art Gallery",
        "category": "Cultural"
      }
    },
    {
      "type": "item",
      "settings": {
        "title": "Lakeside Villa",
        "category": "Residential"
      }
    }
  ]
}

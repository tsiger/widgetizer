        {
          "type": "textarea",
          "id": "features",
          "label": "tTheme:global.widgets.blocks.features.settings.features.label",
          "description": "tTheme:global.widgets.blocks.features.settings.features.description",
          "default": "+ Feature 1\n+ Feature 2\n+ Feature 3"
        }
      ]
    },
    {
      "type": "button",
      "displayName": "tTheme:global.widgets.blocks.button.name",

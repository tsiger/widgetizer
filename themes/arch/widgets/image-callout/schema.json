{
  "type": "image-callout",
  "displayName": "tTheme:image_callout.name",
  "aliases": [
    "cta image",
    "visual lead",
    "promotion",
    "highlight image"
  ],
  "settings": [
    {
      "type": "header",
      "id": "content_header",
      "label": "tTheme:global.widgets.settings.content_header.label"
    },
    {
      "type": "image",
      "id": "image",
      "label": "tTheme:image_callout.settings.image.label"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "tTheme:global.widgets.settings.image_position.label",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "tTheme:global.widgets.settings.image_position.options.left"
        },
        {
          "value": "right",
          "label": "tTheme:global.widgets.settings.image_position.options.right"
        }
      ]
    },
    {
      "type": "header",
      "id": "widget_header",
      "label": "Widget"

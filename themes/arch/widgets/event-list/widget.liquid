<section
  id="{{ widget.id }}"
  class="widget widget-type-event-list widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}{% if widget.settings.top_spacing != 'auto' %} spacing-top-{{ widget.settings.top_spacing }}{% endif %}{% if widget.settings.bottom_spacing != 'auto' %} spacing-bottom-{{ widget.settings.bottom_spacing }}{% endif %}"
  {% unless widget.settings.color_scheme == 'standard-primary' %}
    style="--widget-bg-color: var(--bg-primary);"
  {% endunless %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="event-list"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      & .event-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-xl);
      }

      & .widget-card {
        gap: var(--space-lg);
      }

      & .event-date {
        flex-shrink: 0;
        width: 8rem;
        height: 8rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        border: var(--border-width-medium) solid var(--border-color);
        border-radius: var(--radius-sm);
        text-align: center;
        align-self: flex-start;
      }

      & .event-date-day {
        font-size: calc(var(--font-size-4xl) * var(--heading-scale));
      }

      & .event-date-month {
        margin-block-start: var(--space-xs);
      }

      &.color-scheme-standard-secondary,
      &.color-scheme-highlight-secondary {
        & .widget-card {
          background-color: var(--bg-secondary);
        }
      }

      &.color-scheme-standard-secondary,
      &.color-scheme-highlight-primary,
      &.color-scheme-highlight-secondary {
        & .widget-card {
          border: var(--border-width-thin) solid var(--border-color);
        }
      }

      @media (min-width: 750px) {
        & .widget-card {
          flex-direction: row;
          gap: var(--space-2xl);
          padding: var(--space-2xl);
        }

        & .event-date {
          width: 10rem;
          height: 10rem;
        }
      }
    }
  </style>

  <div class="widget-container {% unless widget.settings.color_scheme == 'standard-primary' %}widget-container-padded{% endunless %}">
    {% if widget.settings.title != blank or widget.settings.description != blank or widget.settings.eyebrow != blank %}
      <div class="widget-header{% if widget.settings.heading_alignment == 'left' %} widget-header--align-start{% endif %}">
        {% assign header_delay = 0 %}
        {% if widget.settings.eyebrow != blank %}
          <span class="w-eyebrow reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.title != blank %}
          {% if widget.index == 1 %}
            <h1 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h1>
          {% else %}
            <h2 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h2>
          {% endif %}
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.description != blank %}
          <p class="w-description reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="description">{{ widget.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="widget-content">
      <ul class="event-list">
        {% assign item_heading_level = 'h3' %}
        {% if widget.settings.title == blank %}
          {% assign item_heading_level = 'h2' %}
        {% endif %}

        {% for blockId in widget.blocksOrder %}
          {% assign block = widget.blocks[blockId] %}
          <li class="widget-card reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
            <div class="event-date">
              <span class="event-date-day t-4xl t-body-bold t-heading" data-setting="day">{{ block.settings.day }}</span>
              <span class="event-date-month w-meta t-sm" data-setting="month">{{ block.settings.month }}</span>
            </div>
            <div class="widget-card-content">
              {% if block.settings.title != blank %}
                <{{ item_heading_level }} class="w-title t-2xl" data-setting="title">{{ block.settings.title }}</{{ item_heading_level }}>
              {% endif %}
              {% if block.settings.location != blank %}
                <p class="w-meta" data-setting="location">{{ block.settings.location }}</p>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="w-body w-rte t-sm" data-setting="description">{{ block.settings.description | raw }}</div>
              {% endif %}
              {% if block.settings.button_link.text != blank %}
                <div class="widget-card-footer">
                  <a
                    href="{{ block.settings.button_link.href }}"
                    class="widget-button widget-button-secondary"
                    data-setting="button_link"
                    {% if block.settings.button_link.target == '_blank' %}
                      target="_blank" rel="noopener"
                    {% endif %}
                  >
                    {{ block.settings.button_link.text }}
                  </a>
                </div>
              {% endif %}
            </div>
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

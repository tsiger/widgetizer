{
  "type": "countdown",
  "displayName": "tTheme:countdown.name",
  "aliases": [
    "timer",
    "launch date",
    "offer ends",
    "deadline"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "Coming Soon"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label"
    },
    {
      "type": "header",
      "id": "content_header",
      "label": "tTheme:global.widgets.settings.content_header.label"
    },
    {
      "type": "text",
      "id": "target_date",
      "label": "tTheme:countdown.settings.target_date.label",
      "default": "2027-01-01 00:00"
    },
    {
      "type": "text",
      "id": "expired_message",
      "label": "tTheme:countdown.settings.expired_message.label",
      "default": "The wait is over!"
    },
    {
      "type": "link",
      "id": "button",
      "label": "tTheme:countdown.settings.button.label"
    },
    {
      "type": "header",
      "id": "options_header",
      "label": "tTheme:global.widgets.settings.options_header.label"
    },
    {
      "type": "checkbox",
      "id": "show_seconds",
      "label": "tTheme:countdown.settings.show_seconds.label",
      "default": true
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "style",
      "label": "tTheme:countdown.settings.style.label",
      "options": [
        {
          "value": "cards",
          "label": "tTheme:countdown.settings.style.options.cards"
        },
        {
          "value": "minimal",
          "label": "tTheme:countdown.settings.style.options.minimal"
        }
      ],
      "default": "cards"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight"
        }
      ]
    }
  ]
}

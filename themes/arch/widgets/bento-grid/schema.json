{
  "type": "bento-grid",
  "displayName": "tTheme:bento_grid.name",
  "aliases": [
    "dashboard",
    "tiles",
    "highlights",
    "featured grid",
    "masonry"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "Feature Spotlight"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "start",
          "label": "tTheme:global.widgets.settings.alignment.options.start"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.alignment.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "gap",
      "label": "tTheme:bento_grid.settings.gap.label",
      "default": "var(--space-md)",
      "options": [
        {
          "value": "0",
          "label": "tTheme:bento_grid.settings.gap.options.0"
        },
        {
          "value": "var(--space-sm)",
          "label": "tTheme:bento_grid.settings.gap.options.var(--space-sm)"
        },
        {
          "value": "var(--space-md)",
          "label": "tTheme:bento_grid.settings.gap.options.var(--space-md)"
        },
        {
          "value": "var(--space-lg)",
          "label": "tTheme:bento_grid.settings.gap.options.var(--space-lg)"
        },
        {
          "value": "var(--space-xl)",
          "label": "tTheme:bento_grid.settings.gap.options.var(--space-xl)"
        }
      ]
    },
    {
      "type": "header",
      "id": "widget_header",
      "label": "Widget"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard-primary",
      "options": [
        {
          "value": "standard-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_primary"
        },
        {
          "value": "standard-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_secondary"
        },
        {
          "value": "highlight-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_primary"
        },
        {
          "value": "highlight-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_secondary"
        }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.top_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.top_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.top_spacing.options.none"
        }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.none"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "displayName": "tTheme:bento_grid.blocks.item.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:bento_grid.blocks.item.settings.title.label",
          "default": "Bento Tile"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "tTheme:bento_grid.blocks.item.settings.text.label",
          "default": "Describe this featured item here."
        },
        {
          "type": "image",
          "id": "image",
          "label": "tTheme:global.widgets.settings.background_image.label"
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "tTheme:global.widgets.settings.overlay_color.label",
          "default": "#0a1e38bf",
          "allow_alpha": true,
          "description": "tTheme:global.widgets.settings.overlay_color.description"
        },
        {
          "type": "link",
          "id": "link",
          "label": "tTheme:global.widgets.settings.link.label",
          "hide_text": true
        },
        {
          "type": "header",
          "id": "layout_header",
          "label": "tTheme:bento_grid.blocks.item.settings.layout_header.label"
        },
        {
          "type": "range",
          "id": "col_span",
          "label": "tTheme:bento_grid.blocks.item.settings.col_span.label",
          "min": 1,
          "max": 4,
          "step": 1,
          "default": 1
        },
        {
          "type": "range",
          "id": "row_span",
          "label": "tTheme:bento_grid.blocks.item.settings.row_span.label",
          "min": 1,
          "max": 2,
          "step": 1,
          "default": 1
        },
        {
          "type": "header",
          "id": "display_header",
          "label": "tTheme:global.widgets.settings.display_header.label"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "tTheme:bento_grid.blocks.item.settings.background_color.label"
        },
        {
          "type": "select",
          "id": "text_color",
          "label": "tTheme:bento_grid.blocks.item.settings.text_color.label",
          "default": "dark",
          "options": [
            {
              "value": "dark",
              "label": "tTheme:bento_grid.blocks.item.settings.text_color.options.dark"
            },
            {
              "value": "light",
              "label": "tTheme:bento_grid.blocks.item.settings.text_color.options.light"
            }
          ]
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "tTheme:bento_grid.blocks.item.settings.alignment.label",
          "default": "start",
          "options": [
            {
              "value": "start",
              "label": "tTheme:global.widgets.settings.options.start"
            },
            {
              "value": "center",
              "label": "tTheme:global.widgets.settings.options.center"
            }
          ]
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "item",
      "settings": {
        "title": "Main Highlight",
        "text": "The centerpiece of your grid.",
        "col_span": 2,
        "row_span": 2,
        "background_color": "#000000",
        "text_color": "light"
      }
    },
    {
      "type": "item",
      "settings": {
        "title": "Feature 1",
        "text": "Compact detail.",
        "col_span": 1,
        "background_color": "#f3f4f6"
      }
    },
    {
      "type": "item",
      "settings": {
        "title": "Feature 2",
        "text": "Compact detail.",
        "col_span": 1,
        "background_color": "#e5e7eb"
      }
    },
    {
      "type": "item",
      "settings": {
        "title": "Wide Strip",
        "text": "Spanning across.",
        "col_span": 2,
        "background_color": "#d1d5db"
      }
    }
  ]
}

{
  "type": "comparison-slider",
  "displayName": "tTheme:comparison_slider.name",
  "aliases": [
    "before after",
    "visual comparison",
    "image slider",
    "compare"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "See the Transformation"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label"
    },
    {
      "type": "image",
      "id": "before_image",
      "label": "tTheme:comparison_slider.settings.before_image.label"
    },
    {
      "type": "image",
      "id": "after_image",
      "label": "tTheme:comparison_slider.settings.after_image.label"
    },
    {
      "type": "header",
      "id": "labels_header",
      "label": "tTheme:global.widgets.settings.labels_header.label"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "tTheme:comparison_slider.settings.before_label.label",
      "default": "Before"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "tTheme:comparison_slider.settings.after_label.label",
      "default": "After"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "orientation",
      "label": "tTheme:comparison_slider.settings.orientation.label",
      "default": "horizontal",
      "options": [
        {
          "value": "horizontal",
          "label": "tTheme:comparison_slider.settings.orientation.options.horizontal"
        },
        {
          "value": "vertical",
          "label": "tTheme:comparison_slider.settings.orientation.options.vertical"
        }
      ]
    },
    {
      "type": "range",
      "id": "initial_position",
      "label": "tTheme:comparison_slider.settings.initial_position.label",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%"
    },
    {
      "type": "checkbox",
      "id": "show_labels",
      "label": "tTheme:comparison_slider.settings.show_labels.label",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight"
        }
      ]
    }
  ]
}

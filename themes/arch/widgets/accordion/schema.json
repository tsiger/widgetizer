{
  "type": "accordion",
  "displayName": "tTheme:accordion.name",
  "aliases": [
    "faq",
    "details",
    "toggle",
    "collapsible"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label",
      "default": "Support"
    },
    {
      "type": "checkbox",
      "id": "eyebrow_uppercase",
      "label": "tTheme:global.widgets.settings.eyebrow_uppercase.label",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label",
      "default": "Everything you need to know about the product and billing."
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "start",
          "label": "tTheme:global.widgets.settings.alignment.options.start"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.alignment.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "style",
      "label": "tTheme:accordion.settings.style.label",
      "default": "separated",
      "options": [
        {
          "value": "separated",
          "label": "tTheme:accordion.settings.style.options.separated"
        },
        {
          "value": "connected",
          "label": "tTheme:accordion.settings.style.options.connected"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "allow_multiple",
      "label": "tTheme:accordion.settings.allow_multiple.label",
      "default": false
    },
    {
      "type": "select",
      "id": "sidebar_position",
      "label": "tTheme:global.widgets.settings.sidebar_position.label",
      "default": "end",
      "options": [
        {
          "value": "start",
          "label": "tTheme:global.widgets.settings.options.start"
        },
        {
          "value": "end",
          "label": "tTheme:global.widgets.settings.options.end"
        }
      ]
    },
    {
      "type": "header",
      "id": "widget_header",
      "label": "Widget"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard-primary",
      "options": [
        {
          "value": "standard-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_primary"
        },
        {
          "value": "standard-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_secondary"
        },
        {
          "value": "highlight-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_primary"
        },
        {
          "value": "highlight-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_secondary"
        }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.top_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.top_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.top_spacing.options.none"
        }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.none"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "displayName": "tTheme:accordion.blocks.item.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "question",
          "label": "tTheme:accordion.blocks.item.settings.question.label",
          "default": "Question goes here"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "tTheme:accordion.blocks.item.settings.answer.label",
          "default": "<p>Answer goes here</p>"
        }
      ]
    },
    {
      "type": "info",
      "displayName": "tTheme:global.widgets.blocks.info.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:global.widgets.blocks.info.settings.title.label",
          "default": "Need Help?"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "tTheme:global.widgets.blocks.info.settings.text.label",
          "default": "<p>hello@example.com</p>"
        }
      ]
    },
    {
      "type": "social",
      "displayName": "tTheme:global.widgets.blocks.social.name",
      "settings": []
    }
  ],
  "defaultBlocks": [
    {
      "type": "item",
      "settings": {
        "question": "What is the return policy?",
        "answer": "<p>We offer a 30-day money-back guarantee on all purchases. If you're not satisfied, simply contact our support team to initiate a return.</p>"
      }
    },
    {
      "type": "item",
      "settings": {
        "question": "Do you offer international shipping?",
        "answer": "<p>Yes, we ship to over 100 countries worldwide. Shipping times and costs vary by location and are calculated at checkout.</p>"
      }
    },
    {
      "type": "item",
      "settings": {
        "question": "Can I change my plan later?",
        "answer": "<p>Absolutely. You can upgrade or downgrade your subscription plan at any time from your account settings. Changes take effect immediately.</p>"
      }
    },
    {
      "type": "item",
      "settings": {
        "question": "Is technical support included?",
        "answer": "<p>Yes, all plans include 24/7 email support. Premium plans also include priority live chat and phone support options.</p>"
      }
    },
    {
      "type": "info",
      "settings": {
        "title": "Need Help?",
        "text": "<p>hello@example.com</p>"
      }
    }
  ]
}

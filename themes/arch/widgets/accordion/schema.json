{
  "type": "accordion",
  "displayName": "tTheme:accordion.name",
  "aliases": [
    "faq",
    "details",
    "toggle",
    "collapsible"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:accordion.settings.eyebrow.label",
      "default": "Support"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:accordion.settings.title.label",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:accordion.settings.description.label",
      "default": "Everything you need to know about the product and billing."
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:accordion.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "style",
      "label": "tTheme:accordion.settings.style.label",
      "default": "separated",
      "options": [
        {
          "value": "separated",
          "label": "tTheme:accordion.settings.style.options.separated"
        },
        {
          "value": "connected",
          "label": "tTheme:accordion.settings.style.options.connected"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "allow_multiple",
      "label": "tTheme:accordion.settings.allow_multiple.label",
      "default": false
    },
    {
      "type": "select",
      "id": "sidebar_position",
      "label": "tTheme:accordion.settings.sidebar_position.label",
      "default": "right",
      "options": [
        {
          "value": "left",
          "label": "tTheme:accordion.settings.sidebar_position.options.left"
        },
        {
          "value": "right",
          "label": "tTheme:accordion.settings.sidebar_position.options.right"
        }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:accordion.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:accordion.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:accordion.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "displayName": "tTheme:accordion.blocks.item.name",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "tTheme:accordion.blocks.item.settings.question.label",
          "default": "Question goes here"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "tTheme:accordion.blocks.item.settings.answer.label",
          "default": "<p>Answer goes here</p>"
        }
      ]
    },
    {
      "type": "info",
      "displayName": "tTheme:accordion.blocks.info.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:accordion.blocks.info.settings.title.label",
          "default": "Need Help?"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "tTheme:accordion.blocks.info.settings.text.label",
          "default": "<p>hello@example.com</p>"
        }
      ]
    },
    {
      "type": "social",
      "displayName": "tTheme:accordion.blocks.social.name",
      "settings": []
    }
  ],
  "defaultBlocks": [
    {
      "type": "item",
      "settings": {
        "question": "What is the return policy?",
        "answer": "<p>We offer a 30-day money-back guarantee on all purchases. If you're not satisfied, simply contact our support team to initiate a return.</p>"
      }
    },
    {
      "type": "item",
      "settings": {
        "question": "Do you offer international shipping?",
        "answer": "<p>Yes, we ship to over 100 countries worldwide. Shipping times and costs vary by location and are calculated at checkout.</p>"
      }
    },
    {
      "type": "item",
      "settings": {
        "question": "Can I change my plan later?",
        "answer": "<p>Absolutely. You can upgrade or downgrade your subscription plan at any time from your account settings. Changes take effect immediately.</p>"
      }
    },
    {
      "type": "item",
      "settings": {
        "question": "Is technical support included?",
        "answer": "<p>Yes, all plans include 24/7 email support. Premium plans also include priority live chat and phone support options.</p>"
      }
    },
    {
      "type": "info",
      "settings": {
        "title": "Need Help?",
        "text": "<p>hello@example.com</p>"
      }
    }
  ]
}

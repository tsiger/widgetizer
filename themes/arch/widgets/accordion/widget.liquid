{% assign has_sidebar_blocks = false %}
{% for blockId in widget.blocksOrder %}
  {% assign block = widget.blocks[blockId] %}
  {% if block.type == 'info' or block.type == 'social' %}
    {% assign has_sidebar_blocks = true %}
  {% endif %}
{% endfor %}

<section
  id="{{ widget.id }}"
  class="widget widget-accordion widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }} {% if widget.settings.style == 'connected' %}accordion-bordered{% endif %} {% if has_sidebar_blocks and widget.settings.sidebar_position == 'left' %}layout-reverse{% endif %}"
  {% unless widget.settings.color_scheme == 'standard' %}
    style="--widget-bg-color: var(--bg-primary);"
  {% endunless %}
  {% if widget.settings.allow_multiple %}
    data-multi-open="true"
  {% endif %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="accordion"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      & .accordion-content-wrapper {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-lg);
      }

      & .accordion-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
      }

      & .accordion-item {
        background-color: var(--bg-primary);
        border: var(--border-width-thin) solid var(--border-color);
        border-radius: var(--radius-sm);
        overflow: hidden;
      }

      &.color-scheme-standard-accent,
      &.color-scheme-highlight-accent {
        & .accordion-item {
          background-color: var(--bg-secondary);
        }
      }

      & .accordion-trigger {
        width: 100%;
        padding: var(--space-md) var(--space-lg);
        text-align: start;
        background: transparent;
        border: none;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--space-md);
        color: var(--text-heading);
        transition: background-color 0.2s;
        font-family: inherit;

        &:focus-visible {
          outline-offset: -0.2rem;
        }
      }

      & .accordion-question {
        flex: 1;
        text-align: start;
      }

      & .accordion-icon {
        width: 2.4rem;
        height: 2.4rem;
        flex-shrink: 0;
        transition: transform 0.3s ease;

        & svg {
          width: 100%;
          height: 100%;
        }
      }

      & .accordion-trigger[aria-expanded="true"] .accordion-icon {
        transform: rotate(180deg);
      }

      /* Grid-based collapse animation */
      & .accordion-collapse {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.3s ease-out;
      }

      & .accordion-collapse[aria-hidden="false"] {
        grid-template-rows: 1fr;
      }

      /* Inner wrapper handles overflow, padding stays constant */
      & .accordion-inner {
        min-height: 0;
        overflow: hidden;
      }

      /* Answer has constant padding, opacity transitions */
      & .accordion-answer {
        padding: 0 var(--space-lg) var(--space-lg) var(--space-lg);
        font-size: calc(var(--font-size-base) * var(--body-scale));
        opacity: 0;
        transform: translateY(-0.8rem);
        transition:
          opacity 0.25s ease-out,
          transform 0.25s ease-out;
      }

      & .accordion-collapse[aria-hidden="false"] .accordion-answer {
        opacity: 1;
        transform: translateY(0);
      }

      /* Sidebar */
      & .accordion-info {
        display: flex;
        flex-direction: column;
        gap: var(--space-xl);
      }

      & .accordion-info-block {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);
      }

      @media (min-width: 750px) {
        & .accordion-trigger {
          padding: var(--space-lg);
        }

        & .accordion-content-wrapper:not(.no-sidebar) {
          grid-template-columns: 7fr 3fr;
          gap: var(--space-3xl);
        }

        &.layout-reverse .accordion-content-wrapper:not(.no-sidebar) {
          grid-template-columns: 3fr 7fr;
        }

        &.layout-reverse .accordion-list-wrapper {
          order: 2;
        }

        &.layout-reverse .accordion-info {
          order: 1;
        }
      }

      /* Variation: Connected/Bordered */
      &.accordion-bordered {
        & .accordion-list {
          gap: 0;
          border: var(--border-width-thin) solid var(--border-color);
          border-radius: var(--radius-sm);
          overflow: hidden;
        }

        & .accordion-item {
          border: none;
          border-radius: 0;
          border-block-end: var(--border-width-thin) solid var(--border-color);

          &:last-child {
            border-block-end: none;
          }
        }
      }
    }
  </style>

  <div class="widget-container {% unless widget.settings.color_scheme == 'standard' %}widget-container-padded{% endunless %}">
    {% if widget.settings.title != blank or widget.settings.description != blank or widget.settings.eyebrow != blank %}
      <div class="widget-header{% if widget.settings.heading_alignment == 'left' %} widget-header--align-start{% endif %}">
        {% assign header_delay = 0 %}
        {% if widget.settings.eyebrow != blank %}
          <span class="w-eyebrow reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.title != blank %}
          {% if widget.index == 1 %}
            <h1 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h1>
          {% else %}
            <h2 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h2>
          {% endif %}
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.description != blank %}
          <p class="w-description reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="description">{{ widget.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="widget-content {% if has_sidebar_blocks %}{% else %}widget-content-md{% endif %}">
      <div class="accordion-content-wrapper {% unless has_sidebar_blocks %}no-sidebar{% endunless %}">
        <div class="accordion-list-wrapper">
          <ul class="accordion-list">
            {% for blockId in widget.blocksOrder %}
              {% assign block = widget.blocks[blockId] %}
              {% if block.type == 'item' %}
                <li class="accordion-item reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
                  <button
                    type="button"
                    class="accordion-trigger"
                    aria-expanded="false"
                    aria-controls="accordion-content-{{ widget.id }}-{{ blockId }}"
                    id="accordion-trigger-{{ widget.id }}-{{ blockId }}"
                  >
                    <span class="accordion-question w-title t-xl t-heading-font" data-setting="question">{{ block.settings.question }}</span>
                    <span class="accordion-icon">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M6 9l6 6 6-6" />
                      </svg>
                    </span>
                  </button>
                  <div
                    class="accordion-collapse"
                    id="accordion-content-{{ widget.id }}-{{ blockId }}"
                    role="region"
                    aria-labelledby="accordion-trigger-{{ widget.id }}-{{ blockId }}"
                    aria-hidden="true"
                  >
                    <div class="accordion-inner">
                      <div class="accordion-answer w-body w-rte" data-setting="answer">{{ block.settings.answer | raw }}</div>
                    </div>
                  </div>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>

        {% if has_sidebar_blocks %}
          <div class="accordion-info">
            {% for blockId in widget.blocksOrder %}
              {% assign block = widget.blocks[blockId] %}
              {% if block.type == 'info' %}
                <div class="accordion-info-block" data-block-id="{{ blockId }}">
                  {% if block.settings.title != blank %}
                    <h3 class="accordion-info-title w-title t-xl" data-setting="title">{{ block.settings.title }}</h3>
                  {% endif %}
                  {% if block.settings.text != blank %}
                    <div class="accordion-info-text w-body w-rte" data-setting="text">
                      {{ block.settings.text | raw }}
                    </div>
                  {% endif %}
                </div>
              {% elsif block.type == 'social' %}
                <div class="social-links" data-block-id="{{ blockId }}">
                  {% render 'social-icons', social: theme.social %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <script>
    (function () {
      const widget = document.getElementById('{{ widget.id }}');
      if (!widget || widget.dataset.initialized) return;
      widget.dataset.initialized = 'true';

      const isMultiOpen = widget.dataset.multiOpen === 'true';
      const triggers = widget.querySelectorAll('.accordion-trigger');

      triggers.forEach(function (trigger) {
        trigger.addEventListener('click', function () {
          const isExpanded = this.getAttribute('aria-expanded') === 'true';
          const content = this.nextElementSibling;

          if (!isMultiOpen) {
            // Close other items if not multi-open
            widget.querySelectorAll('.accordion-trigger').forEach(function (t) {
              if (t !== trigger) {
                t.setAttribute('aria-expanded', 'false');
                t.nextElementSibling.setAttribute('aria-hidden', 'true');
              }
            });
          }

          // Toggle current item
          this.setAttribute('aria-expanded', !isExpanded);
          content.setAttribute('aria-hidden', isExpanded);
        });
      });

      if (window.Widgetizer?.designMode) {
        widget.addEventListener('widget:block-select', (e) => {
          const { blockId } = e.detail;
          const item = widget.querySelector(`.accordion-item[data-block-id="${blockId}"]`);
          if (!item) return;
          const trigger = item.querySelector('.accordion-trigger');
          const content = item.querySelector('.accordion-collapse');
          if (!trigger || !content) return;
          if (trigger.getAttribute('aria-expanded') === 'true') return;

          if (!isMultiOpen) {
            widget.querySelectorAll('.accordion-trigger').forEach(function (t) {
              if (t !== trigger) {
                t.setAttribute('aria-expanded', 'false');
                t.nextElementSibling.setAttribute('aria-hidden', 'true');
              }
            });
          }

          trigger.setAttribute('aria-expanded', 'true');
          content.setAttribute('aria-hidden', 'false');
        });
      }
    })();
  </script>
</section>

<section
  id="{{ widget.id }}"
  class="widget widget-team-highlight widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}{% if widget.settings.top_spacing != 'auto' %} spacing-top-{{ widget.settings.top_spacing }}{% endif %}{% if widget.settings.bottom_spacing != 'auto' %} spacing-bottom-{{ widget.settings.bottom_spacing }}{% endif %}"
  {% unless widget.settings.color_scheme == 'standard-primary' %}
    style="--widget-bg-color: var(--bg-primary);"
  {% endunless %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="team-highlight"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      & .team-highlight-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-2xl);
      }

      & .team-highlight-intro {
        display: flex;
        flex-direction: column;
        gap: var(--space-sm);

        & > * {
          margin-block: 0;
        }
      }

      & .team-highlight-signature {
        max-width: 18rem;
        height: auto;
        margin-block-start: var(--space-md);
      }

      & .member-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: var(--space-xl) var(--space-lg);
        list-style: none;
        padding: 0;
        margin: 0;
      }

      & .member-card {
        display: flex;
        flex-direction: column;
      }

      & .member-photo-wrap {
        display: block;
        overflow: hidden;
        border-radius: var(--radius-md);
        margin-block-end: var(--space-sm);
        {% if widget.settings.image_ratio == 'portrait' %}
        aspect-ratio: 3 / 4;
        {% elsif widget.settings.image_ratio == 'square' %}
        aspect-ratio: 1 / 1;
        {% endif %}
      }

      & .member-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform var(--transition-speed-slow);
      }

      & .member-photo-placeholder {
        width: 100%;
        height: 100%;
        background: var(--bg-secondary);
        background-size: cover;
        background-position: center;
      }

      & .member-card-link {
        text-decoration: none;
        color: inherit;

        &:hover .member-photo,
        &:focus-visible .member-photo {
          transform: scale(1.03);
        }

        &:hover .member-name,
        &:focus-visible .member-name {
          color: var(--accent);
        }
      }

      & .member-name {
        margin-block-end: var(--space-2xs);
        transition: color var(--transition-speed-normal);
      }

      & .member-role {
        margin: 0;
      }

      & .member-specialty {
        margin-block-start: var(--space-sm);
        margin-block-end: 0;
      }

      & .member-bio {
        margin-block-start: var(--space-sm);
        margin-block-end: 0;
      }

      & .member-social {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-xs);
        justify-content: flex-start;
        margin-block-start: var(--space-md);
      }

      & .member-social-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 3.2rem;
        height: 3.2rem;
        border-radius: 50%;
        border: var(--border-width-thin) solid var(--border-color);
        color: var(--text-content);
        text-decoration: none;
        transition: all var(--transition-speed-normal);

        &:hover {
          border-color: var(--accent);
          color: var(--accent);
        }

        svg {
          width: 1.6rem;
          height: 1.6rem;
        }
      }

      @media (min-width: 750px) {
        & .team-highlight-grid {
          grid-template-columns: 4fr 6fr;
          gap: var(--space-3xl);
          align-items: start;
        }

        & .team-highlight-intro {
          position: sticky;
          top: var(--space-2xl);
        }

        & .member-grid {
          grid-template-columns: repeat({{ widget.settings.columns_desktop }}, minmax(0, 1fr));
        }
      }

      @media (min-width: 990px) {
        & .team-highlight-grid {
          gap: var(--space-4xl);
        }
      }
    }
  </style>

  {% assign team_cols = widget.settings.columns_desktop | default: 3 %}
  {% assign team_member_vw = 60 | divided_by: team_cols %}
  {% assign team_member_cap = 852 | divided_by: team_cols %}
  {% assign team_member_sizes = '(max-width: 749px) 45vw, (max-width: 1420px) ' | append: team_member_vw | append: 'vw, ' | append: team_member_cap | append: 'px' %}
  <div class="widget-container {% unless widget.settings.color_scheme == 'standard-primary' %}widget-container-padded{% endunless %}">
    <div class="team-highlight-grid">
      {% assign has_intro = false %}
      {% if widget.settings.eyebrow != blank or widget.settings.title != blank or widget.settings.description != blank or widget.settings.signature_image != blank %}
        {% assign has_intro = true %}
      {% endif %}

      {% if has_intro %}
        <div class="team-highlight-intro">
          {% if widget.settings.eyebrow != blank or widget.settings.title != blank or widget.settings.description != blank %}
            <div class="widget-header{% if widget.settings.heading_alignment == 'start' %} widget-header--align-start{% endif %}">
              {% assign intro_delay = 0 %}
              {% if widget.settings.eyebrow != blank %}
                <span class="w-eyebrow{% if widget.settings.eyebrow_uppercase %} t-uppercase{% endif %} reveal reveal-up" style="--reveal-delay: {{ intro_delay }}" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
                {% assign intro_delay = intro_delay | plus: 1 %}
              {% endif %}
              {% if widget.settings.title != blank %}
                {% if widget.index == 1 %}
                  <h1 class="w-headline reveal reveal-up" style="--reveal-delay: {{ intro_delay }}" data-setting="title">{{ widget.settings.title }}</h1>
                {% else %}
                  <h2 class="w-headline reveal reveal-up" style="--reveal-delay: {{ intro_delay }}" data-setting="title">{{ widget.settings.title }}</h2>
                {% endif %}
                {% assign intro_delay = intro_delay | plus: 1 %}
              {% endif %}
              {% if widget.settings.description != blank %}
                <p class="w-description reveal reveal-up" style="--reveal-delay: {{ intro_delay }}" data-setting="description">{{ widget.settings.description }}</p>
                {% assign intro_delay = intro_delay | plus: 1 %}
              {% endif %}
            </div>
          {% else %}
            {% assign intro_delay = 0 %}
          {% endif %}
          {% if widget.settings.signature_image != blank and widget.settings.signature_image != 'placeholder' %}
            {% image src: widget.settings.signature_image, size: 'small', class: 'team-highlight-signature reveal reveal-up', style: '--reveal-delay: ' | append: intro_delay %}
          {% endif %}
        </div>
      {% endif %}

      <div class="team-highlight-members">
        {% assign item_heading_level = 'h3' %}
        {% if widget.settings.title == blank %}
          {% assign item_heading_level = 'h2' %}
        {% endif %}

        <ul class="member-grid">
          {% for blockId in widget.blocksOrder %}
            {% assign block = widget.blocks[blockId] %}
            {% assign has_link = false %}
            {% if block.settings.link.url != blank %}
              {% assign has_link = true %}
            {% endif %}

            {% assign has_social = false %}
            {% if block.settings.linkedin != blank or block.settings.twitter != blank or block.settings.instagram != blank or block.settings.facebook != blank or block.settings.email != blank or block.settings.github != blank or block.settings.youtube != blank or block.settings.tiktok != blank or block.settings.pinterest != blank or block.settings.bluesky != blank or block.settings.discord != blank or block.settings.meta != blank or block.settings.reddit != blank or block.settings.telegram != blank or block.settings.threads != blank or block.settings.whatsapp != blank %}
              {% assign has_social = true %}
            {% endif %}

            <li class="member-card reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
              {% if has_link %}
                <a href="{{ block.settings.link.url }}" class="member-card-link"
                  {% if block.settings.link.new_tab %}target="_blank" rel="noopener"{% endif %}
                >
              {% endif %}

              <div class="member-photo-wrap">
                {% if block.settings.photo != blank and block.settings.photo != 'placeholder' %}
                  {% image src: block.settings.photo, size: 'medium', srcset: true, sizes: team_member_sizes, class: 'member-photo' %}
                {% else %}
                  <div class="member-photo-placeholder" style="background-image: url({% placeholder_image aspect: 'portrait', output: 'url' %});"></div>
                {% endif %}
              </div>

              {% if block.settings.name != blank %}
                <{{ item_heading_level }} class="member-name w-title t-xl" data-setting="name">{{ block.settings.name }}</{{ item_heading_level }}>
              {% endif %}

              {% if block.settings.role != blank %}
                <p class="member-role w-meta t-sm t-muted" data-setting="role">{{ block.settings.role }}</p>
              {% endif %}

              {% if has_link %}
                </a>
              {% endif %}

              {% if block.settings.specialty != blank %}
                <p class="member-specialty w-meta t-sm t-accent" data-setting="specialty">{{ block.settings.specialty }}</p>
              {% endif %}

              {% if block.settings.bio != blank %}
                <p class="member-bio w-body t-sm" data-setting="bio">{{ block.settings.bio }}</p>
              {% endif %}

              {% if has_social %}
                <div class="member-social">
                  {% if block.settings.linkedin != blank %}
                    <a href="{{ block.settings.linkedin }}" class="member-social-link" target="_blank" rel="noopener" aria-label="LinkedIn" data-setting="linkedin">
                      {% render 'icon', icon: 'linkedin' %}
                    </a>
                  {% endif %}
                  {% if block.settings.twitter != blank %}
                    <a href="{{ block.settings.twitter }}" class="member-social-link" target="_blank" rel="noopener" aria-label="Twitter" data-setting="twitter">
                      {% render 'icon', icon: 'twitter' %}
                    </a>
                  {% endif %}
                  {% if block.settings.instagram != blank %}
                    <a href="{{ block.settings.instagram }}" class="member-social-link" target="_blank" rel="noopener" aria-label="Instagram" data-setting="instagram">
                      {% render 'icon', icon: 'instagram' %}
                    </a>
                  {% endif %}
                  {% if block.settings.facebook != blank %}
                    <a href="{{ block.settings.facebook }}" class="member-social-link" target="_blank" rel="noopener" aria-label="Facebook" data-setting="facebook">
                      {% render 'icon', icon: 'facebook' %}
                    </a>
                  {% endif %}
                  {% if block.settings.email != blank %}
                    <a href="mailto:{{ block.settings.email }}" class="member-social-link" aria-label="Email" data-setting="email">
                      {% render 'icon', icon: 'mail' %}
                    </a>
                  {% endif %}
                  {% if block.settings.github != blank %}
                    <a href="{{ block.settings.github }}" class="member-social-link" target="_blank" rel="noopener" aria-label="GitHub" data-setting="github">
                      {% render 'icon', icon: 'github' %}
                    </a>
                  {% endif %}
                  {% if block.settings.youtube != blank %}
                    <a href="{{ block.settings.youtube }}" class="member-social-link" target="_blank" rel="noopener" aria-label="YouTube" data-setting="youtube">
                      {% render 'icon', icon: 'youtube' %}
                    </a>
                  {% endif %}
                  {% if block.settings.tiktok != blank %}
                    <a href="{{ block.settings.tiktok }}" class="member-social-link" target="_blank" rel="noopener" aria-label="TikTok" data-setting="tiktok">
                      {% render 'icon', icon: 'tiktok' %}
                    </a>
                  {% endif %}
                  {% if block.settings.pinterest != blank %}
                    <a href="{{ block.settings.pinterest }}" class="member-social-link" target="_blank" rel="noopener" aria-label="Pinterest" data-setting="pinterest">
                      {% render 'icon', icon: 'pinterest' %}
                    </a>
                  {% endif %}
                  {% if block.settings.bluesky != blank %}
                    <a href="{{ block.settings.bluesky }}" class="member-social-link" target="_blank" rel="noopener" aria-label="Bluesky" data-setting="bluesky">
                      {% render 'icon', icon: 'bluesky' %}
                    </a>
                  {% endif %}
                  {% if block.settings.discord != blank %}
                    <a href="{{ block.settings.discord }}" class="member-social-link" target="_blank" rel="noopener" aria-label="Discord" data-setting="discord">
                      {% render 'icon', icon: 'discord' %}
                    </a>
                  {% endif %}
                  {% if block.settings.meta != blank %}
                    <a href="{{ block.settings.meta }}" class="member-social-link" target="_blank" rel="noopener" aria-label="Meta" data-setting="meta">
                      {% render 'icon', icon: 'meta' %}
                    </a>
                  {% endif %}
                  {% if block.settings.reddit != blank %}
                    <a href="{{ block.settings.reddit }}" class="member-social-link" target="_blank" rel="noopener" aria-label="Reddit" data-setting="reddit">
                      {% render 'icon', icon: 'reddit' %}
                    </a>
                  {% endif %}
                  {% if block.settings.telegram != blank %}
                    <a href="{{ block.settings.telegram }}" class="member-social-link" target="_blank" rel="noopener" aria-label="Telegram" data-setting="telegram">
                      {% render 'icon', icon: 'telegram' %}
                    </a>
                  {% endif %}
                  {% if block.settings.threads != blank %}
                    <a href="{{ block.settings.threads }}" class="member-social-link" target="_blank" rel="noopener" aria-label="Threads" data-setting="threads">
                      {% render 'icon', icon: 'threads' %}
                    </a>
                  {% endif %}
                  {% if block.settings.whatsapp != blank %}
                    <a href="{{ block.settings.whatsapp }}" class="member-social-link" target="_blank" rel="noopener" aria-label="WhatsApp" data-setting="whatsapp">
                      {% render 'icon', icon: 'whatsapp' %}
                    </a>
                  {% endif %}
                </div>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

{
  "type": "team-highlight",
  "displayName": "tTheme:team_highlight.name",
  "aliases": [
    "team",
    "leadership",
    "our team",
    "meet the team",
    "founders"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:team_highlight.settings.eyebrow.label",
      "default": "Meet Our Team"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:team_highlight.settings.title.label",
      "default": "Our leaders"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "tTheme:team_highlight.settings.description.label",
      "default": "We're 120+ individuals from across the world driven by bold ideas"
    },
    {
      "type": "image",
      "id": "signature_image",
      "label": "tTheme:team_highlight.settings.signature_image.label"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:team_highlight.settings.display_header.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "tTheme:team_highlight.settings.columns_desktop.label",
      "default": 2,
      "min": 2,
      "max": 4,
      "step": 1
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "tTheme:team_highlight.settings.image_ratio.label",
      "default": "portrait",
      "options": [
        {
          "value": "portrait",
          "label": "tTheme:team_highlight.settings.image_ratio.options.portrait"
        },
        {
          "value": "square",
          "label": "tTheme:team_highlight.settings.image_ratio.options.square"
        },
        {
          "value": "auto",
          "label": "tTheme:team_highlight.settings.image_ratio.options.auto"
        }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:team_highlight.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:team_highlight.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:team_highlight.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "member",
      "displayName": "tTheme:team_highlight.blocks.member.name",
      "settings": [
        {
          "type": "image",
          "id": "photo",
          "label": "tTheme:team_highlight.blocks.member.settings.photo.label"
        },
        {
          "type": "text",
          "id": "name",
          "label": "tTheme:team_highlight.blocks.member.settings.name.label",
          "default": "John Doe"
        },
        {
          "type": "text",
          "id": "role",
          "label": "tTheme:team_highlight.blocks.member.settings.role.label",
          "default": "Team Member"
        },
        {
          "type": "link",
          "id": "link",
          "label": "tTheme:team_highlight.blocks.member.settings.link.label"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "member",
      "settings": {
        "name": "David Carter",
        "role": "CEO & Founder"
      }
    },
    {
      "type": "member",
      "settings": {
        "name": "Sarah Thompson",
        "role": "CMO & Co-founder"
      }
    },
    {
      "type": "member",
      "settings": {
        "name": "James Nakamura",
        "role": "CTO"
      }
    },
    {
      "type": "member",
      "settings": {
        "name": "Elena Vasquez",
        "role": "Head of Design"
      }
    }
  ]
}

{
  "type": "image",
  "displayName": "tTheme:image.name",
  "aliases": [
    "photo",
    "picture",
    "visual",
    "graphic"
  ],
  "settings": [
    {
      "type": "header",
      "id": "content_header",
      "label": "tTheme:global.widgets.settings.content_header.label"
    },
    {
      "type": "image",
      "id": "image",
      "label": "tTheme:image.settings.image.label"
    },
    {
      "type": "link",
      "id": "link",
      "label": "tTheme:image.settings.link.label",
      "description": "tTheme:image.settings.link.description",
      "hide_text": true
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "checkbox",
      "id": "fullwidth",
      "label": "tTheme:global.widgets.settings.fullwidth.label",
      "default": false,
      "description": "tTheme:image.settings.fullwidth.description"
    }
  ]
}

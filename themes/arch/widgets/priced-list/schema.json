{
  "type": "priced-list",
  "displayName": "tTheme:priced_list.name",
  "aliases": [
    "menu",
    "catalog",
    "services with price",
    "inventory"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label",
      "default": "Starters"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "Appetizers"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "tTheme:priced_list.settings.layout.label",
      "default": "single-column",
      "options": [
        {
          "value": "single-column",
          "label": "tTheme:priced_list.settings.layout.options.single-column"
        },
        {
          "value": "two-column",
          "label": "tTheme:priced_list.settings.layout.options.two-column"
        }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "displayName": "tTheme:priced_list.blocks.item.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "name",
          "label": "tTheme:priced_list.blocks.item.settings.name.label",
          "default": "Dish Name"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "tTheme:priced_list.blocks.item.settings.description.label",
          "default": "<p>A delicious dish made with fresh ingredients.</p>"
        },
        {
          "type": "text",
          "id": "price",
          "label": "tTheme:priced_list.blocks.item.settings.price.label",
          "default": "$12"
        },
        {
          "type": "image",
          "id": "image",
          "label": "tTheme:priced_list.blocks.item.settings.image.label"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "item",
      "settings": {
        "name": "Garden Bruschetta",
        "description": "<p>Toasted sourdough topped with fresh tomatoes, basil, garlic, and extra virgin olive oil.</p>",
        "price": "$9"
      }
    },
    {
      "type": "item",
      "settings": {
        "name": "Crispy Calamari",
        "description": "<p>Lightly battered calamari rings served with lemon aioli and marinara sauce.</p>",
        "price": "$14"
      }
    },
    {
      "type": "item",
      "settings": {
        "name": "Spicy Buffalo Wings",
        "description": "<p>Crispy chicken wings tossed in our signature buffalo sauce. Served with blue cheese dip.</p>",
        "price": "$12"
      }
    }
  ]
}

<section
  id="{{ widget.id }}"
  class="widget widget-type-priced-list widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}{% if widget.settings.top_spacing != 'auto' %} spacing-top-{{ widget.settings.top_spacing }}{% endif %}{% if widget.settings.bottom_spacing != 'auto' %} spacing-bottom-{{ widget.settings.bottom_spacing }}{% endif %}"
  {% unless widget.settings.color_scheme == 'standard-primary' %}
    style="--widget-bg-color: var(--bg-primary);"
  {% endunless %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="priced-list"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      & .priced-list {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      & .priced-list.priced-list--two-column {
        display: flex;
        flex-direction: column;
      }

      & .priced-row {
        display: grid;
        grid-template-columns: 1fr;
      }

      & .priced-row:first-child {
        border-block-start: var(--border-width-thin) solid var(--border-color);
      }

      & .priced-row {
        border-block-end: var(--border-width-thin) solid var(--border-color);
      }

      & .priced-row-cell {
        display: flex;
      }

      & .priced-list--two-column .priced-row-cell + .priced-row-cell {
        border-block-start: var(--border-width-thin) solid var(--border-color);
      }

      & .priced-list--two-column .priced-item {
        width: 100%;
        height: 100%;
        border: 0;
      }

      & .priced-list--two-column .priced-item:first-child {
        border-block-start: 0;
      }

      & .priced-item {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: var(--space-md);
        padding: var(--space-lg) 0;
        border-block-end: var(--border-width-thin) solid var(--border-color);
        align-items: start;
      }

      & .priced-item:first-child {
        border-block-start: var(--border-width-thin) solid var(--border-color);
      }

      & .priced-item-content {
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
      }

      & .priced-item-description {
        max-width: 60ch;
      }

      & .priced-item-price {
        white-space: nowrap;
      }

      & .priced-item-image {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: var(--radius-sm);
        margin-inline-start: var(--space-md);
      }

      & .priced-item-right {
        display: flex;
        align-items: center;
        gap: var(--space-md);
      }

      @media (min-width: 750px) {
        & .priced-list--two-column .priced-row {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        & .priced-list--two-column .priced-row-cell:first-child {
          padding-inline-end: var(--space-xl);
        }

        & .priced-list--two-column .priced-row-cell + .priced-row-cell {
          padding-inline-start: var(--space-xl);
          border-block-start: 0;
          border-inline-start: var(--border-width-thin) solid var(--border-color);
        }
      }

      @media (max-width: 749px) {
        & .priced-item {
          grid-template-columns: 1fr;
        }

        & .priced-item-right {
          justify-content: space-between;
          margin-block-start: var(--space-sm);
        }

        & .priced-item-image {
          width: 60px;
          height: 60px;
        }
      }
    }
  </style>

  <div class="widget-container {% unless widget.settings.color_scheme == 'standard-primary' %}widget-container-padded{% endunless %}">
    {% if widget.settings.title != blank or widget.settings.description != blank or widget.settings.eyebrow != blank %}
      <div class="widget-header{% if widget.settings.heading_alignment == 'start' %} widget-header--align-start{% endif %}">
        {% assign header_delay = 0 %}
        {% if widget.settings.eyebrow != blank %}
          <span class="w-eyebrow{% if widget.settings.eyebrow_uppercase %} t-uppercase{% endif %} reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.title != blank %}
          {% if widget.index == 1 %}
            <h1 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h1>
          {% else %}
            <h2 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h2>
          {% endif %}
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.description != blank %}
          <p class="w-description reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="description">{{ widget.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="widget-content">
      {% assign item_heading_level = 'h3' %}
      {% if widget.settings.title == blank %}
        {% assign item_heading_level = 'h2' %}
      {% endif %}

      {% if widget.settings.layout == 'two-column' %}
        <div class="priced-list priced-list--two-column">
          {% for blockId in widget.blocksOrder %}
            {% assign block = widget.blocks[blockId] %}
            {% assign position = forloop.index0 | modulo: 2 %}
            {% if position == 0 %}
              <div class="priced-row">
            {% endif %}

            <div class="priced-row-cell">
              <div class="priced-item reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
                <div class="priced-item-content">
                  {% if block.settings.name != blank %}
                    <{{ item_heading_level }} class="priced-item-name w-title t-xl" data-setting="name">{{ block.settings.name }}</{{ item_heading_level }}>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <div class="priced-item-description w-body w-rte t-sm" data-setting="description">{{ block.settings.description | raw }}</div>
                  {% endif %}
                </div>
                <div class="priced-item-right">
                  {% if block.settings.price != blank %}
                    <span class="priced-item-price w-body t-lg t-heading" data-setting="price">{{ block.settings.price }}</span>
                  {% endif %}
                  {% if block.settings.image != blank %}
                    {% image src: block.settings.image, size: 'small', class: 'priced-item-image' %}
                  {% endif %}
                </div>
              </div>
            </div>

            {% if position == 1 or forloop.last %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% else %}
        <div class="priced-list">
          {% for blockId in widget.blocksOrder %}
            {% assign block = widget.blocks[blockId] %}
            <div class="priced-item reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
              <div class="priced-item-content">
                {% if block.settings.name != blank %}
                  <{{ item_heading_level }} class="priced-item-name w-title t-xl" data-setting="name">{{ block.settings.name }}</{{ item_heading_level }}>
                {% endif %}
                {% if block.settings.description != blank %}
                  <div class="priced-item-description w-body w-rte t-sm" data-setting="description">{{ block.settings.description | raw }}</div>
                {% endif %}
              </div>
              <div class="priced-item-right">
                {% if block.settings.price != blank %}
                  <span class="priced-item-price w-body t-lg t-heading" data-setting="price">{{ block.settings.price }}</span>
                {% endif %}
                {% if block.settings.image != blank %}
                  {% image src: block.settings.image, size: 'small', class: 'priced-item-image' %}
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

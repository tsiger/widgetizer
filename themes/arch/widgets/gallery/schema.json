{
  "type": "gallery",
  "displayName": "tTheme:gallery.name",
  "aliases": [
    "images",
    "photos",
    "portfolio",
    "showcase"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "Project Gallery"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "tTheme:global.widgets.settings.options.left"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "tTheme:global.widgets.settings.layout.label",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "tTheme:global.widgets.settings.layout.options.grid"
        },
        {
          "value": "carousel",
          "label": "tTheme:global.widgets.settings.layout.options.carousel"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "tTheme:global.widgets.settings.columns_desktop.label",
      "default": 4,
      "min": 2,
      "max": 5,
      "step": 1
    },
    {
      "type": "checkbox",
      "id": "staggered",
      "label": "tTheme:gallery.settings.staggered.label",
      "default": false
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "tTheme:global.widgets.settings.aspect_ratio.label",
      "default": "4 / 3",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.auto"
        },
        {
          "value": "contain",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.contain"
        },
        {
          "value": "1 / 1",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.1 / 1"
        },
        {
          "value": "4 / 3",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.4 / 3"
        },
        {
          "value": "3 / 2",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.3 / 2"
        },
        {
          "value": "3 / 4",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.3 / 4"
        },
        {
          "value": "16 / 9",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.16 / 9"
        }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard"
        },
        {
          "value": "standard-accent",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_accent"
        },
        {
          "value": "highlight",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight"
        },
        {
          "value": "highlight-accent",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_accent"
        }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.top_spacing.options.auto"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.top_spacing.options.none"
        }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.none"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "image",
      "displayName": "tTheme:gallery.blocks.image.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "image",
          "id": "image",
          "label": "tTheme:gallery.blocks.image.settings.image.label"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "tTheme:gallery.blocks.image.settings.caption.label"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "image",
      "settings": {
        "caption": "Mountain Landscape"
      }
    },
    {
      "type": "image",
      "settings": {
        "caption": "Ocean Sunset"
      }
    },
    {
      "type": "image",
      "settings": {
        "caption": "Urban Architecture"
      }
    },
    {
      "type": "image",
      "settings": {
        "caption": "Forest Trail"
      }
    },
    {
      "type": "image",
      "settings": {
        "caption": "Desert Dunes"
      }
    },
    {
      "type": "image",
      "settings": {
        "caption": "City Skyline"
      }
    },
    {
      "type": "image",
      "settings": {
        "caption": "Beach Sunset"
      }
    },
    {
      "type": "image",
      "settings": {
        "caption": "Beach Sunset"
      }
    }
  ]
}

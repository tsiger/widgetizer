{% if widget.settings.layout == 'carousel' %}
  {% enqueue_script src: "carousel.js", defer: true, location: "footer", priority: 40, theme: true %}
{% endif %}
<section
  id="{{ widget.id }}"
  class="widget widget-type-pricing widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}{% if widget.settings.top_spacing != 'auto' %} spacing-top-{{ widget.settings.top_spacing }}{% endif %}{% if widget.settings.bottom_spacing != 'auto' %} spacing-bottom-{{ widget.settings.bottom_spacing }}{% endif %}"
  {% unless widget.settings.color_scheme == 'standard-primary' %}
    style="--widget-bg-color: var(--bg-primary);"
  {% endunless %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="pricing"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      /* Featured Card - Accent Border */
      & .widget-card.is-featured {
        border-color: var(--accent);
        border-width: var(--border-width-medium);
      }

      /* Pricing Header */
      & .widget-card-header {
        text-align: center;
      }

      & .pricing-price {
        font-size: calc(var(--font-size-5xl) * var(--heading-scale));
        font-weight: var(--font-weight-bold);
        line-height: var(--line-height-tight);
        color: var(--text-heading);
        margin: 0;
        margin-block-start: var(--space-sm);
      }

      & .pricing-features {
        list-style: none;
        padding: 0;
        margin: 0;
        flex: 1;
      }

      & .pricing-feature {
        padding: var(--space-md) 0;
        border-block-end: var(--border-width-thin) solid var(--border-color);
        display: flex;
        gap: var(--space-sm);
        align-items: center;

        &:first-child {
          border-block-start: var(--border-width-thin) solid var(--border-color);
        }

        &:last-child {
          border-block-end: none;
          padding-block-end: var(--space-lg); /* Extra space before button */
        }
      }

      & .feature-icon {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        width: 1.25rem;
        height: 1.25rem;
        color: var(--accent);
      }

      &.color-scheme-standard-secondary,
      &.color-scheme-highlight-secondary {
        & .widget-card {
          background-color: var(--bg-secondary);
        }
      }

      &.color-scheme-standard-secondary,
      &.color-scheme-highlight-primary,
      &.color-scheme-highlight-secondary {
        & .widget-card:not(.is-featured) {
          border: var(--border-width-thin) solid var(--border-color);
        }
      }

      /* Smart layout for different item counts */
    }
  </style>

  <div class="widget-container {% unless widget.settings.color_scheme == 'standard-primary' %}widget-container-padded{% endunless %}">
    {% if widget.settings.title != blank or widget.settings.description != blank or widget.settings.eyebrow != blank %}
      <div class="widget-header{% if widget.settings.heading_alignment == 'start' %} widget-header--align-start{% endif %}">
        {% assign header_delay = 0 %}
        {% if widget.settings.eyebrow != blank %}
          <span class="w-eyebrow reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.title != blank %}
          {% if widget.index == 1 %}
            <h1 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h1>
          {% else %}
            <h2 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h2>
          {% endif %}
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.description != blank %}
          <p class="w-description reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="description">{{ widget.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="widget-content">
      {% assign item_heading_level = 'h3' %}
      {% if widget.settings.title == blank %}
        {% assign item_heading_level = 'h2' %}
      {% endif %}

      {% if widget.settings.layout == 'carousel' %}
        <div class="carousel-container reveal reveal-up">
          <button type="button" class="carousel-btn carousel-btn-prev" aria-label="Previous">
            <svg class="carousel-btn-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <button type="button" class="carousel-btn carousel-btn-next" aria-label="Next">
            <svg class="carousel-btn-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <ul class="widget-card-grid carousel-track" style="--carousel-cols: {{ widget.settings.columns_desktop }}">
            {% for blockId in widget.blocksOrder %}
              {% assign block = widget.blocks[blockId] %}
              <li class="widget-card carousel-item {% if block.settings.featured %}is-featured{% endif %}" data-block-id="{{ blockId }}">
                <div class="widget-card-header">
                  {% if block.settings.title != blank %}
                    <{{ item_heading_level }} class="w-title t-xl" data-setting="title">{{ block.settings.title }}</{{ item_heading_level }}>
                  {% endif %}
                  {% if block.settings.price != blank %}
                    <div class="pricing-price" data-setting="price">{{ block.settings.price }}</div>
                  {% endif %}
                  {% if block.settings.period != blank %}
                    <div class="w-meta" data-setting="period">{{ block.settings.period }}</div>
                  {% endif %}
                </div>
                <div class="widget-card-content">
                  {% if block.settings.features != blank %}
                    <ul class="pricing-features">
                      {% assign normalized_features = block.settings.features | replace: '\r\n', '\n' %}
                      {% assign features = normalized_features | split: '\n' %}
                      {% for feature in features %}
                        {% assign trimmed_feature = feature | strip %}
                        {% if trimmed_feature != blank %}
                          {% assign feature_text = trimmed_feature %}
                          {% assign icon_name = '' %}
                          {% assign first_char = trimmed_feature | slice: 0, 1 %}
                          {% if first_char == '+' %}
                            {% assign icon_name = 'check' %}
                            {% assign feature_text = trimmed_feature | remove_first: '+' | strip %}
                          {% elsif first_char == '-' %}
                            {% assign icon_name = 'x' %}
                            {% assign feature_text = trimmed_feature | remove_first: '-' | strip %}
                          {% endif %}
                          <li class="pricing-feature w-body t-base">
                            {% if icon_name != blank %}
                              <span class="feature-icon">
                                {% render 'icon', icon: icon_name, class: 'feature-icon-svg' %}
                              </span>
                            {% endif %}
                            <span>{{ feature_text }}</span>
                          </li>
                        {% endif %}
                      {% endfor %}
                    </ul>
                  {% endif %}
                </div>
                {% if block.settings.button_link.text != blank %}
                  <div class="widget-card-footer">
                    <a
                      href="{{ block.settings.button_link.href }}"
                      class="widget-button widget-button-full"
                      data-setting="button_link"
                      {% if block.settings.button_link.target == '_blank' %}
                        target="_blank" rel="noopener"
                      {% endif %}
                    >
                      {{ block.settings.button_link.text }}
                    </a>
                  </div>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        </div>

      {% else %}
        <ul
          class="widget-card-grid widget-grid"
          style="--grid-cols-desktop: {{ widget.settings.columns_desktop }};"
        >
          {% for blockId in widget.blocksOrder %}
            {% assign block = widget.blocks[blockId] %}
            <li class="widget-card reveal reveal-up {% if block.settings.featured %}is-featured{% endif %}" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
              <div class="widget-card-header">
                {% if block.settings.title != blank %}
                  <{{ item_heading_level }} class="w-title t-xl" data-setting="title">{{ block.settings.title }}</{{ item_heading_level }}>
                {% endif %}
                {% if block.settings.price != blank %}
                  <div class="pricing-price" data-setting="price">{{ block.settings.price }}</div>
                {% endif %}
                {% if block.settings.period != blank %}
                  <div class="w-meta" data-setting="period">{{ block.settings.period }}</div>
                {% endif %}
              </div>
              <div class="widget-card-content">
                {% if block.settings.features != blank %}
                  <ul class="pricing-features">
                    {% assign normalized_features = block.settings.features | replace: '\r\n', '\n' %}
                    {% assign features = normalized_features | split: '\n' %}
                    {% for feature in features %}
                      {% assign trimmed_feature = feature | strip %}
                      {% if trimmed_feature != blank %}
                        {% assign feature_text = trimmed_feature %}
                        {% assign icon_name = '' %}
                        {% assign first_char = trimmed_feature | slice: 0, 1 %}
                        {% if first_char == '+' %}
                          {% assign icon_name = 'check' %}
                          {% assign feature_text = trimmed_feature | remove_first: '+' | strip %}
                        {% elsif first_char == '-' %}
                          {% assign icon_name = 'x' %}
                          {% assign feature_text = trimmed_feature | remove_first: '-' | strip %}
                        {% endif %}
                        <li class="pricing-feature w-body t-base">
                          {% if icon_name != blank %}
                            <span class="feature-icon">
                              {% render 'icon', icon: icon_name, class: 'feature-icon-svg' %}
                            </span>
                          {% endif %}
                          <span>{{ feature_text }}</span>
                        </li>
                      {% endif %}
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>
              {% if block.settings.button_link.text != blank %}
                <div class="widget-card-footer">
                  <a
                    href="{{ block.settings.button_link.href }}"
                    class="widget-button widget-button-full"
                    data-setting="button_link"
                    {% if block.settings.button_link.target == '_blank' %}
                      target="_blank" rel="noopener"
                    {% endif %}
                  >
                    {{ block.settings.button_link.text }}
                  </a>
                </div>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </div>
</section>

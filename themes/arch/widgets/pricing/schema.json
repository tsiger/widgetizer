{
  "type": "pricing",
  "displayName": "tTheme:pricing.name",
  "aliases": [
    "plans",
    "packages",
    "subscription",
    "pricing tiers"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:pricing.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:pricing.settings.title.label",
      "default": "Pricing Plans"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:pricing.settings.description.label",
      "default": "Choose the plan that fits your needs."
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:pricing.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "tTheme:pricing.settings.layout.label",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "tTheme:pricing.settings.layout.options.grid"
        },
        {
          "value": "carousel",
          "label": "tTheme:pricing.settings.layout.options.carousel"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "tTheme:pricing.settings.columns_desktop.label",
      "default": 3,
      "min": 2,
      "max": 5,
      "step": 1
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:pricing.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:pricing.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:pricing.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "plan",
      "displayName": "tTheme:pricing.blocks.plan.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:pricing.blocks.plan.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:pricing.blocks.plan.settings.title.label",
          "default": "Pro"
        },
        {
          "type": "text",
          "id": "price",
          "label": "tTheme:pricing.blocks.plan.settings.price.label",
          "default": "$49"
        },
        {
          "type": "text",
          "id": "period",
          "label": "tTheme:pricing.blocks.plan.settings.period.label",
          "default": "per month"
        },
        {
          "type": "textarea",
          "id": "features",
          "label": "tTheme:pricing.blocks.plan.settings.features.label",
          "description": "tTheme:pricing.blocks.plan.settings.features.description",
          "default": "+ Unlimited Projects\n+ Priority Support\n+ 10GB Storage"
        },
        {
          "type": "link",
          "id": "button_link",
          "label": "tTheme:pricing.blocks.plan.settings.button_link.label",
          "default": {
            "text": "Get Started",
            "href": "#",
            "target": "_self"
          }
        },
        {
          "type": "header",
          "id": "options_header",
          "label": "tTheme:pricing.blocks.plan.settings.options_header.label"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "tTheme:pricing.blocks.plan.settings.featured.label",
          "default": false
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "plan",
      "settings": {

        "button_link": {
          "text": "Get Started",
          "href": "#",
          "target": "_self"
        },
        "featured": true
      }
    },
    {
      "type": "plan",
      "settings": {
        "title": "Enterprise",
        "price": "$99",
        "period": "per month",
        "features": "+ Unlimited Everything\n+ 24/7 Phone Support\n+ 100GB Storage\n+ Advanced Analytics\n+ Custom Domain\n+ Dedicated Manager",
        "button_link": {

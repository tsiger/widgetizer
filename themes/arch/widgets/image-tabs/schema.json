{
  "type": "image-tabs",
  "displayName": "tTheme:image_tabs.name",
  "aliases": [
    "visual tabs",
    "image selector",
    "gallery tabs",
    "interactive gallery"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "Our Features"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "tTheme:global.widgets.settings.options.left"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "tTheme:global.widgets.settings.image_position.label",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "tTheme:global.widgets.settings.image_position.options.left"
        },
        {
          "value": "right",
          "label": "tTheme:global.widgets.settings.image_position.options.right"
        }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "displayName": "tTheme:image_tabs.blocks.tab.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:image_tabs.blocks.tab.settings.title.label",
          "default": "Feature Name"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "tTheme:image_tabs.blocks.tab.settings.description.label"
        },
        {
          "type": "image",
          "id": "image",
          "label": "tTheme:image_tabs.blocks.tab.settings.image.label"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "tab",
      "settings": {
        "title": "Easy Integration",
        "description": "<p>Connect with all your favorite tools in minutes with our simple API</p>"
      }
    },
    {
      "type": "tab",
      "settings": {
        "title": "Real-time Analytics",
        "description": "<p>Track performance with live dashboards and detailed reports</p>"
      }
    },
    {
      "type": "tab",
      "settings": {
        "title": "Team Collaboration",
        "description": "<p>Work together seamlessly with built-in collaboration features</p>"
      }
    }
  ]
}

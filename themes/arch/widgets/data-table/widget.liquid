{% assign col_count = widget.settings.columns | plus: 0 %}
{% assign row_count = 0 %}
{% for blockId in widget.blocksOrder %}
  {% assign block = widget.blocks[blockId] %}
  {% if block.type == 'row' %}
    {% assign row_count = row_count | plus: 1 %}
  {% endif %}
{% endfor %}

<section
  id="{{ widget.id }}"
  class="widget widget-type-data-table widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}{% if widget.settings.top_spacing != 'auto' %} spacing-top-{{ widget.settings.top_spacing }}{% endif %}{% if widget.settings.bottom_spacing != 'auto' %} spacing-bottom-{{ widget.settings.bottom_spacing }}{% endif %}"
  {% unless widget.settings.color_scheme == 'standard-primary' %}
    style="--widget-bg-color: var(--bg-primary);"
  {% endunless %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="data-table"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      & .table-scroll {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      & .data-table {
        width: 100%;
        border-collapse: collapse;
      }

      & .data-table.cols-3 {
        min-width: 32rem;
      }

      & .data-table.cols-4 {
        min-width: 40rem;
      }

      & .data-table th,
      & .data-table td {
        padding: var(--space-sm) var(--space-md);
        text-align: start;
        vertical-align: top;
      }

      & .data-table th {
        color: var(--text-heading);
        font-weight: var(--font-weight-semibold);
      }

      & .data-table td {
        color: var(--text-content);
      }

      /* Lines and plain styles hug the container edges; striped keeps its inset
         so the stripe wraps the text with breathing room. */
      & .table-style-lines th:first-child,
      & .table-style-lines td:first-child,
      & .table-style-plain th:first-child,
      & .table-style-plain td:first-child {
        padding-inline-start: 0;
      }

      & .table-style-lines th:last-child,
      & .table-style-lines td:last-child,
      & .table-style-plain th:last-child,
      & .table-style-plain td:last-child {
        padding-inline-end: 0;
      }

      & .table-style-lines thead th,
      & .table-style-striped thead th {
        border-block-end: var(--border-width-medium) solid var(--text-heading);
      }

      & .table-style-lines tbody tr {
        border-block-end: var(--border-width-thin) solid var(--border-color);
      }

      & .table-style-striped tbody tr:nth-child(odd) {
        background-color: var(--bg-secondary);
      }

      & .emphasis-first tbody td:first-child {
        color: var(--text-heading);
        font-weight: var(--font-weight-semibold);
      }

      & .align-last-end th:last-child,
      & .align-last-end td:last-child {
        text-align: end;
      }

      & .table-note {
        margin-block-start: var(--space-md);
      }
    }
  </style>

  <div class="widget-container {% unless widget.settings.color_scheme == 'standard-primary' %}widget-container-padded{% endunless %}">
    <div class="widget-content {% case widget.settings.content_width %}{% when 'narrow' %}widget-content-sm{% when 'medium' %}widget-content-md{% when 'wide' %}widget-content-lg{% endcase %}">
      {% if widget.settings.title != blank or widget.settings.description != blank or widget.settings.eyebrow != blank %}
        <div class="widget-header{% if widget.settings.heading_alignment == 'start' %} widget-header--align-start{% endif %}">
          {% assign header_delay = 0 %}
          {% if widget.settings.eyebrow != blank %}
            <span class="w-eyebrow{% if widget.settings.eyebrow_uppercase %} t-uppercase{% endif %} reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
            {% assign header_delay = header_delay | plus: 1 %}
          {% endif %}
          {% if widget.settings.title != blank %}
            {% if widget.index == 1 %}
              <h1 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h1>
            {% else %}
              <h2 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h2>
            {% endif %}
            {% assign header_delay = header_delay | plus: 1 %}
          {% endif %}
          {% if widget.settings.description != blank %}
            <p class="w-description reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="description">{{ widget.settings.description }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% if row_count > 0 %}
        <div class="table-scroll reveal reveal-up">
          <table
            class="data-table table-style-{{ widget.settings.style }} cols-{{ col_count }}{% if widget.settings.first_column_emphasis %} emphasis-first{% endif %}{% if widget.settings.align_last_column == 'end' %} align-last-end{% endif %}"
          >
            {% if widget.settings.show_header %}
              <thead>
                <tr>
                  <th scope="col" data-setting="column_1_header">{{ widget.settings.column_1_header }}</th>
                  <th scope="col" data-setting="column_2_header">{{ widget.settings.column_2_header }}</th>
                  {% if col_count >= 3 %}
                    <th scope="col" data-setting="column_3_header">{{ widget.settings.column_3_header }}</th>
                  {% endif %}
                  {% if col_count >= 4 %}
                    <th scope="col" data-setting="column_4_header">{{ widget.settings.column_4_header }}</th>
                  {% endif %}
                </tr>
              </thead>
            {% endif %}
            <tbody class="w-body">
              {% for blockId in widget.blocksOrder %}
                {% assign block = widget.blocks[blockId] %}
                {% if block.type == 'row' %}
                  <tr data-block-id="{{ blockId }}">
                    <td data-setting="cell_1">{{ block.settings.cell_1 }}</td>
                    <td data-setting="cell_2">{{ block.settings.cell_2 }}</td>
                    {% if col_count >= 3 %}
                      <td data-setting="cell_3">{{ block.settings.cell_3 }}</td>
                    {% endif %}
                    {% if col_count >= 4 %}
                      <td data-setting="cell_4">{{ block.settings.cell_4 }}</td>
                    {% endif %}
                  </tr>
                {% endif %}
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% endif %}

      {% if widget.settings.note != blank %}
        <p class="table-note w-meta t-sm" data-setting="note">{{ widget.settings.note }}</p>
      {% endif %}
    </div>
  </div>
</section>

{
  "type": "embed",
  "displayName": "tTheme:embed.name",
  "aliases": [
    "iframe",
    "external content",
    "integration",
    "third-party"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label"
    },
    {
      "type": "checkbox",
      "id": "eyebrow_uppercase",
      "label": "tTheme:global.widgets.settings.eyebrow_uppercase.label",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "Watch Our Video"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label",
      "default": "Learn more about our product in this quick video overview."
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "start",
          "label": "tTheme:global.widgets.settings.alignment.options.start"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.alignment.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "content_header",
      "label": "tTheme:global.widgets.settings.content_header.label"
    },
    {
      "type": "image",
      "id": "image",
      "label": "tTheme:global.widgets.settings.background_image.label"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "tTheme:global.widgets.settings.overlay_color.label",
      "default": "#0a1e38bf",
      "allow_alpha": true,
      "description": "tTheme:global.widgets.settings.overlay_color.description"
    },
    {
      "type": "code",
      "id": "code",
      "label": "tTheme:embed.settings.code.label",
      "default": "<div style=\"background-color: var(--bg-secondary); border: var(--border-width-thin) solid var(--border-color); padding: var(--space-2xl); text-align: center;\"><h3 style=\"margin: 0 0 var(--space-md) 0; color: var(--text-heading); font-size: var(--font-size-xl);\">Sample Embedded Content</h3><p style=\"margin: 0 0 var(--space-lg) 0; color: var(--text-muted);\">This is a placeholder for your embedded content. Replace this with your own HTML, iframe, or third-party embed code.</p><button style=\"background-color: var(--accent); color: var(--accent-text); border: none; padding: var(--space-sm) var(--space-lg); font-weight: 600; cursor: pointer;\">Learn More</button></div>"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "max_width",
      "label": "tTheme:embed.settings.max_width.label",
      "default": "wide",
      "options": [
        {
          "value": "narrow",
          "label": "tTheme:embed.settings.max_width.options.narrow"
        },
        {
          "value": "medium",
          "label": "tTheme:embed.settings.max_width.options.medium"
        },
        {
          "value": "wide",
          "label": "tTheme:embed.settings.max_width.options.wide"
        },
        {
          "value": "fullwidth",
          "label": "tTheme:embed.settings.max_width.options.fullwidth"
        }
      ]
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "tTheme:embed.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "start",
          "label": "tTheme:global.widgets.settings.options.start"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.options.center"
        },
        {
          "value": "end",
          "label": "tTheme:global.widgets.settings.options.end"
        }
      ]
    },
    {
      "type": "header",
      "id": "appearance_header",
      "label": "tTheme:global.widgets.settings.appearance_header.label"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard-primary",
      "options": [
        {
          "value": "standard-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_primary"
        },
        {
          "value": "standard-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_secondary"
        },
        {
          "value": "highlight-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_primary"
        },
        {
          "value": "highlight-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_secondary"
        }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.top_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.top_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.top_spacing.options.none"
        }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.none"
        }
      ]
    }
  ],
  "blocks": [],
  "defaultBlocks": []
}

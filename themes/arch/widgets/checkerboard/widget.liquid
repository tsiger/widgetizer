<section
  id="{{ widget.id }}"
  class="widget widget-type-checkerboard widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}{% if widget.settings.top_spacing != 'auto' %} spacing-top-{{ widget.settings.top_spacing }}{% endif %}{% if widget.settings.bottom_spacing != 'auto' %} spacing-bottom-{{ widget.settings.bottom_spacing }}{% endif %}"
  {% unless widget.settings.color_scheme == 'standard-primary' %}style="--widget-bg-color: var(--bg-primary);"{% endunless %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="checkerboard"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      & .checkerboard-grid {
        list-style: none;
        padding: 0;
        margin: 0;
      }

      & .checkerboard-item {
        position: relative;
        border-radius: var(--radius-lg);
        overflow: hidden;
        aspect-ratio: 1 / 1;
        border: var(--card-border);
      }

      & .checkerboard-item-image {
        width: 100%;
        height: 100%;

        & img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          display: block;
        }
      }

      & .checkerboard-item-content {
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        height: 100%;
        padding: var(--space-xl);
        background-color: var(--bg-primary);
      }

      & .checkerboard-item-content .w-title {
        margin-block-end: var(--space-md);
      }

      & .checkerboard-item-content .w-body {
        margin-block-end: var(--space-md);
      }

      & .checkerboard-item-content .widget-button {
        align-self: flex-start;
      }

      &.color-scheme-standard-secondary,
      &.color-scheme-highlight-secondary {
        & .checkerboard-item-content {
          background-color: var(--bg-secondary);
        }
      }

      &.color-scheme-standard-secondary,
      &.color-scheme-highlight-primary,
      &.color-scheme-highlight-secondary {
        & .checkerboard-item {
          border: var(--border-width-thin) solid var(--border-color);
        }
      }

      @media (max-width: 749px) {
        & .checkerboard-item-content {
          padding: var(--space-lg);
        }
      }
    }
  </style>

  <div class="widget-container{% unless widget.settings.color_scheme == 'standard-primary' %} widget-container-padded{% endunless %}">
    {% if widget.settings.title != blank or widget.settings.description != blank or widget.settings.eyebrow != blank %}
      <div class="widget-header{% if widget.settings.heading_alignment == 'start' %} widget-header--align-start{% endif %}">
        {% assign header_delay = 0 %}
        {% if widget.settings.eyebrow != blank %}
          <span class="w-eyebrow reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.title != blank %}
          {% if widget.index == 1 %}
            <h1 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h1>
          {% else %}
            <h2 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h2>
          {% endif %}
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.description != blank %}
          <p class="w-description reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="description">
            {{ widget.settings.description }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    <div class="widget-content">
      {% assign has_widget_title = false %}
      {% if widget.settings.title != blank %}
        {% assign has_widget_title = true %}
      {% endif %}

      {% assign card_heading_level = 'h2' %}
      {% if has_widget_title %}
        {% if widget.index == 1 %}
          {% assign card_heading_level = 'h2' %}
        {% else %}
          {% assign card_heading_level = 'h3' %}
        {% endif %}
      {% else %}
        {% if widget.index == 1 %}
          {% assign card_heading_level = 'h1' %}
        {% else %}
          {% assign card_heading_level = 'h2' %}
        {% endif %}
      {% endif %}

      <ul
        class="checkerboard-grid widget-grid"
        style="--grid-cols-desktop: {{ widget.settings.columns_desktop }};"
      >
        {% for blockId in widget.blocksOrder %}
          {% assign block = widget.blocks[blockId] %}

          {% assign current_card_level = card_heading_level %}
          {% if has_widget_title == false and widget.index == 1 %}
            {% if forloop.first %}
              {% assign current_card_level = 'h1' %}
            {% else %}
              {% assign current_card_level = 'h2' %}
            {% endif %}
          {% endif %}

          <li class="checkerboard-item reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
            {% if block.settings.image != blank %}
              <div class="checkerboard-item-image">
                {% image src: block.settings.image, size: 'medium', srcset: true, sizes: '(max-width: 749px) 100vw, 400px' %}
              </div>
            {% else %}
              <div class="checkerboard-item-content">
                {% if block.settings.title != blank %}
                  <{{ current_card_level }} class="w-title t-2xl" data-setting="title">{{ block.settings.title }}</{{ current_card_level }}>
                {% endif %}
                {% if block.settings.description != blank %}
                  <div class="w-body w-rte t-sm" data-setting="description">
                    {{ block.settings.description | raw }}
                  </div>
                {% endif %}
                {% if block.settings.button_link.text != blank %}
                  <a
                    href="{{ block.settings.button_link.href }}"
                    class="widget-button widget-button-secondary"
                    data-setting="button_link"
                    target="{{ block.settings.button_link.target | default: '_self' }}"
                  >
                    {{- block.settings.button_link.text -}}
                  </a>
                {% endif %}
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

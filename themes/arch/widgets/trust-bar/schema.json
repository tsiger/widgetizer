{
  "type": "trust-bar",
  "displayName": "tTheme:trust_bar.name",
  "aliases": [
    "usp",
    "features bar",
    "benefits",
    "selling points",
    "highlights bar"
  ],
  "settings": [
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "tTheme:global.widgets.settings.icon_style.label",
      "default": "plain",
      "options": [
        {
          "value": "plain",
          "label": "tTheme:global.widgets.settings.icon_style.options.plain"
        },
        {
          "value": "outline",
          "label": "tTheme:global.widgets.settings.icon_style.options.outline"
        },
        {
          "value": "filled",
          "label": "tTheme:global.widgets.settings.icon_style.options.filled"
        }
      ]
    },
    {
      "type": "select",
      "id": "icon_size",
      "label": "tTheme:global.widgets.settings.icon_size.label",
      "default": "lg",
      "options": [
        {
          "value": "sm",
          "label": "tTheme:global.widgets.settings.icon_size.options.sm"
        },
        {
          "value": "md",
          "label": "tTheme:global.widgets.settings.icon_size.options.md"
        },
        {
          "value": "lg",
          "label": "tTheme:global.widgets.settings.icon_size.options.lg"
        },
        {
          "value": "xl",
          "label": "tTheme:global.widgets.settings.icon_size.options.xl"
        }
      ]
    },
    {
      "type": "select",
      "id": "icon_shape",
      "label": "tTheme:global.widgets.settings.icon_shape.label",
      "default": "circle",
      "options": [
        {
          "value": "sharp",
          "label": "tTheme:global.widgets.settings.icon_shape.options.sharp"
        },
        {
          "value": "rounded",
          "label": "tTheme:global.widgets.settings.icon_shape.options.rounded"
        },
        {
          "value": "circle",
          "label": "tTheme:global.widgets.settings.icon_shape.options.circle"
        }
      ]
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "start",
      "options": [
        {
          "value": "start",
          "label": "tTheme:global.widgets.settings.alignment.options.start"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.alignment.options.center"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_dividers",
      "label": "tTheme:trust_bar.settings.show_dividers.label",
      "default": true
    },
    {
      "type": "header",
      "id": "widget_header",
      "label": "Widget"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard-primary",
      "options": [
        {
          "value": "standard-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_primary"
        },
        {
          "value": "standard-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_secondary"
        },
        {
          "value": "highlight-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_primary"
        },
        {
          "value": "highlight-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_secondary"
        }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.top_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.top_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.top_spacing.options.none"
        }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.none"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "displayName": "tTheme:trust_bar.blocks.item.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "icon",
          "id": "icon",
          "label": "tTheme:trust_bar.blocks.item.settings.icon.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:trust_bar.blocks.item.settings.title.label",
          "default": "Feature title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "tTheme:trust_bar.blocks.item.settings.text.label",
          "default": "Feature description"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "item",
      "settings": {
        "icon": "medal",
        "title": "Industry Experts",
        "text": "Experienced industry professionals"
      }
    },
    {
      "type": "item",
      "settings": {
        "icon": "star",
        "title": "Strategic Planning",
        "text": "Modern marketing & strategic planning"
      }
    },
    {
      "type": "item",
      "settings": {
        "icon": "shield",
        "title": "Web Solutions",
        "text": "Modern web design & ecommerce solutions"
      }
    },
    {
      "type": "item",
      "settings": {
        "icon": "headset",
        "title": "Client Support",
        "text": "24/7 online client support"
      }
    }
  ]
}

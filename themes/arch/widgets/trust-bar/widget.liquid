<section
  id="{{ widget.id }}"
  class="widget widget-trust-bar widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}{% if widget.settings.top_spacing != 'auto' %} spacing-top-{{ widget.settings.top_spacing }}{% endif %}{% if widget.settings.bottom_spacing != 'auto' %} spacing-bottom-{{ widget.settings.bottom_spacing }}{% endif %}"
  {% unless widget.settings.color_scheme == 'standard-primary' %}
    style="--widget-bg-color: var(--bg-primary);"
  {% endunless %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="trust-bar"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      & .trust-bar-list {
        display: flex;
        flex-direction: column;
        gap: var(--space-lg);
        list-style: none;
        padding: 0;
        margin: 0;
      }

      & .trust-bar-item {
        display: flex;
        align-items: center;
        gap: var(--space-md);
        {% if widget.settings.alignment == 'center' %}
        flex-direction: column;
        align-items: center;
        text-align: center;
        {% endif %}
      }

      & .trust-bar-icon-wrapper {
        flex-shrink: 0;
      }

      & .trust-bar-content {
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
        {% if widget.settings.alignment != 'center' %}
        flex: 1;
        {% endif %}
      }

      @media (min-width: 750px) {
        & .trust-bar-list {
          flex-direction: row;
          flex-wrap: wrap;
          justify-content: center;
          gap: 0;
        }

        & .trust-bar-item {
          flex: 1;
          min-width: 0;
          padding-block: var(--space-sm);
          {% if widget.settings.show_dividers %}
          padding-inline: var(--space-lg);
          border-inline-start: var(--border-width-thin) solid var(--border-color);
          {% else %}
          padding-inline: var(--space-md);
          {% endif %}
        }

        & .trust-bar-item:first-child {
          border-inline-start: none;
          {% if widget.settings.show_dividers %}
          padding-inline-start: 0;
          {% endif %}
        }

        & .trust-bar-item:last-child {
          {% if widget.settings.show_dividers %}
          padding-inline-end: 0;
          {% endif %}
        }
      }

      @media (min-width: 990px) {
        & .trust-bar-list {
          flex-wrap: nowrap;
        }
      }
    }
  </style>

  <div class="widget-container {% unless widget.settings.color_scheme == 'standard-primary' %}widget-container-padded{% endunless %}">
    <ul class="trust-bar-list">
      {% for blockId in widget.blocksOrder %}
        {% assign block = widget.blocks[blockId] %}
        <li class="trust-bar-item reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
          {% if block.settings.icon != blank %}
            {% render 'icon', icon: block.settings.icon, class: 'w-icon', style: widget.settings.icon_style, size: widget.settings.icon_size, shape: widget.settings.icon_shape %}
          {% endif %}
          <div class="trust-bar-content">
            {% if block.settings.title != blank %}
              <span class="w-title t-heading-font" data-setting="title">{{ block.settings.title }}</span>
            {% endif %}
            {% if block.settings.text != blank %}
              <span class="trust-bar-text w-body t-sm" data-setting="text">{{ block.settings.text }}</span>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>
  </div>
</section>

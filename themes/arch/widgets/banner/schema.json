{
  "type": "banner",
  "displayName": "tTheme:banner.name",
  "aliases": [
    "hero",
    "intro",
    "cover",
    "billboard",
    "jumbotron",
    "header",
    "splash"
  ],
  "settings": [
    {
      "type": "image",
      "id": "image",
      "label": "tTheme:banner.settings.image.label"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:banner.settings.display_header.label"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "tTheme:banner.settings.overlay_color.label",
      "default": "#0a1e38bf",
      "allow_alpha": true,
      "description": "tTheme:banner.settings.overlay_color.description"
    },
    {
      "type": "select",
      "id": "height",
      "label": "tTheme:banner.settings.height.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:banner.settings.height.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:banner.settings.height.options.small"
        },
        {
          "value": "medium",
          "label": "tTheme:banner.settings.height.options.medium"
        },
        {
          "value": "large",
          "label": "tTheme:banner.settings.height.options.large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "fullwidth",
      "label": "tTheme:banner.settings.fullwidth.label",
      "default": true
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "tTheme:banner.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "center",
          "label": "tTheme:banner.settings.alignment.options.center"
        },
        {
          "value": "start",
          "label": "tTheme:banner.settings.alignment.options.start"
        }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:banner.settings.color_scheme.label",
      "default": "highlight",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:banner.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:banner.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "displayName": "tTheme:banner.blocks.heading.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "tTheme:banner.blocks.heading.settings.text.label",
          "default": "Build your future"
        },
        {
          "type": "select",
          "id": "size",
          "label": "tTheme:banner.blocks.heading.settings.size.label",
          "default": "5xl",
          "options": [
            {
              "value": "lg",
              "label": "tTheme:banner.blocks.heading.settings.size.options.lg"
            },
            {
              "value": "xl",
              "label": "tTheme:banner.blocks.heading.settings.size.options.xl"
            },
            {
              "value": "2xl",
              "label": "tTheme:banner.blocks.heading.settings.size.options.2xl"
            },
            {
              "value": "3xl",
              "label": "tTheme:banner.blocks.heading.settings.size.options.3xl"
            },
            {
              "value": "4xl",
              "label": "tTheme:banner.blocks.heading.settings.size.options.4xl"
            },
            {
              "value": "5xl",
              "label": "tTheme:banner.blocks.heading.settings.size.options.5xl"
            },
            {
              "value": "6xl",
              "label": "tTheme:banner.blocks.heading.settings.size.options.6xl"
            },
            {
              "value": "7xl",
              "label": "tTheme:banner.blocks.heading.settings.size.options.7xl"
            },
            {
              "value": "8xl",
              "label": "tTheme:banner.blocks.heading.settings.size.options.8xl"
            },
            {
              "value": "9xl",
              "label": "tTheme:banner.blocks.heading.settings.size.options.9xl"
            }
          ]
        }
      ]
    },
    {
      "type": "text",
      "displayName": "tTheme:banner.blocks.text.name",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "tTheme:banner.blocks.text.settings.text.label",
          "default": "<p>Start your journey with our powerful platform.</p>"
        },
        {
          "type": "select",
          "id": "size",
          "label": "tTheme:banner.blocks.text.settings.size.label",
          "default": "lg",
          "options": [
            {
              "value": "sm",
              "label": "tTheme:banner.blocks.text.settings.size.options.sm"
            },
            {
              "value": "base",
              "label": "tTheme:banner.blocks.text.settings.size.options.base"
            },
            {
              "value": "lg",
              "label": "tTheme:banner.blocks.text.settings.size.options.lg"
            }
          ]
        },
        {
          "type": "checkbox",
          "id": "uppercase",
          "label": "tTheme:banner.blocks.text.settings.uppercase.label",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "muted",
          "label": "tTheme:banner.blocks.text.settings.muted.label",
          "default": false
        }
      ]
    },
    {
      "type": "button",
      "displayName": "tTheme:banner.blocks.button.name",
      "settings": [
        {
          "type": "link",
          "id": "link",
          "label": "tTheme:banner.blocks.button.settings.link.label",
          "default": {
            "text": "Get Started",
            "href": "#",
            "target": "_self"
          }
        },
        {
          "type": "select",
          "id": "style",
          "label": "tTheme:banner.blocks.button.settings.style.label",
          "default": "primary",
          "options": [
            {
              "value": "primary",
              "label": "tTheme:banner.blocks.button.settings.style.options.primary"
            },
            {
              "value": "secondary",
              "label": "tTheme:banner.blocks.button.settings.style.options.secondary"
            }
          ]
        },
        {
          "type": "link",
          "id": "link_2",
          "label": "tTheme:banner.blocks.button.settings.link_2.label"
        },
        {
          "type": "select",
          "id": "style_2",
          "label": "tTheme:banner.blocks.button.settings.style_2.label",
          "default": "secondary",
          "options": [
            {
              "value": "primary",
              "label": "tTheme:banner.blocks.button.settings.style_2.options.primary"
            },
            {
              "value": "secondary",
              "label": "tTheme:banner.blocks.button.settings.style_2.options.secondary"
            }
          ]
        },
        {
          "type": "select",
          "id": "size",
          "label": "tTheme:banner.blocks.button.settings.size.label",
          "default": "medium",
          "options": [
            {
              "value": "small",
              "label": "tTheme:banner.blocks.button.settings.size.options.small"
            },
            {
              "value": "medium",
              "label": "tTheme:banner.blocks.button.settings.size.options.medium"
            },
            {
              "value": "large",
              "label": "tTheme:banner.blocks.button.settings.size.options.large"
            },
            {
              "value": "xlarge",
              "label": "tTheme:banner.blocks.button.settings.size.options.xlarge"
            }
          ]
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "text",
      "settings": {
        "text": "<p>Welcome</p>",
        "size": "sm",
        "uppercase": false,
        "muted": false
      }
    },
    {
      "type": "heading",
      "settings": {
        "text": "Build your future",
        "size": "5xl"
      }
    },
    {
      "type": "text",
      "settings": {
        "text": "<p>Start your journey with our powerful platform. Scalable, secure, and ready for growth.</p>",
        "size": "lg",
        "uppercase": false,
        "muted": false
      }
    },
    {
      "type": "button",
      "settings": {
        "link": {
          "text": "Get Started",
          "href": "#",
          "target": "_self"
        },
        "style": "primary",
        "link_2": {
          "text": "Learn More",
          "href": "#",
          "target": "_self"
        },
        "style_2": "secondary"
      }
    }
  ]
}

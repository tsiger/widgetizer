{
  "type": "image-text",
  "displayName": "tTheme:image_text.name",
  "aliases": [
    "split layout",
    "visual content",
    "side by side",
    "media text"
  ],
  "settings": [
    {
      "type": "header",
      "id": "content_header",
      "label": "tTheme:image_text.settings.content_header.label"
    },
    {
      "type": "image",
      "id": "image",
      "label": "tTheme:image_text.settings.image.label"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:image_text.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "tTheme:image_text.settings.image_position.label",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "tTheme:image_text.settings.image_position.options.left"
        },
        {
          "value": "right",
          "label": "tTheme:image_text.settings.image_position.options.right"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "tTheme:image_text.settings.text_position.label",
      "default": "center",
      "options": [
        {
          "value": "flex-start",
          "label": "tTheme:image_text.settings.text_position.options.top"
        },
        {
          "value": "center",
          "label": "tTheme:image_text.settings.text_position.options.center"
        },
        {
          "value": "flex-end",
          "label": "tTheme:image_text.settings.text_position.options.bottom"
        }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:image_text.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:image_text.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:image_text.settings.color_scheme.options.highlight"
        }
      ]
    },
    {
      "type": "select",
      "id": "content_color_scheme",
      "label": "tTheme:image_text.settings.content_color_scheme.label",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "tTheme:image_text.settings.content_color_scheme.options.none"
        },
        {
          "value": "standard",
          "label": "tTheme:image_text.settings.content_color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:image_text.settings.content_color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "rating",
      "displayName": "tTheme:image_text.blocks.rating.name",
      "settings": [
        {
          "type": "select",
          "id": "rating",
          "label": "tTheme:image_text.blocks.rating.settings.rating.label",
          "options": [
            {
              "value": "5",
              "label": "tTheme:image_text.blocks.rating.settings.rating.options.5"
            },
            {
              "value": "4",
              "label": "tTheme:image_text.blocks.rating.settings.rating.options.4"
            },
            {
              "value": "3",
              "label": "tTheme:image_text.blocks.rating.settings.rating.options.3"
            }
          ],
          "default": "5"
        }
      ]
    },
    {
      "type": "image",
      "displayName": "tTheme:image_text.blocks.image.name",
      "settings": [
        {
          "type": "image",
          "id": "image",
          "label": "tTheme:image_text.blocks.image.settings.image.label"
        },
        {
          "type": "range",
          "id": "width",
          "label": "tTheme:image_text.blocks.image.settings.width.label",
          "default": 20,
          "min": 5,
          "max": 100,
          "step": 5
        }
      ]

            {
              "value": "8xl",
              "label": "tTheme:image_text.blocks.heading.settings.size.options.8xl"
            },
            {
              "value": "9xl",
              "label": "tTheme:image_text.blocks.heading.settings.size.options.9xl"
            }
          ]
        }
      ]
    },
    {
      "type": "text",
      "displayName": "tTheme:image_text.blocks.text.name",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "tTheme:image_text.blocks.text.settings.text.label",
          "default": "<p>A paragraph of descriptive text goes here.</p>"

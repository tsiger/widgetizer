{
  "type": "contact-form",
  "displayName": "tTheme:contact_form.name",
  "aliases": [
    "lead capture",
    "inquiry",
    "message",
    "feedback"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:contact_form.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:contact_form.settings.title.label",
      "default": "Get in Touch"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:contact_form.settings.description.label"
    },
    {
      "type": "header",
      "id": "form_header",
      "label": "tTheme:contact_form.settings.form_header.label"
    },
    {
      "type": "text",
      "id": "form_token",
      "label": "tTheme:contact_form.settings.form_token.label",
      "description": "tTheme:contact_form.settings.form_token.description"
    },
    {
      "type": "text",
      "id": "form_name",
      "label": "tTheme:contact_form.settings.form_name.label",
      "default": "Contact Form",
      "description": "tTheme:contact_form.settings.form_name.description"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:contact_form.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "sidebar_position",
      "label": "tTheme:contact_form.settings.sidebar_position.label",
      "default": "right",
      "options": [
        {
          "value": "left",
          "label": "tTheme:contact_form.settings.sidebar_position.options.left"
        },
        {
          "value": "right",
          "label": "tTheme:contact_form.settings.sidebar_position.options.right"
        }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:contact_form.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:contact_form.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:contact_form.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "input",
      "displayName": "tTheme:contact_form.blocks.input.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:contact_form.blocks.input.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "label",
          "label": "tTheme:contact_form.blocks.input.settings.label.label",
          "default": "Name"
        },
        {
          "type": "text",
          "id": "name",
          "label": "tTheme:contact_form.blocks.input.settings.name.label",
          "default": "name"
        },
        {
          "type": "select",
          "id": "input_type",
          "label": "tTheme:contact_form.blocks.input.settings.input_type.label",
          "default": "text",
          "options": [
            {
              "value": "text",
              "label": "tTheme:contact_form.blocks.input.settings.input_type.options.text"
            },
            {
              "value": "email",
              "label": "tTheme:contact_form.blocks.input.settings.input_type.options.email"
            },
            {
              "value": "tel",
              "label": "tTheme:contact_form.blocks.input.settings.input_type.options.tel"
            },
            {
              "value": "url",
              "label": "tTheme:contact_form.blocks.input.settings.input_type.options.url"
            },
            {
              "value": "number",
              "label": "tTheme:contact_form.blocks.input.settings.input_type.options.number"
            },
            {
              "value": "date",
              "label": "tTheme:contact_form.blocks.input.settings.input_type.options.date"
            }
          ]
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "tTheme:contact_form.blocks.input.settings.placeholder.label"
        },
        {
          "type": "header",
          "id": "options_header",
          "label": "tTheme:contact_form.blocks.input.settings.options_header.label"
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "tTheme:contact_form.blocks.input.settings.required.label",
          "default": false
        }
      ]
    },
    {
      "type": "textarea",
      "displayName": "tTheme:contact_form.blocks.textarea.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:contact_form.blocks.textarea.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "label",
          "label": "tTheme:contact_form.blocks.textarea.settings.label.label",
          "default": "Message"
        },
        {
          "type": "text",
          "id": "name",
          "label": "tTheme:contact_form.blocks.textarea.settings.name.label",
          "default": "message"
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "tTheme:contact_form.blocks.textarea.settings.placeholder.label"
        },
        {
          "type": "header",
          "id": "options_header",
          "label": "tTheme:contact_form.blocks.textarea.settings.options_header.label"
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "tTheme:contact_form.blocks.textarea.settings.required.label",
          "default": false
        }
      ]
    },
    {
      "type": "dropdown",
      "displayName": "tTheme:contact_form.blocks.dropdown.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:contact_form.blocks.dropdown.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "label",
          "label": "tTheme:contact_form.blocks.dropdown.settings.label.label",
          "default": "Subject"
        },
        {
          "type": "text",
          "id": "name",
          "label": "tTheme:contact_form.blocks.dropdown.settings.name.label",
          "default": "subject"
        },
        {
          "type": "textarea",
          "id": "options",
          "label": "tTheme:contact_form.blocks.dropdown.settings.options.label",
          "default": "General Inquiry\nSupport\nSales\nOther"
        },
        {
          "type": "header",
          "id": "options_header",
          "label": "tTheme:contact_form.blocks.dropdown.settings.options_header.label"
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "tTheme:contact_form.blocks.dropdown.settings.required.label",
          "default": false
        }
      ]
    },
    {
      "type": "checkbox",
      "displayName": "tTheme:contact_form.blocks.checkbox.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:contact_form.blocks.checkbox.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "label",
          "label": "tTheme:contact_form.blocks.checkbox.settings.label.label",
          "default": "I agree to the terms"
        },
        {
          "type": "text",
          "id": "name",
          "label": "tTheme:contact_form.blocks.checkbox.settings.name.label",
          "default": "agree"
        },
        {
          "type": "header",
          "id": "options_header",
          "label": "tTheme:contact_form.blocks.checkbox.settings.options_header.label"
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "tTheme:contact_form.blocks.checkbox.settings.required.label",
          "default": false
        }
      ]
    },
    {
      "type": "submit",
      "displayName": "tTheme:contact_form.blocks.submit.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:contact_form.blocks.submit.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "text",
          "label": "tTheme:contact_form.blocks.submit.settings.text.label",
          "default": "Send Message"
        }
      ]
    },
    {
      "type": "info",
      "displayName": "tTheme:contact_form.blocks.info.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:contact_form.blocks.info.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:contact_form.blocks.info.settings.title.label",
          "default": "Email Us"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "tTheme:contact_form.blocks.info.settings.text.label",
          "default": "<p>hello@example.com</p>"
        }
      ]
    },
    {
      "type": "social",
      "displayName": "tTheme:contact_form.blocks.social.name",
      "settings": []
    }
  ],
  "defaultBlocks": [
    {
      "type": "input",
      "settings": {
        "label": "Name",
        "name": "name",
        "input_type": "text",
        "placeholder": "Your name",
        "required": true
      }
    },
    {
      "type": "input",
      "settings": {
        "label": "Email",
        "name": "email",
        "input_type": "email",
        "placeholder": "your@email.com",
        "required": true
      }
    },
    {
      "type": "textarea",
      "settings": {
        "label": "Message",
        "name": "message",
        "placeholder": "Tell us how we can help...",
        "required": true
      }
    },
    {
      "type": "submit",
      "settings": {
        "text": "Send Message"
      }
    },
    {
      "type": "info",
      "settings": {
        "title": "Email Us",
        "text": "<p>hello@example.com</p>"
      }
    }
  ]
}

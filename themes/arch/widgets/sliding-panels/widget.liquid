{% enqueue_script src: "sliding-panels.js", defer: true, location: "footer", priority: 40, widget: true %}
<section
  id="{{ widget.id }}"
  class="widget widget-type-sliding-panels widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}"
  {% if widget.settings.color_scheme == 'highlight' %}style="--widget-bg-color: var(--bg-primary);"{% endif %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="sliding-panels"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      & .sliding-panels-container {
        display: flex;
        gap: var(--space-sm);
        height: 60rem;
      }

      & .sliding-panel {
        position: relative;
        flex: 1;
        overflow: hidden;
        border-radius: var(--radius-lg);
        cursor: pointer;
        transition: flex 0.5s ease;
      }

      & .sliding-panel.is-active {
        flex: 3;
      }

      & .sliding-panel-image {
        position: absolute;
        inset: 0;

        & img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          display: block;
        }
      }

      & .sliding-panel-content {
        position: absolute;
        inset-inline: 0;
        inset-block-end: 0;
        padding: var(--space-xl);
        background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 100%);
        color: var(--color-white);
        opacity: 0;
        transition: opacity 0.3s ease;
      }

      & .sliding-panel.is-active .sliding-panel-content {
        opacity: 1;
      }

      & .sliding-panel-title {
        margin: 0;
        color: var(--color-white);
      }

      & .sliding-panel-subtitle {
        margin: 0;
        margin-block-start: var(--space-xs);
        opacity: 0.8;
        color: var(--color-white);
      }

      & .sliding-panel-button {
        margin-block-start: var(--space-md);
      }

      @media (max-width: 749px) {
        & .sliding-panels-container {
          flex-direction: column;
          height: auto;
        }

        & .sliding-panel {
          height: 16rem;
          flex: none;
          transition: height 0.5s ease;
        }

        & .sliding-panel.is-active {
          height: 40rem;
          flex: none;
        }

        & .sliding-panel-content {
          opacity: 1;
        }
      }
    }
  </style>

  {% assign sliding_panel_sizes = '(max-width: 749px) 100vw, 50vw' %}
  <div class="{% if widget.settings.color_scheme == 'highlight' %}widget-container-padded{% else %}widget-container{% endif %}">
    {% if widget.settings.title != blank or widget.settings.description != blank or widget.settings.eyebrow != blank %}
      <div class="widget-header{% if widget.settings.heading_alignment == 'left' %} widget-header--align-start{% endif %}">
        {% assign header_delay = 0 %}
        {% if widget.settings.eyebrow != blank %}
          <span class="w-eyebrow reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.title != blank %}
          {% if widget.index == 1 %}
            <h1 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h1>
          {% else %}
            <h2 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h2>
          {% endif %}
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.description != blank %}
          <p class="w-description reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="description">
            {{ widget.settings.description }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    <div class="widget-content">
      {% assign has_widget_title = false %}
      {% if widget.settings.title != blank %}
        {% assign has_widget_title = true %}
      {% endif %}

      {% assign panel_heading_level = 'h2' %}
      {% if has_widget_title %}
        {% if widget.index == 1 %}
          {% assign panel_heading_level = 'h2' %}
        {% else %}
          {% assign panel_heading_level = 'h3' %}
        {% endif %}
      {% else %}
        {% if widget.index == 1 %}
          {% assign panel_heading_level = 'h1' %}
        {% else %}
          {% assign panel_heading_level = 'h2' %}
        {% endif %}
      {% endif %}

      <div class="sliding-panels-container reveal reveal-up">
        {% for blockId in widget.blocksOrder %}
          {% assign block = widget.blocks[blockId] %}

          {% assign current_heading_level = panel_heading_level %}
          {% if has_widget_title == false and widget.index == 1 %}
            {% if forloop.first %}
              {% assign current_heading_level = 'h1' %}
            {% else %}
              {% assign current_heading_level = 'h2' %}
            {% endif %}
          {% endif %}

          <div
            class="sliding-panel{% if forloop.first %} is-active{% endif %}"
            data-block-id="{{ blockId }}"
          >
            <div class="sliding-panel-image">
              {% if block.settings.image != blank %}
                {% image src: block.settings.image, size: 'large', srcset: true, sizes: sliding_panel_sizes %}
              {% else %}
                {% placeholder_image aspect: 'portrait' %}
              {% endif %}
            </div>

            <div class="sliding-panel-content color-scheme-highlight">
              {% if block.settings.title != blank %}
                <{{ current_heading_level }} class="sliding-panel-title w-title t-xl" data-setting="title">{{ block.settings.title }}</{{ current_heading_level }}>
              {% endif %}
              {% if block.settings.subtitle != blank %}
                <p class="sliding-panel-subtitle w-meta" data-setting="subtitle">{{ block.settings.subtitle }}</p>
              {% endif %}
              {% if block.settings.button_link.text != blank %}
                <a
                  href="{{ block.settings.button_link.href }}"
                  class="widget-button widget-button-secondary sliding-panel-button"
                  data-setting="button_link"
                  target="{{ block.settings.button_link.target | default: '_self' }}"
                >
                  {{- block.settings.button_link.text -}}
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

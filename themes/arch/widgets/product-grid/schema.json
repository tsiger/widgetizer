{
  "type": "product-grid",
  "displayName": "tTheme:product_grid.name",
  "aliases": [
    "shopify",
    "products",
    "collection",
    "shop",
    "store",
    "catalog",
    "ecommerce"
  ],
  "requiresThemeSetting": "shopify.store_domain",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label"
    },
    {
      "type": "checkbox",
      "id": "eyebrow_uppercase",
      "label": "tTheme:global.widgets.settings.eyebrow_uppercase.label",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "Shop"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label",
      "default": ""
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "start",
          "label": "tTheme:global.widgets.settings.alignment.options.start"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.alignment.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "content_header",
      "label": "tTheme:global.widgets.settings.content_header.label"
    },
    {
      "type": "text",
      "id": "collection_handle",
      "label": "tTheme:product_grid.settings.collection_handle.label",
      "description": "tTheme:product_grid.settings.collection_handle.description",
      "default": ""
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "tTheme:product_grid.settings.products_count.label",
      "default": 8,
      "min": 2,
      "max": 24,
      "step": 1
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "tTheme:product_grid.settings.button_text.label",
      "default": "Add to cart"
    },
    {
      "type": "checkbox",
      "id": "show_options",
      "label": "tTheme:product_grid.settings.show_options.label",
      "description": "tTheme:product_grid.settings.show_options.description",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "quick_view",
      "label": "tTheme:product_grid.settings.quick_view.label",
      "description": "tTheme:product_grid.settings.quick_view.description",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "tTheme:product_grid.settings.show_pagination.label",
      "description": "tTheme:product_grid.settings.show_pagination.description",
      "default": true
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "tTheme:global.widgets.settings.columns_desktop.label",
      "default": 4,
      "min": 2,
      "max": 5,
      "step": 1
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "tTheme:global.widgets.settings.aspect_ratio.label",
      "default": "1 / 1",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.auto"
        },
        {
          "value": "1 / 1",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.1 / 1"
        },
        {
          "value": "4 / 3",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.4 / 3"
        },
        {
          "value": "3 / 2",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.3 / 2"
        },
        {
          "value": "3 / 4",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.3 / 4"
        },
        {
          "value": "16 / 9",
          "label": "tTheme:global.widgets.settings.aspect_ratio.options.16 / 9"
        }
      ]
    },
    {
      "type": "header",
      "id": "appearance_header",
      "label": "tTheme:global.widgets.settings.appearance_header.label"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard-primary",
      "options": [
        {
          "value": "standard-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_primary"
        },
        {
          "value": "standard-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_secondary"
        },
        {
          "value": "highlight-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_primary"
        },
        {
          "value": "highlight-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_secondary"
        }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.top_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.top_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.top_spacing.options.none"
        }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.none"
        }
      ]
    }
  ],
  "blocks": [],
  "defaultBlocks": []
}

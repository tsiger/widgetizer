<section
  id="{{ widget.id }}"
  class="widget widget-type-social-icons widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}{% if widget.settings.top_spacing != 'auto' %} spacing-top-{{ widget.settings.top_spacing }}{% endif %}{% if widget.settings.bottom_spacing != 'auto' %} spacing-bottom-{{ widget.settings.bottom_spacing }}{% endif %}"
  {% unless widget.settings.color_scheme == 'standard-primary' %}
    style="--widget-bg-color: var(--bg-primary);"
  {% endunless %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="social-icons"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  {% if widget.settings.icon_size != 2.4 %}
    {% assign social_box_size = widget.settings.icon_size | default: 2.4 | plus: 1.6 %}
    <style>
      .widget-{{ widget.id }} .social-link {
        width: {{ social_box_size }}rem;
        height: {{ social_box_size }}rem;
      }
    </style>
  {% endif %}

  <div class="widget-container {% unless widget.settings.color_scheme == 'standard-primary' %}widget-container-padded{% endunless %}">
    {% if widget.settings.title != blank or widget.settings.description != blank or widget.settings.eyebrow != blank %}
      <div class="widget-header{% if widget.settings.heading_alignment == 'start' %} widget-header--align-start{% endif %}">
        {% assign header_delay = 0 %}
        {% if widget.settings.eyebrow != blank %}
          <span class="w-eyebrow{% if widget.settings.eyebrow_uppercase %} t-uppercase{% endif %} reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.title != blank %}
          {% if widget.index == 1 %}
            <h1 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h1>
          {% else %}
            <h2 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h2>
          {% endif %}
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.description != blank %}
          <p class="w-description reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="description">{{ widget.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="widget-content">
      <div
        class="social-links"
        style="justify-content: {% if widget.settings.heading_alignment == 'start' %}flex-start{% else %}center{% endif %};"
      >
        {% render 'social-icons', social: theme.social %}
      </div>
    </div>
  </div>
</section>

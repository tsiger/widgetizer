{
  "type": "comparison-table",
  "displayName": "Comparison Table",
  "aliases": [
    "pricing table",
    "features comparison",
    "specs",
    "benchmark"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Compare Our Plans"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Subheading"
    },
    {
      "type": "header",
      "id": "content_header",
      "label": "Content"
    },
    {
      "type": "text",
      "id": "feature_column_label",
      "label": "Feature column label",
      "default": "Features"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "Display"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "highlight",
          "label": "Highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "column",
      "displayName": "Column",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "Content"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Column name",
          "default": "Our Product"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge text (optional)"
        },
        {
          "type": "header",
          "id": "options_header",
          "label": "Options"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured (highlighted)",
          "default": false
        },
        {
          "type": "link",
          "id": "link",
          "label": "CTA Button"
        }
      ]
    },
    {
      "type": "feature",
      "displayName": "Feature Row",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "Content"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Feature name",
          "default": "Feature Name"
        },
        {
          "type": "textarea",
          "id": "values",
          "label": "Values for each column (one per line: yes, no, or custom text)",
          "default": "yes\nyes\nno"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "column",
      "settings": {
        "name": "Free",
        "featured": false,
        "link": { "text": "Get Started", "href": "#", "target": "_self" }
      }
    },
    {
      "type": "column",
      "settings": {
        "name": "Pro",
        "featured": true,
        "badge": "Popular",
        "link": { "text": "Get Started", "href": "#", "target": "_self" }
      }
    },
    {
      "type": "column",
      "settings": {
        "name": "Enterprise",
        "featured": false,
        "link": { "text": "Contact Us", "href": "#", "target": "_self" }
      }
    },
    {
      "type": "feature",
      "settings": {
        "name": "Basic Features",
        "values": "yes\nyes\nyes"
      }
    },
    {
      "type": "feature",
      "settings": {
        "name": "Advanced Analytics",
        "values": "no\nyes\nyes"
      }
    },
    {
      "type": "feature",
      "settings": {
        "name": "Priority Support",
        "values": "no\nno\nyes"
      }
    }
  ]
}

{
  "type": "comparison-table",
  "displayName": "tTheme:comparison_table.name",
  "aliases": [
    "pricing table",
    "features comparison",
    "specs",
    "benchmark"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label"
    },
    {
      "type": "checkbox",
      "id": "eyebrow_uppercase",
      "label": "tTheme:global.widgets.settings.eyebrow_uppercase.label",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "Compare Our Plans"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "start",
          "label": "tTheme:global.widgets.settings.alignment.options.start"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.alignment.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "content_header",
      "label": "tTheme:global.widgets.settings.content_header.label"
    },
    {
      "type": "text",
      "id": "feature_column_label",
      "label": "tTheme:comparison_table.settings.feature_column_label.label",
      "default": "Features"
    },
    {
      "type": "header",
      "id": "appearance_header",
      "label": "tTheme:global.widgets.settings.appearance_header.label"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard-primary",
      "options": [
        {
          "value": "standard-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_primary"
        },
        {
          "value": "standard-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_secondary"
        },
        {
          "value": "highlight-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_primary"
        },
        {
          "value": "highlight-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_secondary"
        }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.top_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.top_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.top_spacing.options.none"
        }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.none"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "column",
      "displayName": "tTheme:comparison_table.blocks.column.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "name",
          "label": "tTheme:comparison_table.blocks.column.settings.name.label",
          "default": "Our Product"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "tTheme:comparison_table.blocks.column.settings.badge.label"
        },
        {
          "type": "link",
          "id": "link",
          "label": "tTheme:comparison_table.blocks.column.settings.link.label"
        },
        {
          "type": "header",
          "id": "display_header",
          "label": "tTheme:global.widgets.settings.display_header.label"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "tTheme:comparison_table.blocks.column.settings.featured.label",
          "default": false
        }
      ]
    },
    {
      "type": "feature",
      "displayName": "tTheme:comparison_table.blocks.feature.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "name",
          "label": "tTheme:comparison_table.blocks.feature.settings.name.label",
          "default": "Feature Name"
        },
        {
          "type": "textarea",
          "id": "values",
          "label": "tTheme:comparison_table.blocks.feature.settings.values.label",
          "default": "yes\nyes\nno"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "column",
      "settings": {
        "name": "Free",
        "featured": false,
        "link": {
          "text": "Get Started",
          "href": "#",
          "target": "_self"
        }
      }
    },
    {
      "type": "column",
      "settings": {
        "name": "Pro",
        "featured": true,
        "badge": "Popular",
        "link": {
          "text": "Get Started",
          "href": "#",
          "target": "_self"
        }
      }
    },
    {
      "type": "column",
      "settings": {
        "name": "Enterprise",
        "featured": false,
        "link": {
          "text": "Contact Us",
          "href": "#",
          "target": "_self"
        }
      }
    },
    {
      "type": "feature",
      "settings": {
        "name": "Basic Features",
        "values": "yes\nyes\nyes"
      }
    },
    {
      "type": "feature",
      "settings": {
        "name": "Advanced Analytics",
        "values": "no\nyes\nyes"
      }
    },
    {
      "type": "feature",
      "settings": {
        "name": "Priority Support",
        "values": "no\nno\nyes"
      }
    }
  ]
}

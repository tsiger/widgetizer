  "displayName": "tTheme:numbered_cards.name",
  "aliases": [
    "steps",
    "process",
    "workflow",
    "ordered list"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:numbered_cards.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:numbered_cards.settings.title.label",
      "default": "Our Process"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:numbered_cards.settings.description.label"
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:numbered_cards.settings.display_header.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "tTheme:numbered_cards.settings.columns_desktop.label",

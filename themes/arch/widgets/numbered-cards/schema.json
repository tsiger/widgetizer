      "options": [
        {
          "value": "grid",
          "label": "tTheme:numbered_cards.settings.layout.options.grid"
        },
        {
          "value": "carousel",
          "label": "tTheme:numbered_cards.settings.layout.options.carousel"
        }
      ]
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:numbered_cards.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:numbered_cards.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:numbered_cards.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "step",
      "displayName": "tTheme:numbered_cards.blocks.step.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:numbered_cards.blocks.step.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:numbered_cards.blocks.step.settings.title.label",
          "default": "Step Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "tTheme:numbered_cards.blocks.step.settings.description.label",
          "default": "<p>Describe this step in the process.</p>"

{
  "type": "numbered-cards",
  "displayName": "tTheme:numbered_cards.name",
  "aliases": [
    "steps",
    "process",
    "workflow",
    "ordered list"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label"
    },
    {
      "type": "checkbox",
      "id": "eyebrow_uppercase",
      "label": "tTheme:global.widgets.settings.eyebrow_uppercase.label",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "Our Process"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "start",
          "label": "tTheme:global.widgets.settings.alignment.options.start"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.alignment.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "tTheme:global.widgets.settings.layout.label",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "tTheme:global.widgets.settings.layout.options.grid"
        },
        {
          "value": "carousel",
          "label": "tTheme:global.widgets.settings.layout.options.carousel"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "tTheme:global.widgets.settings.columns_desktop.label",
      "default": 4,
      "min": 2,
      "max": 5,
      "step": 1
    },
    {
      "type": "header",
      "id": "cards_header",
      "label": "tTheme:global.widgets.settings.cards_header.label"
    },
    {
      "type": "select",
      "id": "card_layout",
      "label": "tTheme:global.widgets.settings.card_layout.label",
      "default": "box",
      "options": [
        {
          "value": "box",
          "label": "tTheme:global.widgets.settings.card_layout.options.box"
        },
        {
          "value": "flat",
          "label": "tTheme:global.widgets.settings.card_layout.options.flat"
        }
      ]
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "start",
      "options": [
        {
          "value": "start",
          "label": "tTheme:global.widgets.settings.alignment.options.start"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.alignment.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "appearance_header",
      "label": "tTheme:global.widgets.settings.appearance_header.label"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard-primary",
      "options": [
        {
          "value": "standard-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_primary"
        },
        {
          "value": "standard-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_secondary"
        },
        {
          "value": "highlight-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_primary"
        },
        {
          "value": "highlight-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_secondary"
        }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.top_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.top_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.top_spacing.options.none"
        }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.none"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "step",
      "displayName": "tTheme:numbered_cards.blocks.step.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:numbered_cards.blocks.step.settings.title.label",
          "default": "Step Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "tTheme:numbered_cards.blocks.step.settings.description.label",
          "default": "<p>Describe this step in the process.</p>"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "step",
      "settings": {
        "title": "Consultation",
        "description": "<p>Schedule a free consultation to discuss your goals and requirements.</p>"
      }
    },
    {
      "type": "step",
      "settings": {
        "title": "Planning",
        "description": "<p>We create a detailed plan tailored to your specific needs.</p>"
      }
    },
    {
      "type": "step",
      "settings": {
        "title": "Execution",
        "description": "<p>Our team implements the solution with precision and care.</p>"
      }
    },
    {
      "type": "step",
      "settings": {
        "title": "Delivery",
        "description": "<p>We launch, monitor results, and optimize for long-term success.</p>"
      }
    }
  ]
}

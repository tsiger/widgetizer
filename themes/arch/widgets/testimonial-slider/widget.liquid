{% enqueue_script src: "testimonial-slider.js", defer: true, location: "footer", priority: 40, widget: true %}
<section
  id="{{ widget.id }}"
  class="widget widget-type-testimonial-slider widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}{% if widget.settings.top_spacing != 'auto' %} spacing-top-{{ widget.settings.top_spacing }}{% endif %}{% if widget.settings.bottom_spacing != 'auto' %} spacing-bottom-{{ widget.settings.bottom_spacing }}{% endif %}"
  {% unless widget.settings.color_scheme == 'standard' %}style="--widget-bg-color: var(--bg-primary);"{% endunless %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="testimonial-slider"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
  data-autoplay="{{ widget.settings.autoplay }}"
  data-autoplay-speed="{{ widget.settings.autoplay_speed }}"
>
  <style>
    .widget-{{ widget.id }} {
      & .testimonial-slider-track {
        position: relative;
        width: 100%;
      }

      & .testimonial-slider-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.6s ease-in-out;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: var(--space-2xl) var(--space-xl);

        &.is-active {
          opacity: 1;
          z-index: 1;
          position: relative;
        }
      }

      & .testimonial-slider-rating {
        display: flex;
        gap: 0.2rem;
        margin-block-end: var(--space-xl);
      }

      & .testimonial-slider-star {
        color: var(--rating-star-color);
        font-size: var(--font-size-xl);
        line-height: 1;
      }

      & .testimonial-slider-star.empty {
        color: var(--border-color);
      }

      & .testimonial-slider-quote {
        max-width: var(--content-width-lg);
        margin: 0 0 var(--space-2xl) 0;
        font-style: normal;
      }

      & .testimonial-slider-author {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-sm);
      }

      & .testimonial-slider-avatar {
        width: 6.4rem;
        height: 6.4rem;
        border-radius: 50%;
        object-fit: cover;
      }

      & .testimonial-slider-info {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-2xs);
      }

      & .testimonial-slider-pagination {
        display: flex;
        justify-content: center;
        gap: var(--space-sm);
        padding-block-start: var(--space-xl);
      }

      & .testimonial-slider-dot {
        width: 1rem;
        height: 1rem;
        border-radius: 50%;
        background-color: var(--text-content);
        opacity: 0.3;
        border: none;
        cursor: pointer;
        transition: opacity 0.3s, transform 0.3s;
        padding: 0;

        &:hover,
        &.is-active {
          opacity: 1;
        }

        &.is-active {
          transform: scale(1.2);
          background-color: var(--accent);
        }
      }

      @media (max-width: 749px) {
        & .testimonial-slider-slide {
          padding: var(--space-lg) var(--space-md);
        }

        & .testimonial-slider-avatar {
          width: 4.8rem;
          height: 4.8rem;
        }
      }
    }
  </style>

  <div class="widget-container{% unless widget.settings.color_scheme == 'standard' %} widget-container-padded{% endunless %}">
    <div class="widget-content">
      <div class="testimonial-slider-track">
        {% for blockId in widget.blocksOrder %}
          {% assign block = widget.blocks[blockId] %}
          <div
            class="testimonial-slider-slide{% if forloop.first %} is-active{% endif %}"
            data-block-id="{{ blockId }}"
            aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
          >
            {% if block.settings.rating != blank %}
              <div class="testimonial-slider-rating">
                {% assign rating = block.settings.rating | plus: 0 %}
                <span class="stars" aria-hidden="true">
                  {% for i in (1..5) %}
                    {% if i <= rating %}
                      <span class="testimonial-slider-star">★</span>
                    {% else %}
                      <span class="testimonial-slider-star empty">★</span>
                    {% endif %}
                  {% endfor %}
                </span>
                <span class="visually-hidden">
                  Rated {{ rating }} out of 5
                </span>
              </div>
            {% endif %}

            {% if block.settings.quote != blank %}
              <blockquote class="testimonial-slider-quote w-body t-xl" data-setting="quote">
                {{ block.settings.quote }}
              </blockquote>
            {% endif %}

            <div class="testimonial-slider-author">
              {% if block.settings.avatar != blank %}
                {% image src: block.settings.avatar, size: 'small', class: 'testimonial-slider-avatar' %}
              {% endif %}

              <div class="testimonial-slider-info">
                {% if block.settings.name != blank %}
                  <p class="w-body t-semibold t-heading" data-setting="name">{{ block.settings.name }}</p>
                {% endif %}
                {% if block.settings.title != blank %}
                  <p class="w-meta t-sm" data-setting="title">{{ block.settings.title }}</p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if widget.blocksOrder.size > 1 %}
        <div class="testimonial-slider-pagination">
          {% for blockId in widget.blocksOrder %}
            <button
              type="button"
              class="testimonial-slider-dot{% if forloop.first %} is-active{% endif %}"
              data-index="{{ forloop.index0 }}"
              aria-label="Go to testimonial {{ forloop.index }}"
            ></button>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<section
  id="{{ widget.id }}"
  class="widget widget-type-steps widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}"
  {% if widget.settings.color_scheme == 'highlight' %}style="--widget-bg-color: var(--bg-primary);"{% endif %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="steps"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      & .steps-list {
        display: flex;
        flex-direction: column;
      }

      & .steps-item {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: var(--space-2xl);
        align-items: start;
        padding-block: var(--space-2xl);

        &:first-child {
          padding-block-start: 0;
        }

        &:last-child {
          padding-block-end: 0;
        }
      }

      & .steps-image {
        border-radius: var(--radius-lg);
        overflow: hidden;

        & img {
          width: 100%;
          height: auto;
          display: block;
        }
      }

      & .steps-badge-col {
        align-self: stretch;
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
      }

      & .steps-badge-col::before {
        content: '';
        position: absolute;
        top: calc(-1 * var(--space-2xl));
        bottom: calc(-1 * var(--space-2xl));
        left: 50%;
        width: var(--border-width-thin);
        background-color: var(--border-color);
        transform: translateX(-50%);
      }

      & .steps-item:first-child .steps-badge-col::before {
        top: 2.4rem;
      }

      & .steps-item:last-child .steps-badge-col::before {
        bottom: 2.4rem;
      }

      & .steps-badge {
        position: relative;
        z-index: 1;
        width: 4.8rem;
        height: 4.8rem;
        border-radius: 50%;
        background-color: var(--accent);
        color: var(--accent-text);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: var(--font-size-lg);
        font-weight: 600;
        flex-shrink: 0;
      }

      & .steps-content {
        display: flex;
        flex-direction: column;
        gap: var(--space-md);
      }

      & .steps-content .w-title {
        margin: 0;
      }

      & .steps-content .w-body {
        margin: 0;
      }

      /* Even rows: text left, badge center, image right */
      & .steps-item:nth-child(even) {
        & .steps-image {
          order: 3;
        }

        & .steps-badge-col {
          order: 2;
        }

        & .steps-content {
          order: 1;
        }
      }

      @media (max-width: 749px) {
        & .steps-item {
          grid-template-columns: 1fr;
          gap: var(--space-lg);
          text-align: center;
        }

        & .steps-badge-col {
          margin-inline: auto;
          align-self: auto;
        }

        & .steps-badge-col::before {
          display: none;
        }

        & .steps-image {
          order: 2 !important;
        }

        & .steps-badge-col {
          order: 1 !important;
        }

        & .steps-content {
          order: 3 !important;
          align-items: center;
        }
      }
    }
  </style>

  {% assign steps_image_sizes = '(max-width: 749px) 100vw, (max-width: 1420px) 40vw, 560px' %}
  <div class="{% if widget.settings.color_scheme == 'highlight' %}widget-container-padded{% else %}widget-container{% endif %}">
    {% if widget.settings.title != blank or widget.settings.description != blank or widget.settings.eyebrow != blank %}
      <div class="widget-header{% if widget.settings.heading_alignment == 'left' %} widget-header--align-start{% endif %}">
        {% assign header_delay = 0 %}
        {% if widget.settings.eyebrow != blank %}
          <span class="w-eyebrow reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.title != blank %}
          {% if widget.index == 1 %}
            <h1 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h1>
          {% else %}
            <h2 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h2>
          {% endif %}
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.description != blank %}
          <p class="w-description reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="description">
            {{ widget.settings.description }}
          </p>
        {% endif %}
      </div>
    {% endif %}

    <div class="widget-content">
      {% assign has_widget_title = false %}
      {% if widget.settings.title != blank %}
        {% assign has_widget_title = true %}
      {% endif %}

      {% assign step_heading_level = 'h2' %}
      {% if has_widget_title %}
        {% if widget.index == 1 %}
          {% assign step_heading_level = 'h2' %}
        {% else %}
          {% assign step_heading_level = 'h3' %}
        {% endif %}
      {% else %}
        {% if widget.index == 1 %}
          {% assign step_heading_level = 'h1' %}
        {% else %}
          {% assign step_heading_level = 'h2' %}
        {% endif %}
      {% endif %}

      <div class="steps-list">
        {% for blockId in widget.blocksOrder %}
          {% assign block = widget.blocks[blockId] %}

          {% assign current_heading_level = step_heading_level %}
          {% if has_widget_title == false and widget.index == 1 %}
            {% if forloop.first %}
              {% assign current_heading_level = 'h1' %}
            {% else %}
              {% assign current_heading_level = 'h2' %}
            {% endif %}
          {% endif %}

          <div class="steps-item reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
            <div class="steps-image">
              {% if block.settings.image != blank %}
                {% image src: block.settings.image, size: 'medium', srcset: true, sizes: steps_image_sizes %}
              {% endif %}
            </div>

            <div class="steps-badge-col">
              <div class="steps-badge" aria-hidden="true">
                {{ forloop.index }}
              </div>
            </div>

            <div class="steps-content">
              {% if block.settings.title != blank %}
                <{{ current_heading_level }} class="w-title t-3xl" data-setting="title">{{ block.settings.title }}</{{ current_heading_level }}>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="w-body w-rte" data-setting="description">
                  {{ block.settings.description | raw }}
                </div>
              {% endif %}
              {% if block.settings.button_link.text != blank %}
                <div>
                  <a
                    href="{{ block.settings.button_link.href }}"
                    class="widget-button widget-button-secondary"
                    data-setting="button_link"
                    target="{{ block.settings.button_link.target | default: '_self' }}"
                  >
                    {{- block.settings.button_link.text -}}
                  </a>
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{
  "type": "steps",
  "displayName": "tTheme:steps.name",
  "aliases": [
    "process",
    "numbered steps",
    "how it works",
    "timeline",
    "workflow"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "How It Works"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "tTheme:global.widgets.settings.options.left"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "widget_header",
      "label": "Widget"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard"
        },
        {
          "value": "standard-accent",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_accent"
        },
        {
          "value": "highlight",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight"
        },
        {
          "value": "highlight-accent",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_accent"
        }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.top_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.top_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.top_spacing.options.none"
        }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.none"
        }
      ]
    }
  ],
  "maxBlocks": 8,
  "blocks": [
    {
      "type": "step",
      "displayName": "tTheme:steps.blocks.step.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "image",
          "id": "image",
          "label": "tTheme:steps.blocks.step.settings.image.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:steps.blocks.step.settings.title.label",
          "default": "Step Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "tTheme:steps.blocks.step.settings.description.label",
          "default": "<p>Describe this step in your process.</p>"
        },
        {
          "type": "link",
          "id": "button_link",
          "label": "tTheme:global.widgets.settings.button_link.label"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "step",
      "settings": {
        "title": "We provide exceptional design services",
        "description": "<p>Don't miss out on the chance to transform your space into something extraordinary. Reach out to us for a complimentary consultation.</p>"
      }
    },
    {
      "type": "step",
      "settings": {
        "title": "Your partner in design excellence",
        "description": "<p>Take the first step towards success today by contacting us for a free consultation. Let's achieve your goals together.</p>"
      }
    },
    {
      "type": "step",
      "settings": {
        "title": "Bringing your vision to life",
        "description": "<p>We work closely with you to ensure every detail is perfect. From concept to completion, we're with you every step of the way.</p>"
      }
    }
  ]
}

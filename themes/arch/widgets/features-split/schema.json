{
  "type": "features-split",
  "displayName": "tTheme:features_split.name",
  "aliases": [
    "services split",
    "markets",
    "audience",
    "segments",
    "two column features"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label",
      "default": "Our Markets"
    },
    {
      "type": "checkbox",
      "id": "eyebrow_uppercase",
      "label": "tTheme:global.widgets.settings.eyebrow_uppercase.label",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "Optimal Solution For Every Business"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label",
      "default": "We combine industry expertise with innovative technology to deliver solutions that drive real results. Our approach is tailored to meet the unique challenges of each market segment we serve."
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "start",
          "label": "tTheme:global.widgets.settings.alignment.options.start"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.alignment.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "tTheme:features_split.settings.content_position.label",
      "default": "start",
      "options": [
        {
          "value": "start",
          "label": "tTheme:global.widgets.settings.options.start"
        },
        {
          "value": "end",
          "label": "tTheme:global.widgets.settings.options.end"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "tTheme:features_split.settings.show_divider.label",
      "default": true
    },
    {
      "type": "header",
      "id": "icon_header",
      "label": "tTheme:global.widgets.settings.icon_header.label"
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "tTheme:global.widgets.settings.icon_style.label",
      "default": "plain",
      "options": [
        {
          "value": "plain",
          "label": "tTheme:global.widgets.settings.icon_style.options.plain"
        },
        {
          "value": "outline",
          "label": "tTheme:global.widgets.settings.icon_style.options.outline"
        },
        {
          "value": "filled",
          "label": "tTheme:global.widgets.settings.icon_style.options.filled"
        }
      ]
    },
    {
      "type": "select",
      "id": "icon_size",
      "label": "tTheme:global.widgets.settings.icon_size.label",
      "default": "xl",
      "options": [
        {
          "value": "sm",
          "label": "tTheme:global.widgets.settings.icon_size.options.sm"
        },
        {
          "value": "md",
          "label": "tTheme:global.widgets.settings.icon_size.options.md"
        },
        {
          "value": "lg",
          "label": "tTheme:global.widgets.settings.icon_size.options.lg"
        },
        {
          "value": "xl",
          "label": "tTheme:global.widgets.settings.icon_size.options.xl"
        }
      ]
    },
    {
      "type": "select",
      "id": "icon_shape",
      "label": "tTheme:global.widgets.settings.icon_shape.label",
      "default": "circle",
      "options": [
        {
          "value": "sharp",
          "label": "tTheme:global.widgets.settings.icon_shape.options.sharp"
        },
        {
          "value": "rounded",
          "label": "tTheme:global.widgets.settings.icon_shape.options.rounded"
        },
        {
          "value": "circle",
          "label": "tTheme:global.widgets.settings.icon_shape.options.circle"
        }
      ]
    },
    {
      "type": "header",
      "id": "appearance_header",
      "label": "tTheme:global.widgets.settings.appearance_header.label"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard-primary",
      "options": [
        {
          "value": "standard-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_primary"
        },
        {
          "value": "standard-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard_secondary"
        },
        {
          "value": "highlight-primary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_primary"
        },
        {
          "value": "highlight-secondary",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight_secondary"
        }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "tTheme:global.widgets.settings.top_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.top_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.top_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.top_spacing.options.none"
        }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "tTheme:global.widgets.settings.bottom_spacing.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.auto"
        },
        {
          "value": "small",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.small"
        },
        {
          "value": "none",
          "label": "tTheme:global.widgets.settings.bottom_spacing.options.none"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "displayName": "tTheme:features_split.blocks.feature.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "icon",
          "id": "icon",
          "label": "tTheme:features_split.blocks.feature.settings.icon.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:features_split.blocks.feature.settings.title.label",
          "default": "Feature Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "tTheme:features_split.blocks.feature.settings.description.label",
          "default": "<p>Feature description goes here.</p>"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "feature",
      "settings": {
        "icon": "user",
        "title": "Private entrepreneurs",
        "description": "<p>Tailored solutions for independent professionals looking to streamline operations and accelerate growth.</p>"
      }
    },
    {
      "type": "feature",
      "settings": {
        "icon": "users",
        "title": "Small & medium companies",
        "description": "<p>Scalable tools designed to help growing teams collaborate effectively and compete with larger organizations.</p>"
      }
    },
    {
      "type": "feature",
      "settings": {
        "icon": "building",
        "title": "Large companies",
        "description": "<p>Enterprise-grade features with dedicated support to meet the demands of complex organizational structures.</p>"
      }
    }
  ]
}

{
  "type": "features-split",
  "displayName": "tTheme:features_split.name",
  "aliases": [
    "services split",
    "markets",
    "audience",
    "segments",
    "two column features"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:features_split.settings.eyebrow.label",
      "default": "Our Markets"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:features_split.settings.title.label",
      "default": "Optimal Solution For Every Business"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:features_split.settings.description.label",
      "default": "We combine industry expertise with innovative technology to deliver solutions that drive real results. Our approach is tailored to meet the unique challenges of each market segment we serve."
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:features_split.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "tTheme:features_split.settings.icon_style.label",
      "default": "plain",
      "options": [
        {
          "value": "plain",
          "label": "tTheme:features_split.settings.icon_style.options.plain"
        },
        {
          "value": "outline",
          "label": "tTheme:features_split.settings.icon_style.options.outline"
        },
        {
          "value": "filled",
          "label": "tTheme:features_split.settings.icon_style.options.filled"
        }
      ]
    },
    {
      "type": "select",
      "id": "icon_size",
      "label": "tTheme:features_split.settings.icon_size.label",
      "default": "xl",
      "options": [
        {
          "value": "sm",
          "label": "tTheme:features_split.settings.icon_size.options.sm"
        },
        {
          "value": "md",
          "label": "tTheme:features_split.settings.icon_size.options.md"
        },
        {
          "value": "lg",
          "label": "tTheme:features_split.settings.icon_size.options.lg"
        },
        {
          "value": "xl",
          "label": "tTheme:features_split.settings.icon_size.options.xl"
        }
      ]
    },
    {
      "type": "select",
      "id": "icon_shape",
      "label": "tTheme:features_split.settings.icon_shape.label",
      "default": "circle",
      "options": [
        {
          "value": "sharp",
          "label": "tTheme:features_split.settings.icon_shape.options.sharp"
        },
        {
          "value": "rounded",
          "label": "tTheme:features_split.settings.icon_shape.options.rounded"
        },
        {
          "value": "circle",
          "label": "tTheme:features_split.settings.icon_shape.options.circle"
        }
      ]
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "tTheme:features_split.settings.content_position.label",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "tTheme:features_split.settings.content_position.options.left"
        },
        {
          "value": "right",
          "label": "tTheme:features_split.settings.content_position.options.right"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "tTheme:features_split.settings.show_divider.label",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:features_split.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:features_split.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:features_split.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "displayName": "tTheme:features_split.blocks.feature.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:features_split.blocks.feature.settings.content_header.label"
        },
        {
          "type": "icon",
          "id": "icon",
          "label": "tTheme:features_split.blocks.feature.settings.icon.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:features_split.blocks.feature.settings.title.label",
          "default": "Feature Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "tTheme:features_split.blocks.feature.settings.description.label",
          "default": "<p>Feature description goes here.</p>"
        }
      ]
    }
  ],
  "defaultBlocks": [
    {
      "type": "feature",
      "settings": {
        "icon": "user",
        "title": "Private entrepreneurs",
        "description": "<p>Tailored solutions for independent professionals looking to streamline operations and accelerate growth.</p>"
      }
    },
    {
      "type": "feature",
      "settings": {
        "icon": "users",
        "title": "Small & medium companies",
        "description": "<p>Scalable tools designed to help growing teams collaborate effectively and compete with larger organizations.</p>"
      }
    },
    {
      "type": "feature",
      "settings": {
        "icon": "building",
        "title": "Large companies",
        "description": "<p>Enterprise-grade features with dedicated support to meet the demands of complex organizational structures.</p>"
      }
    }
  ]
}

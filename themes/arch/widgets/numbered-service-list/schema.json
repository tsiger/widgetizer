        {
          "type": "richtext",
          "id": "description",
          "label": "tTheme:numbered_service_list.blocks.service.settings.description.label",
          "default": "<p>Describe the service offering, business outcomes, and the value it creates for clients.</p>"
        },
        {
          "type": "link",
          "id": "link",
          "label": "tTheme:numbered_service_list.blocks.service.settings.link.label",
          "default": {
            "text": "Learn More",
            "href": "#",

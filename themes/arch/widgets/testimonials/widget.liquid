{% if widget.settings.layout == 'carousel' %}
  {% enqueue_script src: "carousel.js", defer: true, location: "footer", priority: 40, theme: true %}
{% endif %}
<section
  id="{{ widget.id }}"
  class="widget widget-type-testimonials widget-{{ widget.id }} color-scheme-{{ widget.settings.color_scheme }}{% if widget.settings.card_layout == 'flat' %} card-layout-flat{% endif %}{% if widget.settings.top_spacing != 'auto' %} spacing-top-{{ widget.settings.top_spacing }}{% endif %}{% if widget.settings.bottom_spacing != 'auto' %} spacing-bottom-{{ widget.settings.bottom_spacing }}{% endif %}"
  {% unless widget.settings.color_scheme == 'standard-primary' %}
    style="--widget-bg-color: var(--bg-primary);"
  {% endunless %}
  data-widget-id="{{ widget.id }}"
  data-widget-type="testimonials"
  {% if widget.index != null %}data-widget-index="{{ widget.index }}"{% endif %}
>
  <style>
    .widget-{{ widget.id }} {
      & .testimonial-quote {
        margin: 0 0 var(--space-lg) 0;
        position: relative;
      }

      & .testimonial-rating {
        display: flex;
        gap: 0.2rem;
        margin-block-end: var(--space-md);
      }

      & .testimonial-star {
        color: var(--rating-star-color);
        font-size: var(--font-size-lg);
        line-height: 1;
      }

      & .testimonial-star.empty {
        color: var(--border-color);
      }

      & .testimonial-author {
        display: flex;
        align-items: center;
        gap: var(--space-md);
        margin-block-start: auto;
      }

      & .testimonial-author-no-avatar {
        gap: 0;
      }

      & .testimonial-avatar {
        width: 4.8rem;
        height: 4.8rem;
        border-radius: 50%;
        object-fit: cover;
      }

      & .testimonial-info {
        display: flex;
        flex-direction: column;
        gap: var(--space-2xs);
      }

      &:not(.card-layout-flat).color-scheme-standard-secondary,
      &:not(.card-layout-flat).color-scheme-highlight-secondary {
        & .widget-card {
          background-color: var(--bg-secondary);
        }
      }

      &:not(.card-layout-flat).color-scheme-standard-primary,
      &:not(.card-layout-flat).color-scheme-standard-secondary,
      &:not(.card-layout-flat).color-scheme-highlight-primary,
      &:not(.card-layout-flat).color-scheme-highlight-secondary {
        & .widget-card {
          border: var(--border-width-thin) solid var(--border-color);
        }
      }
    }
  </style>

  <div class="widget-container {% unless widget.settings.color_scheme == 'standard-primary' %}widget-container-padded{% endunless %}">
    {% if widget.settings.title != blank or widget.settings.description != blank or widget.settings.eyebrow != blank %}
      <div class="widget-header{% if widget.settings.heading_alignment == 'start' %} widget-header--align-start{% endif %}">
        {% assign header_delay = 0 %}
        {% if widget.settings.eyebrow != blank %}
          <span class="w-eyebrow{% if widget.settings.eyebrow_uppercase %} t-uppercase{% endif %} reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.title != blank %}
          {% if widget.index == 1 %}
            <h1 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h1>
          {% else %}
            <h2 class="w-headline reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="title">{{ widget.settings.title }}</h2>
          {% endif %}
          {% assign header_delay = header_delay | plus: 1 %}
        {% endif %}
        {% if widget.settings.description != blank %}
          <p class="w-description reveal reveal-up" style="--reveal-delay: {{ header_delay }}" data-setting="description">{{ widget.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="widget-content">
      {% if widget.settings.layout == 'carousel' %}
        <div class="carousel-container reveal reveal-up">
          <button type="button" class="carousel-btn carousel-btn-prev" aria-label="Previous">
            <svg class="carousel-btn-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <button type="button" class="carousel-btn carousel-btn-next" aria-label="Next">
            <svg class="carousel-btn-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <ul class="widget-card-grid carousel-track" style="--carousel-cols: {{ widget.settings.columns_desktop }}">
            {% for blockId in widget.blocksOrder %}
              {% assign block = widget.blocks[blockId] %}
              <li class="widget-card{% if widget.settings.card_layout == 'box' %} widget-card-flat{% endif %} carousel-item" data-block-id="{{ blockId }}">
                {% if block.settings.rating != blank %}
                  <div class="testimonial-rating">
                    {% assign rating = block.settings.rating | plus: 0 %}
                    <span class="stars" aria-hidden="true">
                      {% for i in (1..5) %}
                        {% if i <= rating %}
                          <span class="testimonial-star">★</span>
                        {% else %}
                          <span class="testimonial-star empty">★</span>
                        {% endif %}
                      {% endfor %}
                    </span>

                    <span class="visually-hidden">
                      Rated {{ rating }} out of 5
                    </span>
                  </div>
                {% endif %}

                {% if block.settings.quote != blank %}
                  <p class="testimonial-quote w-body" data-setting="quote">{{ block.settings.quote }}</p>
                {% endif %}

                <div class="testimonial-author{% if block.settings.avatar == blank %} testimonial-author-no-avatar{% endif %}">
                  {% if block.settings.avatar != blank %}
                    {% image src: block.settings.avatar, size: 'small', class: 'testimonial-avatar' %}
                  {% endif %}

                  <div class="testimonial-info">
                    {% if block.settings.name != blank %}
                      <p class="testimonial-name w-body t-semibold t-heading" data-setting="name">{{ block.settings.name }}</p>
                    {% endif %}
                    {% if block.settings.title != blank %}
                      <p class="testimonial-title w-meta t-sm" data-setting="title">{{ block.settings.title }}</p>
                    {% endif %}
                  </div>
                </div>
              </li>
            {% endfor %}
          </ul>

        </div>

      {% else %}
        <ul
          class="widget-card-grid widget-grid"
          style="--grid-cols-desktop: {{ widget.settings.columns_desktop }};"
        >
          {% for blockId in widget.blocksOrder %}
            {% assign block = widget.blocks[blockId] %}
            <li class="widget-card{% if widget.settings.card_layout == 'box' %} widget-card-flat{% endif %} reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }}" data-block-id="{{ blockId }}">
              {% if block.settings.rating != blank %}
                <div class="testimonial-rating">
                  {% assign rating = block.settings.rating | plus: 0 %}
                  <span class="stars" aria-hidden="true">
                    {% for i in (1..5) %}
                      {% if i <= rating %}
                        <span class="testimonial-star">★</span>
                      {% else %}
                        <span class="testimonial-star empty">★</span>
                      {% endif %}
                    {% endfor %}
                  </span>

                  <span class="visually-hidden">
                    Rated {{ rating }} out of 5
                  </span>
                </div>
              {% endif %}

              {% if block.settings.quote != blank %}
                <p class="testimonial-quote w-body" data-setting="quote">{{ block.settings.quote }}</p>
              {% endif %}

              <div class="testimonial-author{% if block.settings.avatar == blank %} testimonial-author-no-avatar{% endif %}">
                {% if block.settings.avatar != blank %}
                  {% image src: block.settings.avatar, size: 'small', class: 'testimonial-avatar' %}
                {% endif %}

                <div class="testimonial-info">
                  {% if block.settings.name != blank %}
                    <p class="testimonial-name w-body t-semibold t-heading" data-setting="name">{{ block.settings.name }}</p>
                  {% endif %}
                  {% if block.settings.title != blank %}
                    <p class="testimonial-title w-meta t-sm" data-setting="title">{{ block.settings.title }}</p>
                  {% endif %}
                </div>
              </div>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </div>
</section>

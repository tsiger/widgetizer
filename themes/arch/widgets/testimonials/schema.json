{
  "type": "testimonials",
  "displayName": "tTheme:testimonials.name",
  "aliases": [
    "reviews",
    "feedback",
    "social proof",
    "quotes"
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "tTheme:global.widgets.settings.eyebrow.label"
    },
    {
      "type": "text",
      "id": "title",
      "label": "tTheme:global.widgets.settings.title.label",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "description",
      "label": "tTheme:global.widgets.settings.description.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "tTheme:global.widgets.settings.alignment.label",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "tTheme:global.widgets.settings.options.left"
        },
        {
          "value": "center",
          "label": "tTheme:global.widgets.settings.options.center"
        }
      ]
    },
    {
      "type": "header",
      "id": "display_header",
      "label": "tTheme:global.widgets.settings.display_header.label"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "tTheme:global.widgets.settings.layout.label",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "tTheme:global.widgets.settings.layout.options.grid"
        },
        {
          "value": "carousel",
          "label": "tTheme:global.widgets.settings.layout.options.carousel"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "tTheme:global.widgets.settings.columns_desktop.label",
      "default": 4,
      "min": 2,
      "max": 5,
      "step": 1
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "tTheme:global.widgets.settings.color_scheme.label",
      "default": "standard",
      "options": [
        {
          "value": "standard",
          "label": "tTheme:global.widgets.settings.color_scheme.options.standard"
        },
        {
          "value": "highlight",
          "label": "tTheme:global.widgets.settings.color_scheme.options.highlight"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "displayName": "tTheme:testimonials.blocks.quote.name",
      "settings": [
        {
          "type": "header",
          "id": "content_header",
          "label": "tTheme:global.widgets.settings.content_header.label"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "tTheme:global.widgets.blocks.quote.settings.quote.label",
          "default": "This product has completely transformed how we work. Highly recommended!"
        },
        {
          "type": "image",
          "id": "avatar",
          "label": "tTheme:global.widgets.blocks.quote.settings.avatar.label"
        },
        {
          "type": "text",
          "id": "name",
          "label": "tTheme:global.widgets.blocks.quote.settings.name.label",
          "default": "Jane Smith"
        },
        {
          "type": "text",
          "id": "title",
          "label": "tTheme:global.widgets.blocks.quote.settings.title.label",
          "default": "CEO, Acme Inc."
        },
        {
          "type": "header",
          "id": "display_header",
          "label": "tTheme:global.widgets.settings.display_header.label"
        },
        {
          "type": "select",
          "id": "rating",
          "label": "tTheme:global.widgets.blocks.quote.settings.rating.label",
          "options": [
            {
              "value": "",
              "label": "tTheme:global.widgets.blocks.quote.settings.rating.options."
            },
            {
              "value": "5",
              "label": "tTheme:global.widgets.blocks.quote.settings.rating.options.5"
            },
            {
              "value": "4",
              "label": "tTheme:global.widgets.blocks.quote.settings.rating.options.4"
            },
            {
              "value": "3",
              "label": "tTheme:global.widgets.blocks.quote.settings.rating.options.3"
            }
          ],
          "default": "5"
        }
      ]
    }
  ],

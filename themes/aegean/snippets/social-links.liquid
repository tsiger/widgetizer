{%- comment -%}
  Renders <a> social links from theme social settings.
  Usage: {% render 'social-links', social: theme.social %}
  Caller wraps the output (e.g. <div class="footer-social">...</div>).
{%- endcomment -%}
{%- if social.facebook_url != blank -%}<a href="{{ social.facebook_url | safe_url }}" target="_blank" rel="noopener" aria-label="Facebook">{% render 'icon', name: 'facebook' %}</a>{%- endif -%}
{%- if social.instagram_url != blank -%}<a href="{{ social.instagram_url | safe_url }}" target="_blank" rel="noopener" aria-label="Instagram">{% render 'icon', name: 'instagram' %}</a>{%- endif -%}
{%- if social.twitter_url != blank -%}<a href="{{ social.twitter_url | safe_url }}" target="_blank" rel="noopener" aria-label="X">{% render 'icon', name: 'twitter' %}</a>{%- endif -%}
{%- if social.youtube_url != blank -%}<a href="{{ social.youtube_url | safe_url }}" target="_blank" rel="noopener" aria-label="YouTube">{% render 'icon', name: 'youtube' %}</a>{%- endif -%}
{%- if social.pinterest_url != blank -%}<a href="{{ social.pinterest_url | safe_url }}" target="_blank" rel="noopener" aria-label="Pinterest">{% render 'icon', name: 'pinterest' %}</a>{%- endif -%}

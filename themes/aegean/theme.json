{
  "name": "Aegean",
  "version": "1.0.0",
  "description": "A serene Mediterranean resort & hotel theme inspired by whitewashed Cycladic architecture, deep Aegean blues and sun-warmed terracotta. Includes an Accommodation collection for rooms and suites.",
  "author": "Widgetizer",
  "useCoreWidgets": true,
  "settings": {
    "imageSizes": {
      "thumb": { "width": 150, "enabled": true },
      "small": { "width": 600, "enabled": true },
      "medium": { "width": 1024, "enabled": true },
      "large": { "width": 1600, "enabled": true, "quality": 82 },
      "hero": { "width": 2200, "enabled": true, "quality": 80 }
    },
    "global": {
      "general": [
        { "type": "header", "id": "branding_header", "label": "Branding" },
        { "type": "text", "id": "brand_name", "label": "Brand name", "default": "Aegean Resort" },
        { "type": "image", "id": "favicon", "label": "Favicon", "description": "Square image used to generate site icons on export." },
        { "type": "header", "id": "animation_header", "label": "Animation" },
        {
          "type": "checkbox",
          "id": "enable_reveal_animations",
          "label": "Enable scroll reveal animations",
          "description": "Gently fade and lift sections as they scroll into view.",
          "default": true
        }
      ],
      "colors": [
        { "type": "header", "id": "colors_surfaces_header", "label": "Surfaces" },
        { "type": "color", "id": "bg_primary", "label": "Page background", "default": "#f4f1e9", "outputAsCssVar": true },
        { "type": "color", "id": "bg_surface", "label": "Surface / cards", "default": "#ffffff", "outputAsCssVar": true },
        { "type": "color", "id": "panel", "label": "Panel / alt section", "default": "#ebe4d6", "outputAsCssVar": true },
        { "type": "color", "id": "line", "label": "Hairline / border", "default": "#ddd4c4", "outputAsCssVar": true },
        { "type": "header", "id": "colors_text_header", "label": "Text" },
        { "type": "color", "id": "ink", "label": "Headings", "default": "#15303f", "outputAsCssVar": true },
        { "type": "color", "id": "text", "label": "Body text", "default": "#44525a", "outputAsCssVar": true },
        { "type": "color", "id": "muted", "label": "Muted text", "default": "#7b8890", "outputAsCssVar": true },
        { "type": "header", "id": "colors_brand_header", "label": "Brand" },
        { "type": "color", "id": "sea", "label": "Sea (primary)", "default": "#1f6f8b", "outputAsCssVar": true },
        { "type": "color", "id": "accent", "label": "Accent (terracotta)", "default": "#c25b34", "outputAsCssVar": true },
        { "type": "color", "id": "accent_text", "label": "Accent text", "default": "#ffffff", "outputAsCssVar": true }
      ],
      "typography": [
        { "type": "header", "id": "typography_header", "label": "Typography" },
        {
          "type": "font_picker",
          "id": "heading_font",
          "label": "Heading font",
          "default": { "stack": "\"Cormorant Garamond\", Georgia, \"Times New Roman\", serif", "weight": 600 }
        },
        {
          "type": "font_picker",
          "id": "body_font",
          "label": "Body font",
          "default": { "stack": "\"Mulish\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif", "weight": 400 }
        }
      ],
      "style": [
        { "type": "header", "id": "style_header", "label": "Style" },
        {
          "type": "select",
          "id": "corner_style",
          "label": "Corner style",
          "default": "slightly-rounded",
          "options": [
            { "value": "sharp", "label": "Sharp" },
            { "value": "slightly-rounded", "label": "Slightly rounded" },
            { "value": "rounded", "label": "Rounded" }
          ]
        },
        {
          "type": "select",
          "id": "spacing_density",
          "label": "Spacing density",
          "default": "airy",
          "options": [
            { "value": "compact", "label": "Compact" },
            { "value": "default", "label": "Default" },
            { "value": "airy", "label": "Airy" }
          ]
        },
        {
          "type": "select",
          "id": "button_shape",
          "label": "Button shape",
          "default": "sharp",
          "options": [
            { "value": "auto", "label": "Auto" },
            { "value": "pill", "label": "Pill" },
            { "value": "sharp", "label": "Sharp" }
          ]
        },
        {
          "type": "checkbox",
          "id": "arch_images",
          "label": "Arched image tops",
          "description": "Round the top of feature images into a Cycladic arch.",
          "default": true
        }
      ],
      "social": [
        { "type": "header", "id": "social_header", "label": "Social links" },
        { "type": "text", "id": "facebook_url", "label": "Facebook URL" },
        { "type": "text", "id": "instagram_url", "label": "Instagram URL" },
        { "type": "text", "id": "twitter_url", "label": "X / Twitter URL" },
        { "type": "text", "id": "youtube_url", "label": "YouTube URL" },
        { "type": "text", "id": "pinterest_url", "label": "Pinterest URL" }
      ],
      "privacy": [
        { "type": "header", "id": "privacy_header", "label": "Privacy" },
        {
          "type": "checkbox",
          "id": "use_bunny_fonts",
          "label": "Use Bunny Fonts",
          "description": "Load fonts from the GDPR-friendly Bunny Fonts CDN instead of Google Fonts.",
          "default": false
        }
      ],
      "advanced": [
        { "type": "header", "id": "advanced_header", "label": "Custom code" },
        { "type": "code", "id": "custom_css", "label": "Custom CSS", "language": "css", "rows": 10, "default": "" },
        { "type": "code", "id": "custom_head_scripts", "label": "Custom head scripts", "language": "html", "rows": 8, "default": "" },
        { "type": "code", "id": "custom_footer_scripts", "label": "Custom footer scripts", "language": "html", "rows": 8, "default": "" }
      ]
    }
  }
}

<section
  id="{{ widget.id }}"
  class="widget widget-accommodation-grid widget-{{ widget.id }} section"
  data-widget-id="{{ widget.id }}"
  data-widget-type="accommodation-grid"
  style="--cols: {{ widget.settings.columns | default: 3 }};"
>
  <style>
    .widget-{{ widget.id }} .room-grid {
      display: grid;
      grid-template-columns: repeat(var(--cols, 3), minmax(0, 1fr));
      gap: clamp(1.5rem, 3vw, 2.6rem);
      margin-top: var(--s7);
    }
    .widget-{{ widget.id }} .room-card { position: relative; }
    .widget-{{ widget.id }} .room-card .media {
      aspect-ratio: 4 / 5;
      border-bottom: none;
    }
    .widget-{{ widget.id }} .room-card__body {
      display: flex;
      flex-direction: column;
      flex: 1;
      padding: calc(var(--s5)) calc(var(--s5)) calc(var(--s5));
      gap: var(--s2);
    }
    .widget-{{ widget.id }} .room-card__type {
      font-size: 0.74rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--sea);
    }
    .widget-{{ widget.id }} .room-card__title {
      font-size: var(--fs-h3);
      line-height: 1.1;
    }
    .widget-{{ widget.id }} .room-card__title a { color: inherit; }
    .widget-{{ widget.id }} .room-card__title a:hover { color: var(--accent); }
    .widget-{{ widget.id }} .room-card__summary {
      color: var(--muted);
      font-size: 0.96rem;
      line-height: 1.6;
    }
    .widget-{{ widget.id }} .room-card__specs {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 1.2rem;
      margin-top: var(--s2);
      padding-top: var(--s3);
      border-top: 1px solid var(--line);
      color: var(--text);
      font-size: 0.85rem;
    }
    .widget-{{ widget.id }} .room-card__specs span {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }
    .widget-{{ widget.id }} .room-card__specs svg {
      width: 1.05rem;
      height: 1.05rem;
      color: var(--sea);
    }
    .widget-{{ widget.id }} .room-card__foot {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1rem;
      margin-top: auto;
      padding-top: var(--s4);
    }
    .widget-{{ widget.id }} .room-card__price {
      display: flex;
      flex-direction: column;
      line-height: 1.1;
    }
    .widget-{{ widget.id }} .room-card__price small {
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .widget-{{ widget.id }} .room-card__price b {
      font-family: var(--font-head);
      font-weight: 600;
      font-size: 1.9rem;
      color: var(--ink);
    }
    .widget-{{ widget.id }} .room-card__price b span {
      font-size: 0.9rem;
      color: var(--muted);
    }
    .widget-{{ widget.id }} .room-grid--empty {
      display: block;
      margin-top: var(--s6);
      padding: var(--s7);
      text-align: center;
      border: 1px dashed var(--line);
      border-radius: var(--radius-lg);
      color: var(--muted);
    }
    .widget-{{ widget.id }} .room-grid-foot {
      display: flex;
      justify-content: center;
      margin-top: var(--s7);
    }
    @media (max-width: 880px) {
      .widget-{{ widget.id }} .room-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 560px) {
      .widget-{{ widget.id }} .room-grid { grid-template-columns: 1fr; }
    }
  </style>

  <div class="container container--wide">
    <div class="heading-group heading-group--center reveal reveal-up">
      {% if widget.settings.eyebrow != blank %}
        <span class="eyebrow eyebrow--center" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
      {% endif %}
      {% if widget.settings.heading != blank %}
        <h2 class="section-title" data-setting="heading">{{ widget.settings.heading }}</h2>
      {% endif %}
      {% if widget.settings.subheading != blank %}
        <p class="lede" data-setting="subheading">{{ widget.settings.subheading }}</p>
      {% endif %}
    </div>

    {% assign rooms = 'accommodation' | collection: limit: widget.settings.limit, sort: widget.settings.sort %}

    {% if rooms == empty %}
      <p class="room-grid--empty">No accommodation has been added yet. Create items in the <strong>Accommodation</strong> collection to populate this section.</p>
    {% else %}
      <div class="room-grid">
        {% for room in rooms %}
          <article class="card room-card reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }};" data-block-id="{{ room.uuid }}">
            <div class="media media--arch">
              {% if room.url %}<a href="{{ room.url }}" aria-label="{{ room.settings.title }}">{% endif %}
              {% if room.settings.featured_image != blank %}
                {% image src: room.settings.featured_image, size: 'large', srcset: true, sizes: '(max-width: 560px) 100vw, 33vw', alt: room.settings.title %}
              {% else %}
                {% placeholder_image aspect: 'portrait' %}
              {% endif %}
              {% if room.url %}</a>{% endif %}
            </div>

            <div class="room-card__body">
              {% if room.settings.room_type != blank %}
                <span class="room-card__type">{{ room.settings.room_type }}</span>
              {% endif %}
              <h3 class="room-card__title">
                {% if room.url %}<a href="{{ room.url }}">{{ room.settings.title }}</a>{% else %}{{ room.settings.title }}{% endif %}
              </h3>
              {% if room.settings.summary != blank %}
                <p class="room-card__summary">{{ room.settings.summary }}</p>
              {% endif %}

              <div class="room-card__specs">
                {% if room.settings.max_guests != blank %}
                  <span>{% render 'icon', name: 'guests' %}{{ room.settings.max_guests }} guests</span>
                {% endif %}
                {% if room.settings.size_sqm != blank %}
                  <span>{% render 'icon', name: 'size' %}{{ room.settings.size_sqm }} m²</span>
                {% endif %}
                {% if room.settings.bed_type != blank %}
                  <span>{% render 'icon', name: 'bed' %}{{ room.settings.bed_type }}</span>
                {% endif %}
              </div>

              <div class="room-card__foot">
                {% if room.settings.from_price != blank %}
                  <span class="room-card__price">
                    <small>From</small>
                    <b>{{ widget.settings.currency }}{{ room.settings.from_price }} <span>/ {{ widget.settings.price_suffix }}</span></b>
                  </span>
                {% endif %}
                {% if room.url %}
                  <a class="text-link" href="{{ room.url }}">{{ widget.settings.cta_label | default: 'View details' }}{% render 'icon', name: 'arrow-right' %}</a>
                {% endif %}
              </div>
            </div>
          </article>
        {% endfor %}
      </div>

      {% if widget.settings.all_link.href != blank and widget.settings.all_label != blank %}
        <div class="room-grid-foot">
          <a class="btn btn--outline" href="{{ widget.settings.all_link.href }}"{% if widget.settings.all_link.target != blank %} target="{{ widget.settings.all_link.target }}"{% endif %}>{{ widget.settings.all_label }}</a>
        </div>
      {% endif %}
    {% endif %}
  </div>
</section>

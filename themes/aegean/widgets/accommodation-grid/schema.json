{
  "type": "accommodation-grid",
  "displayName": "Accommodation Grid",
  "aliases": ["rooms", "suites", "accommodation", "collection", "stays"],
  "settings": [
    { "type": "header", "id": "content_header", "label": "Heading" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay with us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Rooms & Suites" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Each room is a private balcony over the Aegean — choose the space that suits your escape." },
    { "type": "header", "id": "source_header", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Items to show", "default": 3, "min": 1, "max": 12, "step": 1 },
    {
      "type": "select",
      "id": "sort",
      "label": "Sort",
      "default": "manual",
      "options": [
        { "value": "manual", "label": "Manual order" },
        { "value": "created_desc", "label": "Newest first" },
        { "value": "title_asc", "label": "Name (A–Z)" },
        { "value": "title_desc", "label": "Name (Z–A)" }
      ]
    },
    { "type": "header", "id": "display_header", "label": "Display" },
    { "type": "range", "id": "columns", "label": "Columns", "default": 3, "min": 2, "max": 4, "step": 1 },
    { "type": "text", "id": "currency", "label": "Currency symbol", "default": "€" },
    { "type": "text", "id": "price_suffix", "label": "Price suffix", "default": "per night" },
    { "type": "text", "id": "cta_label", "label": "Card link label", "default": "View details" },
    { "type": "header", "id": "footer_header", "label": "Footer link" },
    { "type": "text", "id": "all_label", "label": "View-all label", "default": "All accommodation" },
    { "type": "link", "id": "all_link", "label": "View-all link", "hide_text": true }
  ]
}

<section
  id="{{ widget.id }}"
  class="widget widget-amenities widget-{{ widget.id }} section section--panel amenities--{{ widget.settings.variant | default: 'boxed' }}"
  data-widget-id="{{ widget.id }}"
  data-widget-type="amenities"
  style="--cols: {{ widget.settings.columns | default: 4 }};"
>
  <style>
    .widget-{{ widget.id }} .amenity-grid {
      display: grid;
      grid-template-columns: repeat(var(--cols, 4), minmax(0, 1fr));
      gap: clamp(0.6rem, 1.6vw, 1.4rem);
      margin-top: var(--s7);
    }
    .widget-{{ widget.id }} .amenity {
      display: flex;
      flex-direction: column;
      gap: var(--s2);
      padding: var(--s5);
      text-align: center;
      align-items: center;
    }
    .widget-{{ widget.id }}.amenities--boxed .amenity {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
    }
    .widget-{{ widget.id }}.amenities--boxed .amenity:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-lg);
    }
    .widget-{{ widget.id }} .amenity__icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 3.6rem;
      height: 3.6rem;
      margin-bottom: var(--s2);
      color: var(--sea);
      border-radius: 50%;
      background: var(--sea-soft);
    }
    .widget-{{ widget.id }} .amenity__icon svg { width: 1.7rem; height: 1.7rem; }
    .widget-{{ widget.id }} .amenity__title {
      font-family: var(--font-head);
      font-size: 1.3rem;
      color: var(--ink);
    }
    .widget-{{ widget.id }} .amenity__text {
      font-size: 0.92rem;
      color: var(--muted);
      line-height: 1.55;
    }
    @media (max-width: 880px) {
      .widget-{{ widget.id }} .amenity-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 460px) {
      .widget-{{ widget.id }} .amenity-grid { grid-template-columns: 1fr; }
    }
  </style>

  <div class="container container--wide">
    <div class="heading-group heading-group--center reveal reveal-up">
      {% if widget.settings.eyebrow != blank %}
        <span class="eyebrow eyebrow--center" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
      {% endif %}
      {% if widget.settings.heading != blank %}
        <h2 class="section-title" data-setting="heading">{{ widget.settings.heading }}</h2>
      {% endif %}
      {% if widget.settings.subheading != blank %}
        <p class="lede" data-setting="subheading">{{ widget.settings.subheading }}</p>
      {% endif %}
    </div>

    {% if widget.blocks != blank %}
      <div class="amenity-grid">
        {% for blockId in widget.blocksOrder %}
          {% assign block = widget.blocks[blockId] %}
          <div class="amenity reveal reveal-up" style="--reveal-delay: {{ forloop.index0 }};" data-block-id="{{ blockId }}">
            <span class="amenity__icon">{% render 'icon', name: block.settings.icon %}</span>
            {% if block.settings.title != blank %}
              <h3 class="amenity__title" data-setting="title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.text != blank %}
              <p class="amenity__text" data-setting="text">{{ block.settings.text }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

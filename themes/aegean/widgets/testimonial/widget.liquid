<section
  id="{{ widget.id }}"
  class="widget widget-testimonial widget-{{ widget.id }} section section--{{ widget.settings.background | default: 'ink' }}"
  data-widget-id="{{ widget.id }}"
  data-widget-type="testimonial"
>
  <style>
    .widget-{{ widget.id }} .quote-wrap {
      max-width: 56rem;
      margin-inline: auto;
      text-align: center;
    }
    .widget-{{ widget.id }} .quote-mark {
      color: var(--accent);
      display: inline-flex;
      margin-bottom: var(--s4);
    }
    .widget-{{ widget.id }} .quote-mark svg { width: 3rem; height: 3rem; }
    .widget-{{ widget.id }} .quote-stars {
      display: inline-flex;
      gap: 0.3rem;
      margin-bottom: var(--s4);
      color: var(--accent);
    }
    .widget-{{ widget.id }} .quote-stars svg { width: 1.1rem; height: 1.1rem; }
    .widget-{{ widget.id }} .quote-text {
      font-family: var(--font-head);
      font-weight: 500;
      font-size: clamp(1.8rem, 3.4vw, 3rem);
      line-height: 1.28;
      letter-spacing: -0.01em;
      color: #fff;
      text-wrap: balance;
    }
    .widget-{{ widget.id }}.section--panel .quote-text { color: var(--ink); }
    .widget-{{ widget.id }} .quote-author {
      display: inline-flex;
      align-items: center;
      gap: 0.9rem;
      margin-top: var(--s6);
    }
    .widget-{{ widget.id }} .quote-author img {
      width: 3.2rem;
      height: 3.2rem;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid rgba(255,255,255,0.4);
    }
    .widget-{{ widget.id }} .quote-author__name {
      font-weight: 700;
      letter-spacing: 0.04em;
      color: #fff;
    }
    .widget-{{ widget.id }}.section--panel .quote-author__name { color: var(--ink); }
    .widget-{{ widget.id }} .quote-author__detail {
      font-size: 0.85rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      opacity: 0.75;
    }
    .widget-{{ widget.id }} .quote-author__txt { text-align: left; }
  </style>

  <div class="container">
    <div class="quote-wrap reveal reveal-up">
      <span class="quote-mark">{% render 'icon', name: 'quote' %}</span>

      {% assign stars = widget.settings.rating | default: 5 %}
      {% if stars > 0 %}
        <div class="quote-stars" aria-label="{{ stars }} out of 5 stars">
          {% for i in (1..stars) %}{% render 'icon', name: 'star' %}{% endfor %}
        </div>
      {% endif %}

      {% if widget.settings.quote != blank %}
        <blockquote class="quote-text" data-setting="quote">{{ widget.settings.quote }}</blockquote>
      {% endif %}

      <div class="quote-author">
        {% if widget.settings.author_image != blank %}
          {% image src: widget.settings.author_image, size: 'small', alt: widget.settings.author_name %}
        {% endif %}
        <span class="quote-author__txt">
          {% if widget.settings.author_name != blank %}
            <span class="quote-author__name" data-setting="author_name">{{ widget.settings.author_name }}</span>
          {% endif %}
          {% if widget.settings.author_detail != blank %}
            <span class="quote-author__detail" data-setting="author_detail" style="display:block;">{{ widget.settings.author_detail }}</span>
          {% endif %}
        </span>
      </div>
    </div>
  </div>
</section>

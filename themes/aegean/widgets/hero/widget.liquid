<section
  id="{{ widget.id }}"
  class="widget widget-hero widget-{{ widget.id }} hero hero--{{ widget.settings.height | default: 'full' }} hero--{{ widget.settings.alignment | default: 'center' }}"
  data-widget-id="{{ widget.id }}"
  data-widget-type="hero"
  style="--ov: {{ widget.settings.overlay | default: 42 }}%;"
>
  <style>
    .widget-{{ widget.id }} {
      position: relative;
      display: grid;
      align-items: center;
      isolation: isolate;
      color: #fff;
      overflow: hidden;
    }
    .widget-{{ widget.id }}.hero--medium { min-height: 64vh; }
    .widget-{{ widget.id }}.hero--tall { min-height: 84vh; }
    .widget-{{ widget.id }}.hero--full { min-height: 100svh; }
    .widget-{{ widget.id }} .hero__img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: -2;
    }
    .widget-{{ widget.id }} .hero__veil {
      position: absolute;
      inset: 0;
      z-index: -1;
      background:
        linear-gradient(180deg, rgba(21,48,63,calc(var(--ov) * 0.6 / 100)) 0%, rgba(21,48,63,calc(var(--ov) / 100)) 100%),
        linear-gradient(0deg, rgba(21,48,63,0.35) 0%, transparent 38%);
    }
    .widget-{{ widget.id }} .hero__inner {
      width: 100%;
      padding-block: calc(var(--header-h) + 4rem) 6rem;
    }
    .widget-{{ widget.id }} .hero__content { max-width: 60rem; }
    .widget-{{ widget.id }}.hero--center .hero__content {
      margin-inline: auto;
      text-align: center;
    }
    .widget-{{ widget.id }} .hero__eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.7rem;
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.88);
      margin-bottom: var(--s4);
    }
    .widget-{{ widget.id }} .hero__eyebrow::before {
      content: "";
      width: 2.4rem;
      height: 1px;
      background: var(--accent);
    }
    .widget-{{ widget.id }}.hero--center .hero__eyebrow::after {
      content: "";
      width: 2.4rem;
      height: 1px;
      background: var(--accent);
    }
    .widget-{{ widget.id }} .hero__title {
      color: #fff;
      font-size: var(--fs-display);
      font-weight: 500;
      line-height: 1.02;
      letter-spacing: -0.015em;
      text-wrap: balance;
    }
    .widget-{{ widget.id }} .hero__sub {
      max-width: 42rem;
      margin-top: var(--s4);
      font-size: var(--fs-lede);
      line-height: 1.7;
      color: rgba(255,255,255,0.9);
    }
    .widget-{{ widget.id }}.hero--center .hero__sub { margin-inline: auto; }
    .widget-{{ widget.id }} .hero__actions {
      display: flex;
      flex-wrap: wrap;
      gap: var(--s3);
      margin-top: var(--s6);
    }
    .widget-{{ widget.id }}.hero--center .hero__actions { justify-content: center; }
    .widget-{{ widget.id }} .hero__scroll {
      position: absolute;
      left: 50%;
      bottom: 2rem;
      translate: -50% 0;
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.68rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.75);
    }
    .widget-{{ widget.id }} .hero__scroll span {
      width: 1px;
      height: 2.6rem;
      background: rgba(255,255,255,0.6);
      animation: hero-scroll 2.2s var(--ease) infinite;
      transform-origin: top;
    }
    @keyframes hero-scroll {
      0% { transform: scaleY(0); opacity: 0; }
      40% { transform: scaleY(1); opacity: 1; }
      100% { transform: scaleY(0) translateY(2.6rem); opacity: 0; }
    }
  </style>

  {% if widget.settings.background_image != blank %}
    {% image src: widget.settings.background_image, size: 'hero', srcset: true, sizes: '100vw', class: 'hero__img', lazy: false, fetchpriority: 'high', alt: '' %}
  {% else %}
    {% placeholder_image aspect: 'landscape', class: 'hero__img' %}
  {% endif %}
  <div class="hero__veil"></div>

  <div class="hero__inner container container--wide">
    <div class="hero__content">
      {% if widget.settings.eyebrow != blank %}
        <span class="hero__eyebrow reveal reveal-fade" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
      {% endif %}
      {% if widget.settings.heading != blank %}
        {%- assign heading_lines = widget.settings.heading | strip | split: '
' -%}
        <h1 class="hero__title reveal reveal-up" style="--reveal-delay: 1;" data-setting="heading">{% for ln in heading_lines %}{{ ln }}{% unless forloop.last %}<br />{% endunless %}{% endfor %}</h1>
      {% endif %}
      {% if widget.settings.subheading != blank %}
        <p class="hero__sub reveal reveal-up" style="--reveal-delay: 2;" data-setting="subheading">{{ widget.settings.subheading }}</p>
      {% endif %}
      {% if widget.settings.button_label != blank or widget.settings.button2_label != blank %}
        <div class="hero__actions reveal reveal-up" style="--reveal-delay: 3;">
          {% if widget.settings.button_label != blank %}
            <a class="btn" href="{{ widget.settings.button_link.href | default: 'contact.html' }}"{% if widget.settings.button_link.target != blank %} target="{{ widget.settings.button_link.target }}"{% endif %}>{{ widget.settings.button_label }}</a>
          {% endif %}
          {% if widget.settings.button2_label != blank %}
            <a class="btn btn--light" href="{{ widget.settings.button2_link.href | default: '#' }}"{% if widget.settings.button2_link.target != blank %} target="{{ widget.settings.button2_link.target }}"{% endif %}>{{ widget.settings.button2_label }}</a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>

  {% if widget.settings.scroll_hint %}
    <div class="hero__scroll" aria-hidden="true">Scroll<span></span></div>
  {% endif %}
</section>

{
  "type": "hero",
  "displayName": "Hero",
  "supportsTransparentHeader": true,
  "aliases": ["banner", "cover", "intro", "masthead"],
  "settings": [
    { "type": "header", "id": "content_header", "label": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Santorini · Greece" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Where the Aegean\nmeets the sky" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "A whitewashed retreat perched above the caldera, with sunsets that fold the sea into gold." },
    { "type": "header", "id": "buttons_header", "label": "Buttons" },
    { "type": "text", "id": "button_label", "label": "Primary button", "default": "Reserve your stay" },
    { "type": "link", "id": "button_link", "label": "Primary link", "hide_text": true },
    { "type": "text", "id": "button2_label", "label": "Secondary button", "default": "Explore rooms" },
    { "type": "link", "id": "button2_link", "label": "Secondary link", "hide_text": true },
    { "type": "header", "id": "media_header", "label": "Background" },
    { "type": "image", "id": "background_image", "label": "Background image" },
    { "type": "range", "id": "overlay", "label": "Overlay strength", "default": 42, "min": 0, "max": 80, "step": 2, "unit": "%" },
    { "type": "header", "id": "layout_header", "label": "Layout" },
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "default": "full",
      "options": [
        { "value": "medium", "label": "Medium" },
        { "value": "tall", "label": "Tall" },
        { "value": "full", "label": "Full screen" }
      ]
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "default": "center",
      "options": [
        { "value": "start", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    { "type": "checkbox", "id": "scroll_hint", "label": "Show scroll hint", "default": true }
  ]
}

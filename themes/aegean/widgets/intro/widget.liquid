<section
  id="{{ widget.id }}"
  class="widget widget-intro widget-{{ widget.id }} section intro--img-{{ widget.settings.image_position | default: 'end' }}"
  data-widget-id="{{ widget.id }}"
  data-widget-type="intro"
>
  <style>
    .widget-{{ widget.id }} .intro__grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2.5rem, 6vw, 6rem);
      align-items: center;
    }
    .widget-{{ widget.id }}.intro--img-start .intro__media { order: -1; }
    .widget-{{ widget.id }} .intro__body { max-width: 38rem; }
    .widget-{{ widget.id }} .intro__title {
      font-size: var(--fs-h2);
      margin-bottom: var(--s4);
      text-wrap: balance;
    }
    .widget-{{ widget.id }} .intro__rte { color: var(--text); }
    .widget-{{ widget.id }} .intro__rte p + p { margin-top: 1em; }
    .widget-{{ widget.id }} .intro__cta { margin-top: var(--s6); }
    .widget-{{ widget.id }} .intro__media { position: relative; }
    .widget-{{ widget.id }} .intro__media .media {
      aspect-ratio: 4 / 5;
      box-shadow: var(--shadow-lg);
    }
    .widget-{{ widget.id }} .intro__caption {
      position: absolute;
      bottom: -1.4rem;
      {% if widget.settings.image_position == 'start' %}right: -1rem;{% else %}left: -1rem;{% endif %}
      background: var(--surface);
      color: var(--ink);
      font-family: var(--font-head);
      font-size: 1.4rem;
      letter-spacing: 0.02em;
      padding: 0.9rem 1.6rem;
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-sm);
    }
    @media (max-width: 820px) {
      .widget-{{ widget.id }} .intro__grid { grid-template-columns: 1fr; }
      .widget-{{ widget.id }}.intro--img-start .intro__media { order: 0; }
      .widget-{{ widget.id }} .intro__media .media { aspect-ratio: 5 / 4; }
    }
  </style>

  <div class="container container--wide">
    <div class="intro__grid">
      <div class="intro__body reveal reveal-up">
        {% if widget.settings.eyebrow != blank %}
          <span class="eyebrow" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
        {% endif %}
        {% if widget.settings.heading != blank %}
          <h2 class="intro__title" data-setting="heading">{{ widget.settings.heading }}</h2>
        {% endif %}
        {% if widget.settings.body != blank %}
          <div class="intro__rte rte" data-setting="body">{{ widget.settings.body | raw }}</div>
        {% endif %}
        {% if widget.settings.button_label != blank %}
          <div class="intro__cta">
            <a class="text-link" href="{{ widget.settings.button_link.href | default: '#' }}"{% if widget.settings.button_link.target != blank %} target="{{ widget.settings.button_link.target }}"{% endif %}>
              {{ widget.settings.button_label }}{% render 'icon', name: 'arrow-right' %}
            </a>
          </div>
        {% endif %}
      </div>

      <div class="intro__media reveal reveal-scale" style="--reveal-delay: 1;">
        <div class="media media--arch">
          {% if widget.settings.image != blank %}
            {% image src: widget.settings.image, size: 'large', srcset: true, sizes: '(max-width: 820px) 100vw, 45vw' %}
          {% else %}
            {% placeholder_image aspect: 'portrait' %}
          {% endif %}
        </div>
        {% if widget.settings.image_caption != blank %}
          <span class="intro__caption">{{ widget.settings.image_caption }}</span>
        {% endif %}
      </div>
    </div>
  </div>
</section>

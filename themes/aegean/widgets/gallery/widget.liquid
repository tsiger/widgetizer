<section
  id="{{ widget.id }}"
  class="widget widget-gallery widget-{{ widget.id }} section gallery--{{ widget.settings.layout | default: 'mosaic' }}"
  data-widget-id="{{ widget.id }}"
  data-widget-type="gallery"
>
  <style>
    .widget-{{ widget.id }} .gallery-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 1fr;
      gap: clamp(0.5rem, 1.2vw, 1rem);
      margin-top: var(--s7);
    }
    .widget-{{ widget.id }} .gallery__item {
      position: relative;
      display: block;
      width: 100%;
      padding: 0;
      overflow: hidden;
      border-radius: var(--radius-md);
      cursor: zoom-in;
      aspect-ratio: 1 / 1;
      background: var(--panel);
    }
    .widget-{{ widget.id }} .gallery__item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.8s var(--ease);
    }
    .widget-{{ widget.id }} .gallery__item:hover img { transform: scale(1.06); }
    .widget-{{ widget.id }} .gallery__item::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 55%, rgba(21,48,63,0.55));
      opacity: 0;
      transition: opacity 0.4s var(--ease);
    }
    .widget-{{ widget.id }} .gallery__item:hover::after { opacity: 1; }
    .widget-{{ widget.id }} .gallery__cap {
      position: absolute;
      left: 1rem;
      bottom: 0.85rem;
      z-index: 1;
      color: #fff;
      font-size: 0.82rem;
      letter-spacing: 0.04em;
      opacity: 0;
      translate: 0 0.5rem;
      transition: opacity 0.4s var(--ease), translate 0.4s var(--ease);
    }
    .widget-{{ widget.id }} .gallery__item:hover .gallery__cap { opacity: 1; translate: 0 0; }

    .widget-{{ widget.id }}.gallery--mosaic .gallery__item:nth-child(6n + 1) {
      grid-column: span 2;
      grid-row: span 2;
      aspect-ratio: auto;
    }
    .widget-{{ widget.id }}.gallery--mosaic .gallery__item:nth-child(6n + 4) {
      grid-column: span 2;
      aspect-ratio: 2 / 1;
    }
    @media (max-width: 760px) {
      .widget-{{ widget.id }} .gallery-grid { grid-template-columns: repeat(2, 1fr); }
      .widget-{{ widget.id }}.gallery--mosaic .gallery__item:nth-child(6n + 1),
      .widget-{{ widget.id }}.gallery--mosaic .gallery__item:nth-child(6n + 4) {
        grid-column: span 2;
        grid-row: auto;
        aspect-ratio: 16 / 10;
      }
    }
  </style>

  <div class="container container--wide">
    <div class="heading-group heading-group--center reveal reveal-up">
      {% if widget.settings.eyebrow != blank %}
        <span class="eyebrow eyebrow--center" data-setting="eyebrow">{{ widget.settings.eyebrow }}</span>
      {% endif %}
      {% if widget.settings.heading != blank %}
        <h2 class="section-title" data-setting="heading">{{ widget.settings.heading }}</h2>
      {% endif %}
      {% if widget.settings.subheading != blank %}
        <p class="lede" data-setting="subheading">{{ widget.settings.subheading }}</p>
      {% endif %}
    </div>

    {% if widget.blocks != blank %}
      <div class="gallery-grid reveal reveal-fade">
        {% for blockId in widget.blocksOrder %}
          {% assign block = widget.blocks[blockId] %}
          <button
            type="button"
            class="gallery__item"
            data-block-id="{{ blockId }}"
            data-lightbox="gallery-{{ widget.id }}"
            data-lightbox-src="{% if block.settings.image != blank %}{% image src: block.settings.image, size: 'hero', output: 'url' %}{% endif %}"
            aria-label="{{ block.settings.caption | default: 'View photo' }}"
          >
            {% if block.settings.image != blank %}
              {% image src: block.settings.image, size: 'medium', srcset: true, sizes: '(max-width: 760px) 50vw, 25vw', alt: block.settings.caption %}
            {% else %}
              {% placeholder_image aspect: 'square' %}
            {% endif %}
            {% if block.settings.caption != blank %}
              <span class="gallery__cap">{{ block.settings.caption }}</span>
            {% endif %}
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>
